{
  "ConnectionStrings": {
    "DefaultConnection": "Server=staging-server\\SQLEXPRESS;Database=ReportPanel_Staging;User Id=staging_user;Password=CHANGE_ME;TrustServerCertificate=true;",
    "LoggingConnection": "Server=staging-server\\SQLEXPRESS;Database=ReportPanel_Staging;User Id=staging_user;Password=CHANGE_ME;TrustServerCertificate=true;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "Console": {
      "IncludeScopes": true
    },
    "File": {
      "Path": "logs/staging-{Date}.log",
      "MinLevel": "Information"
    }
  },
  "AllowedHosts": "*",
  "Environment": "Staging",
  "Features": {
    "EnableDetailedErrors": true,
    "EnableSwagger": true,
    "EnableHealthChecks": true,
    "EnableMetrics": true
  },
  "Security": {
    "RequireHttps": false,
    "EnableCors": true,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://staging.bkm.com",
      "https://staging.bkm.com"
    ]
  },
  "Cache": {
    "DefaultExpirationMinutes": 5,
    "EnableDistributedCache": false
  },
  "Performance": {
    "CommandTimeoutSeconds": 30,
    "MaxConcurrentReports": 10,
    "EnableQueryOptimization": true
  },
  "Monitoring": {
    "EnableApplicationInsights": false,
    "EnableHealthChecks": true,
    "HealthCheckIntervalSeconds": 30
  }
}
