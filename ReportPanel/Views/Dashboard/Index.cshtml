@model ReportPanel.ViewModels.DashboardViewModel
@using System.Globalization
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Genel Bakış - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Genel Bakış";

    var trCulture = new CultureInfo("tr-TR");
    var now = DateTime.Now;
    var todayStr = now.ToString("d MMMM yyyy, dddd", trCulture);
    var firstName = !string.IsNullOrWhiteSpace(Model.FullName)
        ? Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? Model.User
        : Model.User;

    string GreetingByHour()
    {
        var h = DateTime.Now.Hour;
        if (h < 6) return "İyi geceler";
        if (h < 12) return "Günaydın";
        if (h < 18) return "İyi günler";
        return "İyi akşamlar";
    }

    string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - (dt.Kind == DateTimeKind.Utc ? dt : dt.ToUniversalTime());
        if (diff.TotalSeconds < 60) return "şimdi";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} dk önce";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} sa önce";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} gün önce";
        return dt.ToString("dd.MM.yyyy", trCulture);
    }

    string AvatarInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(new[] { ' ', '.', '_' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpperInvariant();
    }

    string ReportTypeChip(ReportPanel.Models.ReportCatalog r)
    {
        // Heuristik: dashboard widget sayısına göre tür ataması (M-13 P1'de gerçek metadata)
        return "type-dash";
    }

    int maxRun = Model.TopRunReports.Count > 0 ? Model.TopRunReports.Max(t => t.Count) : 1;

    // Hourly trend SVG path generator (24 nokta, viewBox 480x140)
    string BuildHourlyPath(List<ReportPanel.ViewModels.HourlyTrendItem> trend, bool closeArea)
    {
        if (trend == null || trend.Count == 0) return "";
        var max = Math.Max(1, trend.Max(t => t.Count));
        var n = trend.Count;
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < n; i++)
        {
            var x = (n == 1) ? 240 : (int)Math.Round(i * (480.0 / (n - 1)));
            var y = 110 - (int)Math.Round((trend[i].Count / (double)max) * 92.0); // 18-110 range
            if (i == 0) sb.Append($"M{x},{y}");
            else sb.Append($" L{x},{y}");
        }
        if (closeArea)
        {
            sb.Append(" L480,140 L0,140 Z");
        }
        return sb.ToString();
    }

    var hourlyPath = BuildHourlyPath(Model.HourlyTrend, false);
    var hourlyArea = BuildHourlyPath(Model.HourlyTrend, true);
    var hourlyTotal = Model.HourlyTrend.Sum(h => h.Count);
    // Son nokta vurgu
    var lastPoint = Model.HourlyTrend.LastOrDefault();
    var lastPointHasData = lastPoint != null && lastPoint.Count > 0;
    var lastX = 480;
    var hourlyMax = Model.HourlyTrend.Count > 0 ? Math.Max(1, Model.HourlyTrend.Max(t => t.Count)) : 1;
    var lastY = lastPoint != null ? 110 - (int)Math.Round((lastPoint.Count / (double)hourlyMax) * 92.0) : 110;
}

<div class="hero">
    <h1>@GreetingByHour(), @firstName 👋</h1>
    <div class="sub">
        <span class="mono">@todayStr</span>
        @{
            var dotColor = Model.SystemStatusKind switch
            {
                "warn" => "var(--warn)",
                "err"  => "var(--danger)",
                _      => "var(--ok)"
            };
        }
        <span class="pill"><span class="dot" style="background:@dotColor"></span>@Model.SystemStatus</span>
        <span class="pill mono">@Model.DataSourceStatus</span>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card k-red">
        <div class="head">
            <span class="label">Erişilebilir Rapor</span>
            <div class="ico"><i class="fas fa-chart-column"></i></div>
        </div>
        <div class="value">@Model.ReportCount.ToString("N0", trCulture)</div>
        <div class="delta up">
            <i class="fas fa-arrow-up text-[10px]"></i>
            <span>aktif</span>
            <span class="desc">rol filtresine göre</span>
        </div>
    </div>

    <div class="kpi-card k-ink">
        <div class="head">
            <span class="label">Bugün Çalıştırılan</span>
            <div class="ico"><i class="fas fa-play"></i></div>
        </div>
        <div class="value">@Model.TodayRunCount.ToString("N0", trCulture)</div>
        <div class="delta">
            <span class="desc">tüm kullanıcılar</span>
        </div>
    </div>

    <div class="kpi-card k-green">
        <div class="head">
            <span class="label">Aktif Kullanıcı</span>
            <div class="ico"><i class="fas fa-users"></i></div>
        </div>
        <div class="value">@Model.ActiveUserCount.ToString("N0", trCulture)</div>
        <div class="delta">
            <span class="desc">son 1 saat</span>
        </div>
    </div>

    <div class="kpi-card k-warn">
        <div class="head">
            <span class="label">Bu Ay (Sen)</span>
            <div class="ico"><i class="fas fa-clock"></i></div>
        </div>
        <div class="value">@Model.MonthlyRunCount.ToString("N0", trCulture)</div>
        <div class="delta">
            @if (Model.LastRunAt.HasValue)
            {
                <span class="desc">son: @TimeAgo(Model.LastRunAt.Value)</span>
            }
            else
            {
                <span class="desc">henüz çalıştırılmadı</span>
            }
        </div>
    </div>
</div>

<div class="section-title">
    <h2>Bugünün Özeti</h2>
    <a href="/Logs" class="more">Detaylı analiz <i class="fas fa-chevron-right text-[10px]"></i></a>
</div>

<div class="grid-2">

    <div class="mini-chart">
        <div class="head">
            <div>
                <h3>Saatlik Çalıştırma Trendi</h3>
                <div style="font-size:12px; color:var(--ink-3); margin-top:2px;">Son 24 saat · tüm raporlar</div>
            </div>
            <div style="text-align:right;">
                <div style="font-size:22px; font-weight:700; color:var(--ink-0); line-height:1; letter-spacing:-.02em; font-variant-numeric:tabular-nums;">@Model.TodayRunCount</div>
                <div style="font-size:11.5px; color:var(--ok); font-weight:600;">bugün toplam</div>
            </div>
        </div>
        @* Canlı SVG — son 24 saat audit_log report_run group by hour (DashboardController) *@
        <svg width="100%" height="140" viewBox="0 0 480 140" preserveAspectRatio="none">
            <defs>
                <linearGradient id="dashAreaGrad" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#dc2626" stop-opacity=".22"/>
                    <stop offset="100%" stop-color="#dc2626" stop-opacity="0"/>
                </linearGradient>
            </defs>
            <line x1="0" y1="35" x2="480" y2="35" stroke="#f3f4f6"/>
            <line x1="0" y1="70" x2="480" y2="70" stroke="#f3f4f6"/>
            <line x1="0" y1="105" x2="480" y2="105" stroke="#f3f4f6"/>
            @if (hourlyTotal > 0)
            {
                <path d="@hourlyArea" fill="url(#dashAreaGrad)" />
                <path d="@hourlyPath" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                @if (lastPointHasData)
                {
                    <circle cx="@lastX" cy="@lastY" r="3.5" fill="#dc2626"/>
                }
            }
            else
            {
                @Html.Raw("<text x='240' y='75' text-anchor='middle' font-family='Inter' font-size='11' fill='#9ca3af'>son 24 saatte rapor çalıştırma yok</text>")
            }
            <text x="0" y="135" font-family="JetBrains Mono" font-size="9.5" fill="#9ca3af">@(Model.HourlyTrend.FirstOrDefault()?.Hour.ToLocalTime().ToString("HH:mm") ?? "")</text>
            <text x="120" y="135" font-family="JetBrains Mono" font-size="9.5" fill="#9ca3af">@(Model.HourlyTrend.Count > 6 ? Model.HourlyTrend[6].Hour.ToLocalTime().ToString("HH:mm") : "")</text>
            <text x="240" y="135" font-family="JetBrains Mono" font-size="9.5" fill="#9ca3af">@(Model.HourlyTrend.Count > 12 ? Model.HourlyTrend[12].Hour.ToLocalTime().ToString("HH:mm") : "")</text>
            <text x="360" y="135" font-family="JetBrains Mono" font-size="9.5" fill="#9ca3af">@(Model.HourlyTrend.Count > 18 ? Model.HourlyTrend[18].Hour.ToLocalTime().ToString("HH:mm") : "")</text>
            <text x="448" y="135" font-family="JetBrains Mono" font-size="9.5" fill="#9ca3af">şimdi</text>
        </svg>
    </div>

    <div class="mini-chart">
        <div class="head">
            <h3>En Çok Çalıştırılan</h3>
        </div>
        @if (!Model.TopRunReports.Any())
        {
            <div style="font-size:12px; color:var(--ink-4); padding: 16px 0; text-align: center;">
                <i class="fas fa-chart-line opacity-40 text-2xl mb-2 block"></i>
                Son 30 günde çalıştırma yok
            </div>
        }
        else
        {
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
                @for (int i = 0; i < Model.TopRunReports.Count; i++)
                {
                    var item = Model.TopRunReports[i];
                    var pct = (int)Math.Round((double)item.Count / maxRun * 100);
                    <li style="display:flex; align-items:center; gap:10px;">
                        <span class="mono" style="font-size:10.5px; color:var(--ink-4); width:22px;">#@(i + 1)</span>
                        <span style="flex:1; min-width:0; font-size:12.5px; color:var(--ink-1); font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@item.Title</span>
                        <span class="mono" style="font-size:11px; color:var(--ink-3);">@item.Count</span>
                        <div style="width:60px; height:6px; background:var(--line-2); border-radius:3px; overflow:hidden;">
                            <div style="width:@pct%; height:100%; background:var(--accent);"></div>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>

</div>

<div class="section-title">
    <h2>Hızlı Erişim</h2>
    <a href="/Reports" class="more">Tüm raporları gör <i class="fas fa-chevron-right text-[10px]"></i></a>
</div>

@if (!Model.FavoriteReports.Any())
{
    <div style="background:var(--paper); border:1px dashed var(--line); border-radius:10px; padding: 32px; text-align: center; color: var(--ink-3);">
        <i class="fas fa-folder-open text-4xl mb-3 opacity-40"></i>
        <p style="margin:0; font-size:13px;">Henüz erişilebilir rapor yok. Yöneticinizden rol veya rapor erişimi isteyin.</p>
    </div>
}
else
{
    <div class="quick-grid">
        @foreach (var report in Model.FavoriteReports)
        {
            <a href="/Reports/Run?reportId=@report.ReportId" class="qcard">
                <div class="row1">
                    <span class="type-chip @ReportTypeChip(report)">Dashboard</span>
                    <span class="mono" style="font-size:10.5px; color:var(--ink-4); margin-left:auto;">#@report.ReportId</span>
                </div>
                <h3>@report.Title</h3>
                <div class="sub">@(string.IsNullOrWhiteSpace(report.Description) ? (report.DataSource?.Title ?? report.DataSourceKey) : report.Description)</div>
                <div class="meta">
                    <span class="ago">@(report.DataSource?.Title ?? report.DataSourceKey)</span>
                    <span class="run">Aç <i class="fas fa-arrow-right text-[10px]"></i></span>
                </div>
            </a>
        }
    </div>
}

<div class="section-title">
    <h2>Son Aktivite</h2>
    <a href="/Logs" class="more">Tüm log <i class="fas fa-chevron-right text-[10px]"></i></a>
</div>

@if (!Model.RecentLogs.Any())
{
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding: 32px; text-align: center; color: var(--ink-3);">
        <i class="fas fa-history text-4xl mb-3 opacity-40"></i>
        <p style="margin:0; font-size:13px;">Henüz aktivite kaydı yok.</p>
    </div>
}
else
{
    <div class="activity">
        <table class="dt">
            <thead>
                <tr>
                    <th style="width:28%;">Kullanıcı</th>
                    <th>Eylem</th>
                    <th>Hedef</th>
                    <th class="num">Sonuç</th>
                    <th>Durum</th>
                    <th class="num">Zaman</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.RecentLogs)
                {
                    var ev = log.EventType switch
                    {
                        "report_run" => "Çalıştırdı",
                        "report_create" => "Yeni rapor",
                        "report_update" => "Düzenledi",
                        "export" => "Excel export",
                        _ => log.EventType
                    };
                    var statusClass = log.IsSuccess ? "ok" : "err";
                    var statusText = log.IsSuccess ? "başarılı" : "hata";
                    var rowCount = log.ResultRowCount?.ToString("N0", trCulture) ?? "—";
                    <tr>
                        <td>
                            <div class="who">
                                <div class="av">@AvatarInitials(log.Username ?? "")</div>
                                <span>@(log.Username ?? "?")</span>
                            </div>
                        </td>
                        <td>@ev</td>
                        <td>@(string.IsNullOrWhiteSpace(log.Description) ? (log.TargetType ?? "-") : log.Description)</td>
                        <td class="num mono">@rowCount</td>
                        <td><span class="status @statusClass">@statusText</span></td>
                        <td class="num"><span class="ago">@TimeAgo(log.CreatedAt)</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@await Html.PartialAsync("_FooterHint", (string?)null)
