@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Erişim Engellendi - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Erişim Engellendi";
}

<div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:32px; max-width:560px; margin:48px auto 0; text-align:center;">
    <div style="width:56px; height:56px; margin:0 auto 16px; border-radius:50%; background:rgba(220,38,38,0.10); display:flex; align-items:center; justify-content:center;">
        <i class="fas fa-ban" style="font-size:22px; color:var(--accent-ink);"></i>
    </div>
    <h1 style="font-size:18px; font-weight:600; color:var(--ink-1); margin:0 0 8px;">Erişim Engellendi</h1>
    <p style="font-size:13px; color:var(--ink-3); margin:0 0 20px;">
        Bu sayfaya erişim izniniz yok. Yetkiniz varsa yöneticinize bildirin.
    </p>
    <a href="/Dashboard" class="btn primary">
        <i class="fas fa-arrow-left text-[10px]"></i>
        Genel Bakış
    </a>
</div>
