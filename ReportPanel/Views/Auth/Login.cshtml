@model ReportPanel.ViewModels.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Giriş - BKM Rapor Paneli";
}

<div style="margin-bottom:18px;">
    <h2 style="font-size:14px; font-weight:600; color:var(--ink-1); margin:0 0 3px;">Giriş Yap</h2>
    <div style="font-size:12px; color:var(--ink-3);">Hesabınızla devam edin</div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div role="alert" style="margin-bottom:14px; padding:10px 12px; border-radius:8px; font-size:12px;
                background:rgba(220,38,38,0.10); border:1px solid rgba(220,38,38,0.25); color:var(--accent-ink);">
        <i class="fas fa-circle-exclamation" style="margin-right:6px;"></i>
        Giriş bilgileri hatalı.
    </div>
}

@if (ViewData["LoginWarning"] is string warning && !string.IsNullOrWhiteSpace(warning))
{
    <div role="alert" style="margin-bottom:14px; padding:10px 12px; border-radius:8px; font-size:12px;
                background:rgba(245,158,11,0.10); border:1px solid rgba(245,158,11,0.25); color:#92400e;">
        <i class="fas fa-triangle-exclamation" style="margin-right:6px;"></i>
        @warning
    </div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="field">
        <label class="lab" for="Username">Kullanıcı Adı</label>
        <input asp-for="Username" id="Username" required autocomplete="username" class="inp" placeholder="DOMAIN\kullanici veya kullanici" />
        <p style="margin:6px 0 0; font-size:11px; color:var(--ink-3);">AD kullanıcıları DOMAIN\kullanici formatını kullanır.</p>
    </div>

    @* Plan 04 F2.3 (28 Nisan): _PasswordInput partial — DRY (Profile + Login ortak). *@
    @await Html.PartialAsync("_PasswordInput", new ReportPanel.ViewModels.PasswordInputViewModel {
        Id = "Password",
        Name = "Password",
        Label = "Şifre",
        Placeholder = "Şifrenizi girin",
        Autocomplete = "current-password",
        Required = true
    })

    <button type="submit" class="btn primary" style="width:100%; height:38px; margin-top:6px; justify-content:center;">
        <i class="fas fa-right-to-bracket text-[10px]"></i>
        Giriş Yap
    </button>
</form>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('Username');
            if (!input || input.value) {
                return;
            }

            fetch('/Login/WindowsIdentity', { credentials: 'include' })
                .then(function (response) {
                    return response.ok ? response.json() : null;
                })
                .then(function (data) {
                    if (data && data.username) {
                        input.value = data.username;
                    }
                })
                .catch(function () { /* AD probe sessizce baris */ });
        })();
    </script>
}
