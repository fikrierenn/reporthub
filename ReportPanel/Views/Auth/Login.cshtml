@model ReportPanel.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Giriş - BKM Rapor Paneli";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/assets/css/style.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen flex items-center justify-center px-6">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl shadow-2xl overflow-hidden animate-fadeInUp">
                <div class="px-8 pt-8 pb-6 text-center">
                    <div class="mb-4">
                        <div class="w-16 h-16 bg-brand rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="fas fa-book text-2xl text-white"></i>
                        </div>
                        <h1 class="text-2xl font-bold text-brand">BKM Rapor Paneli</h1>
                        <p class="text-gray-600 mt-2">Güvenli rapor erişim sistemi</p>
                    </div>
                </div>

                <div class="px-8 pb-8">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg flex items-center">
                            <i class="fas fa-exclamation-circle text-red-500 mr-3"></i>
                            <span class="text-red-700 text-sm">Giriş bilgileri hatalı.</span>
                        </div>
                    }

                    <form method="post" class="space-y-6">
                        @Html.AntiForgeryToken()

                        <div>
                            <label for="Username" class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fas fa-user mr-2 text-gray-400"></i>
                                Kullanıcı Adı
                            </label>
                            <input asp-for="Username"
                                   id="Username"
                                   required
                                   autocomplete="username"
                                   class="form-input-brand w-full px-4 py-3 rounded-lg"
                                   placeholder="Kullanıcı adınızı girin">
                        </div>

                        <div>
                            <label for="Password" class="block text-sm font-medium text-gray-700 mb-2">
                                <i class="fas fa-lock mr-2 text-gray-400"></i>
                                Şifre
                            </label>
                            <input asp-for="Password"
                                   id="Password"
                                   type="password"
                                   required
                                   autocomplete="current-password"
                                   class="form-input-brand w-full px-4 py-3 rounded-lg"
                                   placeholder="Şifrenizi girin">
                        </div>

                        <button type="submit"
                                class="btn-brand w-full py-3 px-4 rounded-lg font-medium focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
                            <i class="fas fa-sign-in-alt mr-2"></i>
                            Giriş Yap
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>