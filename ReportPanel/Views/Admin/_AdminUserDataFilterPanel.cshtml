@model ReportPanel.ViewModels.AdminUserFormViewModel
@*
    Plan 07 Faz 5 — FilterDefinition-driven dinamik field UI.
    Onceki M-13 R3.2 generic "filter row" UI (FilterKey dropdown + FilterValue dropdown +
    addFilter butonu) bu fazda kalkti — her aktif FilterDefinition icin kalici section
    + "Hepsi" toggle + multi-select.

    Default (Onaylanmis karar 4 Mayis madde 3): yeni user formunda "Hepsi" KAPALI + multi-select
    bos. Admin secim yapmadan kaydederse o key icin DB'de 0 satir → kullanici 403 (deny-by-default).
    Backfill (Migration 20) mevcut user'lara her aktif key icin '*' kaydi ekledi → EditUser'da
    "Hepsi" ON.
*@
@{
    var definitions = Model.FilterDefinitions ?? new List<ReportPanel.Models.FilterDefinition>();
    var sectionsData = definitions.Select(def =>
    {
        var userRecords = Model.DataFilters
            .Where(f => string.Equals(f.FilterKey, def.FilterKey, StringComparison.OrdinalIgnoreCase))
            .ToList();
        var hasStar = userRecords.Any(r => r.FilterValue == ReportPanel.Models.FilterDefinition.ValueAll);
        var concreteValues = userRecords
            .Where(r => r.FilterValue != ReportPanel.Models.FilterDefinition.ValueAll)
            .Select(r => r.FilterValue)
            .ToList();
        return new
        {
            key = def.FilterKey,
            label = def.Label,
            isAll = hasStar,
            selected = concreteValues,
            options = new object[0]
        };
    }).ToList();
    var sectionsJson = System.Text.Json.JsonSerializer.Serialize(sectionsData);
}

<div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; max-width:880px; margin-bottom:18px;">
    <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
        <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
            <i class="fas fa-filter" style="margin-right:6px; color:var(--ink-3);"></i>
            Veri Filtreleri
        </h2>
        <div style="font-size:12px; color:var(--ink-3); margin-top:2px;">
            Her filtre için "Hepsi" işaretli ya da spesifik değerler seçili olmalı. Hiçbiri seçilmezse kullanıcı bu kapsamda rapor çalıştıramaz.
        </div>
    </div>

    <div style="padding:18px 20px;"
         x-data="{
            sections: @Html.Raw(sectionsJson),
            async loadOptions(i) {
                var s = this.sections[i];
                try {
                    var r = await fetch('/Admin/FilterOptions?filterKey=' + encodeURIComponent(s.key));
                    var d = await r.json();
                    s.options = (d.options && d.options.length) ? d.options : [];
                } catch { s.options = []; }
            },
            toggleAll(i) {
                if (this.sections[i].isAll) this.sections[i].selected = [];
            },
            init() { this.sections.forEach((_, i) => this.loadOptions(i)); }
         }"
         x-init="init()">

        <template x-if="sections.length === 0">
            <div style="font-size:12px; color:var(--ink-3);">Aktif filtre tanımı yok. Yönetim Paneli &gt; Filtreler bölümünden ekleyebilirsiniz.</div>
        </template>

        <template x-for="(s, i) in sections" :key="s.key">
            <div style="border:1px solid var(--line); border-radius:8px; padding:12px 14px; margin-bottom:10px;">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px;">
                    <label style="font-size:13px; font-weight:600; color:var(--ink-1);" x-text="s.label"></label>
                    <label style="margin-left:auto; font-size:12px; color:var(--ink-2); display:flex; align-items:center; gap:5px; cursor:pointer;">
                        <input type="checkbox" x-model="s.isAll" @@change="toggleAll(i)">
                        Hepsi
                    </label>
                </div>
                <select multiple x-model="s.selected" :disabled="s.isAll"
                        size="6" class="inp"
                        style="width:100%; min-height:120px;"
                        :style="s.isAll ? 'width:100%; min-height:120px; background:#f5f5f5; opacity:0.5;' : 'width:100%; min-height:120px;'">
                    <template x-for="opt in (s.options || [])" :key="opt.value">
                        <option :value="opt.value" x-text="opt.label"></option>
                    </template>
                </select>
                <div style="font-size:11px; margin-top:4px; min-height:14px;">
                    <span x-show="s.isAll" style="color:var(--ink-3);">"Hepsi" işaretli — kullanıcı tüm değerleri görür.</span>
                    <span x-show="!s.isAll && s.selected.length === 0" style="color:#b91c1c;">
                        Hiçbir değer seçili değil — kullanıcı bu kapsamda rapor çalıştıramaz.
                    </span>
                    <span x-show="!s.isAll && s.selected.length > 0" style="color:var(--ink-3);" x-text="s.selected.length + ' değer seçili'"></span>
                </div>

                @* Backend flat array: FilterKeys[] / FilterValues[] / FilterDataSources[] (paralel index). *@
                <template x-if="s.isAll">
                    <span>
                        <input type="hidden" name="FilterKeys" :value="s.key">
                        <input type="hidden" name="FilterValues" value="*">
                        <input type="hidden" name="FilterDataSources" value="">
                    </span>
                </template>
                <template x-if="!s.isAll">
                    <template x-for="v in s.selected" :key="v">
                        <span>
                            <input type="hidden" name="FilterKeys" :value="s.key">
                            <input type="hidden" name="FilterValues" :value="v">
                            <input type="hidden" name="FilterDataSources" value="">
                        </span>
                    </template>
                </template>
            </div>
        </template>
    </div>
</div>
