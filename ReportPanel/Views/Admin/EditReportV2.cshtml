@model ReportPanel.ViewModels.AdminReportFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = $"V2 Düzenle: {Model.Report.Title} - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Rapor Tasarımı (V2)";
    ViewData["BodyClass"] = "builder-v2-page";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@@10.3.1/dist/gridstack.min.css" crossorigin="anonymous" />
    <script defer src="https://cdn.jsdelivr.net/npm/gridstack@@10.3.1/dist/gridstack-all.js" crossorigin="anonymous"></script>
    @* F-09: Chart.js — V2 builder canvas chart widget'ları gerçek render (designer ↔ Run görsel parite) *@
    <script defer src="https://cdn.jsdelivr.net/npm/chart.js@@4.4.0/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="~/assets/css/builder-v2.css" asp-append-version="true" />
}

@section Breadcrumb {
    <div class="crumbs">
        <a href="/Dashboard">BKM Kitap</a>
        <span class="sep">/</span>
        <a href="/Admin">Yönetim</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=reports">Raporlar</a>
        <span class="sep">/</span>
        <span class="current">@Model.Report.Title</span>
        <span class="sp-chip mono">@Model.Report.ProcName</span>
    </div>
}

@section TopActions {
    @await Html.PartialAsync("_ReportFormBuilderTopActionsV2", "reportEditFormV2")
}

<script>
window.__reportMeta = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
    reportId = Model.Report.ReportId,
    title = Model.Report.Title,
    dataSourceKey = Model.Report.DataSourceKey,
    procName = Model.Report.ProcName,
    isActive = Model.Report.IsActive,
    description = Model.Report.Description ?? string.Empty,
    paramSchemaJson = Model.Report.ParamSchemaJson ?? string.Empty,
    availableRoles = (Model.AvailableRoles ?? new()).Select(r => new { id = r.RoleId, name = r.Name }),
    selectedRoleIds = Model.SelectedRoleIds ?? new HashSet<int>(),
    availableGroups = (Model.AvailableGroups ?? new()).Select(c => new { id = c.GroupId, name = c.Name }),
    selectedGroupIds = Model.SelectedGroupIds ?? new HashSet<int>()
}));
window.__availableDataSources = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (Model.DataSources ?? new()).Where(d => d.IsActive).Select(d => new { key = d.DataSourceKey, title = d.Title })));
</script>

<form method="post" action="/Admin/EditReport/@Model.Report.ReportId" id="reportEditFormV2"
      x-data="{}" x-on:input="$store.builder.dirty = true">
    @Html.AntiForgeryToken()
    <input type="hidden" name="ReportId" value="@Model.Report.ReportId" />
    @* Description, IsActive, Roles, Groups → Alpine reactive hidden input'lar builder-v2 div'inde *@
    <textarea name="DashboardConfigJson" id="DashboardConfigJson" style="display:none;">@Model.Report.DashboardConfigJson</textarea>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var isError = Model.MessageType == "error";
    <div role="alert" style="margin:12px 24px; padding:12px 16px; border-radius:10px; font-size:13px;
                white-space:pre-line;
                background: @(isError ? "rgba(220,38,38,0.10)" : "rgba(16,185,129,0.10)");
                border: 1px solid @(isError ? "rgba(220,38,38,0.25)" : "rgba(16,185,129,0.25)");
                color: @(isError ? "var(--accent-ink)" : "#065f46");">
        <i class="fas @(isError ? "fa-circle-exclamation" : "fa-circle-check")" style="margin-right:8px;"></i>@Model.Message
    </div>
}

@* ============ BUILDER 3-PANE — Alpine x-data ============ *@
<div class="builder-v2" x-data="builderV2" x-cloak
     x-on:builder-preview-open.window="openPreview()">
    @* F-9: validation banner + toast — builder root scope'unda render *@
    @await Html.PartialAsync("_ReportFormBuilderFeedbackV2")
    @* F-10: kbd shortcuts help modal (template picker EditReport'ta yok — sadece CreateReport için) *@
    @await Html.PartialAsync("_ReportFormBuilderShortcutsV2")
    @* Alpine reactive hidden input'lar — form="reportEditFormV2" ile dış form'a bağlı *@
    <input type="hidden" name="Title" form="reportEditFormV2" :value="title" />
    <input type="hidden" name="DataSourceKey" form="reportEditFormV2" :value="dataSourceKey" />
    <input type="hidden" name="ProcName" form="reportEditFormV2" :value="procName" />
    <input type="hidden" name="ParamSchemaJson" form="reportEditFormV2" :value="paramSchemaJson" />
    <input type="hidden" name="Description" form="reportEditFormV2" :value="description" />
    <input type="hidden" name="IsActive" form="reportEditFormV2" :value="isActive ? 'true' : 'false'" />
    <template x-for="rid in selectedRoleIds" :key="rid">
        <input type="hidden" name="SelectedRoles" form="reportEditFormV2" :value="rid" />
    </template>
    <template x-for="gid in selectedGroupIds" :key="gid">
        <input type="hidden" name="SelectedGroups" form="reportEditFormV2" :value="gid" />
    </template>

    @* SOL: PALETTE *@
    @* palette aside kaldırıldı (Plan 04 redesign) — bileşen ekle artık canvas-toolbar'da, veri setleri chip + modal *@

    @* ORTA: CANVAS *@
    <main class="canvas"
          @@dragover="onCanvasDragOver($event)"
          @@dragleave="onCanvasDragLeave($event)"
          @@drop="onCanvasDrop($event)">
        @* Multi-tab strip — birden fazla sayfa (DashboardConfig.tabs) *@
        <div class="tab-strip">
            <template x-for="(tab, i) in (config.tabs || [])" :key="i">
                <div class="tab-chip" :class="i === activeTab && 'active'" @@click="switchTab(i)"
                     @@dblclick="(() => { var t = prompt('Sekme adı:', tab.title || ''); if (t !== null) setTabTitle(i, t); })()"
                     :title="'Tıkla: geç · Çift-tıkla: ad değiştir'">
                    <span x-text="tab.title || ('Sekme ' + (i+1))"></span>
                    <button type="button" class="tab-close" x-show="config.tabs.length > 1"
                            @@click.stop="removeTab(i)" title="Sekmeyi sil">×</button>
                </div>
            </template>
            <button type="button" class="tab-add" @@click="addTab()" title="Yeni sekme ekle">
                <i class="fas fa-plus text-[10px]"></i> Yeni Sekme
            </button>
        </div>

        @* Canvas toolbar — bileşen ekle butonları + Veri Setleri chip (palette yerine) *@
        <div class="canvas-toolbar">
            <div class="cv-add-group">
                <button type="button" class="cv-add-btn" draggable="true"
                        @@dragstart="onPaletteDragStart($event, 'kpi')"
                        @@click="addWidget('kpi')" title="KPI ekle (sürükle veya tıkla)">
                    <i class="fas fa-chart-line"></i> <span>KPI</span>
                </button>
                <button type="button" class="cv-add-btn" draggable="true"
                        @@dragstart="onPaletteDragStart($event, 'chart')"
                        @@click="addWidget('chart')" title="Grafik ekle">
                    <i class="fas fa-chart-column"></i> <span>Grafik</span>
                </button>
                <button type="button" class="cv-add-btn" draggable="true"
                        @@dragstart="onPaletteDragStart($event, 'table')"
                        @@click="addWidget('table')" title="Tablo ekle">
                    <i class="fas fa-table"></i> <span>Tablo</span>
                </button>
            </div>
            <button type="button" class="cv-rs-chip" @@click="openDataModal(0, null)"
                    x-show="resultSets().length > 0" x-cloak
                    :title="resultSets().length + ' veri seti — tıkla satırları gör'">
                <i class="fas fa-database text-[10px]"></i>
                <span x-text="resultSets().length + ' set'"></span>
                <span class="dot">·</span>
                <span x-text="resultSets().reduce((a, rs) => a + (rs.rowCount || (rs.rows||[]).length), 0) + ' satır'"></span>
            </button>
            <span class="cv-rs-chip muted" x-show="resultSets().length === 0" x-cloak>
                <i class="fas fa-circle-notch fa-spin text-[10px]"></i>
                Veri yükleniyor…
            </span>
        </div>

        <div class="param-bar">
            <span class="lbl">Parametreler</span>

            @* Hiç param yoksa minik bir not *@
            <template x-if="paramFields().length === 0">
                <span style="font-size:11px; color:var(--ink-4);">Bu raporda parametre tanımı yok</span>
            </template>

            @* Her ParamSchema field için bir chip — tıklanır, inline edit *@
            <template x-for="f in paramFields()" :key="f.name">
                <span class="param-chip" :class="paramEditing === f.name && 'editing'">
                    <i class="fas" :class="(f.type === 'date' ? 'fa-calendar' : f.type === 'number' || f.type === 'decimal' ? 'fa-hashtag' : f.type === 'checkbox' ? 'fa-check' : 'fa-tag')"></i>
                    <span x-text="(f.label || f.name) + ':'"></span>

                    @* Görüntüleme modu (chip'in normal hali) *@
                    <span class="v" x-show="paramEditing !== f.name"
                          @@click="toggleParamEdit(f.name)"
                          x-text="paramDisplayValue(f)"
                          style="cursor:pointer; text-decoration:underline dotted;"
                          title="Düzenlemek için tıkla"></span>

                    @* Inline edit modu — type'a göre input *@
                    <input x-show="paramEditing === f.name" x-cloak
                           :type="f.type === 'date' ? 'date' : f.type === 'number' || f.type === 'decimal' ? 'number' : 'text'"
                           :value="paramValue(f)"
                           @@input="setParamOverride(f.name, $event.target.value)"
                           @@keydown.enter="paramEditing = null; runWithCurrentParams()"
                           @@keydown.escape="paramEditing = null"
                           @@blur="paramEditing = null"
                           x-init="$nextTick(() => $el.focus())"
                           style="width:130px; height:22px; border:1px solid var(--accent); border-radius:4px; padding:0 6px; font-size:11px; font-family:'JetBrains Mono',monospace;" />
                </span>
            </template>

            @* Override varsa Sıfırla linki *@
            <button type="button" x-show="paramDirty || (paramOverrides && Object.keys(paramOverrides).length > 0)"
                    @@click="resetParams()"
                    style="background:transparent; border:none; color:var(--ink-3); font-size:10px; cursor:pointer; text-transform:uppercase; letter-spacing:.04em;"
                    title="Default'a dön">
                <i class="fas fa-rotate-left text-[9px]"></i>
                Sıfırla
            </button>

            <button type="button" class="btn run-btn"
                    :class="paramDirty && 'primary'"
                    @@click="runWithCurrentParams()">
                <i class="fas fa-play text-[10px]"></i>
                <span x-text="paramDirty ? 'Çalıştır (değişti)' : 'Çalıştır'"></span>
            </button>
        </div>
        @* Empty state — bu sekmede henüz widget yok, kullanıcıya 3 büyük CTA *@
        <div class="empty-canvas" x-show="components.length === 0" x-cloak>
            <div class="ec-icon"><i class="fas fa-chart-pie"></i></div>
            <div class="ec-title">Bu sekmede henüz bileşen yok</div>
            <div class="ec-sub">Aşağıdan birini seçerek başlayın · sonra sağ panelden veri bağlayın</div>
            <div class="ec-cta-row">
                <button type="button" class="ec-cta" @@click="addWidget('kpi')">
                    <span class="ec-ico kpi"><i class="fas fa-chart-line"></i></span>
                    <span class="ec-lbl">KPI</span>
                    <span class="ec-desc">Tek sayı + delta</span>
                </button>
                <button type="button" class="ec-cta" @@click="addWidget('chart')">
                    <span class="ec-ico chart"><i class="fas fa-chart-column"></i></span>
                    <span class="ec-lbl">Grafik</span>
                    <span class="ec-desc">Bar, line, area, donut</span>
                </button>
                <button type="button" class="ec-cta" @@click="addWidget('table')">
                    <span class="ec-ico table"><i class="fas fa-table"></i></span>
                    <span class="ec-lbl">Tablo</span>
                    <span class="ec-desc">Result set satırları</span>
                </button>
            </div>
        </div>
        <div class="grid-stack" x-show="components.length > 0"></div>
    </main>

    @* SAĞ: PROPERTIES PANEL — Plan 04 redesign: context-aware, 2-tab (Setup/Stil) *@
    <aside class="drawer">
        @* Tab strip sadece widget seçili iken görünür *@
        <template x-if="selected">
            <div class="drawer-tabs">
                <button type="button" :class="drawerTab === 'setup' && 'active'" @@click="drawerTab = 'setup'">
                    <i class="fas fa-database text-[10px]"></i>
                    Setup
                </button>
                <button type="button" :class="drawerTab === 'style' && 'active'" @@click="drawerTab = 'style'">
                    <i class="fas fa-palette text-[10px]"></i>
                    Stil
                </button>
            </div>
        </template>

        <div class="drawer-content">

            @* ===== SETUP tab — veri bağlama (eski "Veri" tab) ===== *@
            <div x-show="selected && drawerTab === 'setup'" x-cloak>
                @* Bağlı kolon banner (seçili widget varsa) *@
                <template x-if="selected && selected.column">
                    <div class="selected-bound">
                        <span class="lbl">Bağlı</span>
                        <span class="val" x-text="(selected.result || 'rs0') + ' · ' + selected.column"></span>
                        <button type="button" class="clear" @@click="unbindColumn()" title="Bağı kaldır">
                            <i class="fas fa-xmark text-[11px]"></i>
                        </button>
                    </div>
                </template>

                @* Hızlı Bağla — Plan 04: cascading dropdown (Veri Seti → Kolon → Hesap) *@
                <div class="quick-bind">
                    <div class="qb-header">
                        <i class="fas fa-bolt text-[10px]"></i> Hızlı Bağla
                    </div>
                    <div class="field">
                        <label class="lab">Başlık</label>
                        <input type="text" class="inp"
                               :value="selected ? (selected.title || '') : ''"
                               @@input="setField('title', $event.target.value)"
                               placeholder="Örn: Toplam Kadro" />
                    </div>
                    <div class="field">
                        <label class="lab" style="display:flex; align-items:center; justify-content:space-between;">
                            <span>Veri Seti</span>
                            <button type="button" x-show="selected && selected.result"
                                    @@click="toggleRsPanel()"
                                    style="background:transparent; border:none; color:var(--accent-ink); font-size:10px; cursor:pointer; text-transform:none; letter-spacing:0; display:inline-flex; align-items:center; gap:4px;"
                                    :title="rsPanelOpen ? 'Önizleme panelini gizle' : 'Bağlı veri setinin ilk satırlarını göster'">
                                <i class="fas" :class="rsPanelOpen ? 'fa-eye-slash' : 'fa-eye'" style="font-size:9px;"></i>
                                <span x-text="rsPanelOpen ? 'Gizle' : 'Önizle'"></span>
                            </button>
                        </label>
                        <select class="inp"
                                :value="selected ? (selected.result || '') : ''"
                                @@change="setBoundResult($event.target.value)">
                            <option value="">— seç —</option>
                            <template x-for="(rs, i) in resultSets()" :key="i">
                                <option :value="'rs' + i"
                                        :selected="selected && selected.result === 'rs' + i"
                                        x-text="resultSetTitle(rs, i) + ' — ' + (rs.rows || []).length + ' satır'"></option>
                            </template>
                        </select>

                        @* Inline RS preview — Önizle toggle, max 10 satır × tüm kolonlar, kompakt scroll *@
                        <div x-show="rsPanelOpen && selected && selected.result" x-cloak
                             style="margin-top:8px; border:1px solid var(--line); border-radius:6px; background:#fafafa; max-height:240px; overflow:auto;">
                            <div style="position:sticky; top:0; padding:6px 8px; background:#f1f5f9; border-bottom:1px solid var(--line); font-size:10px; color:var(--ink-3); display:flex; justify-content:space-between; z-index:1;">
                                <span x-text="rsPanelColumns().length + ' kolon · ' + rsPanelTotalRows() + ' toplam satır'"></span>
                                <span x-show="rsPanelTotalRows() > 10" class="text-amber-600">ilk 10</span>
                            </div>
                            <table style="width:100%; font-size:10px; border-collapse:collapse;">
                                <thead>
                                    <tr>
                                        <template x-for="col in rsPanelColumns()" :key="col">
                                            <th style="white-space:nowrap; padding:3px 6px; background:#f8fafc; border-bottom:1px solid var(--line); text-align:left; font-weight:600; position:sticky; top:24px; font-size:10px;"
                                                x-text="col"></th>
                                        </template>
                                    </tr>
                                </thead>
                                <tbody>
                                    <template x-for="(row, ri) in rsPanelRows()" :key="ri">
                                        <tr style="border-bottom:1px solid var(--line-2);">
                                            <template x-for="col in rsPanelColumns()" :key="col">
                                                <td style="padding:2px 6px; white-space:nowrap;"
                                                    :style="rsPanelCellAlign(row, col) === 'right' ? 'text-align:right; font-variant-numeric:tabular-nums;' : ''"
                                                    x-text="rsPanelCellValue(row, col)"></td>
                                            </template>
                                        </tr>
                                    </template>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    @* KPI'a özgü kolon seçimi — chart kendi X/Y bloğunu kullanır, tablo kolon listesi *@
                    <div class="field" x-show="selected && selected.result && selected.type === 'kpi'">
                        <label class="lab">Kolon</label>
                        <select class="inp"
                                :value="selected ? (selected.column || '') : ''"
                                @@change="setBoundColumn($event.target.value)">
                            <option value="">— seç —</option>
                            <template x-for="col in selectedRsColumns()" :key="col">
                                <option :value="col"
                                        :selected="selected && selected.column === col"
                                        x-text="col + ' · ' + columnKindFor(col) + (columnSampleFor(col) ? ' · ' + columnSampleFor(col) : '')"></option>
                            </template>
                        </select>
                    </div>
                    <div class="field" x-show="selected && selected.column && selected.type === 'kpi'">
                        <label class="lab">Hesap</label>
                        <select class="inp"
                                :value="selected ? (selected.agg || 'first') : 'first'"
                                @@change="setField('agg', $event.target.value)">
                            <option value="first">İlk Değer</option>
                            <option value="sum">Toplam (SUM)</option>
                            <option value="avg">Ortalama (AVG)</option>
                            <option value="count">Adet (COUNT)</option>
                            <option value="min">Min</option>
                            <option value="max">Max</option>
                        </select>
                    </div>

                    @* F09 Faz 3 — KPI variant'a göre koşullu form alanları *@
                    <template x-if="selected && selected.type === 'kpi' && selected.result">
                        <div>
                            @* Capacity warning *@
                            <template x-if="kpiCapacityWarning()">
                                <div style="background:#fef3c7; border:1px solid #fde68a; color:#92400e; padding:8px 10px; border-radius:6px; font-size:11px; margin-bottom:10px;">
                                    <i class="fas fa-triangle-exclamation text-[10px]"></i>
                                    <span x-text="kpiCapacityWarning()"></span>
                                </div>
                            </template>

                            @* DELTA: karşılaştırma kolonu + etiket *@
                            <template x-if="(selected.variant || 'basic') === 'delta'">
                                <div>
                                    <div class="field">
                                        <label class="lab">Karşılaştırma Kolonu</label>
                                        <select class="inp"
                                                :value="selected.delta && selected.delta.compareColumn || ''"
                                                @@change="setDeltaField('compareColumn', $event.target.value)">
                                            <option value="">— seç —</option>
                                            <template x-for="col in kpiNumberColumns()" :key="col">
                                                <option :value="col" x-text="col"></option>
                                            </template>
                                        </select>
                                        <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">Değişim yüzdesi bu kolona göre hesaplanır.</p>
                                    </div>
                                    <div class="field">
                                        <label class="lab">Karşılaştırma Etiketi</label>
                                        <input type="text" class="inp"
                                               :value="(selected.delta && selected.delta.compareLabel) || ''"
                                               @@input="setDeltaField('compareLabel', $event.target.value)"
                                               placeholder="örn: vs önceki ay" />
                                    </div>
                                </div>
                            </template>

                            @* SPARKLINE: trend değer kolonu (mini grafik beslemesi) *@
                            <template x-if="(selected.variant || 'basic') === 'sparkline'">
                                <div>
                                    <div class="field">
                                        <label class="lab">Trend Değer Kolonu</label>
                                        <select class="inp"
                                                :value="(selected.trend && selected.trend.valueColumn) || ''"
                                                @@change="setTrendField('valueColumn', $event.target.value)">
                                            <option value="">— seç —</option>
                                            <template x-for="col in kpiNumberColumns()" :key="col">
                                                <option :value="col" x-text="col"></option>
                                            </template>
                                        </select>
                                        <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">Mini grafik bu kolonun satır-satır değerlerini çizer.</p>
                                    </div>
                                </div>
                            </template>

                            @* PROGRESS: hedef tipi (Sabit/Kolon) + value | column *@
                            <template x-if="(selected.variant || 'basic') === 'progress'">
                                <div>
                                    <div class="field">
                                        <label class="lab">Hedef Tipi</label>
                                        <div class="seg-full">
                                            <button type="button" :class="progressTargetMode() === 'value' && 'on'" @@click="switchProgressTargetMode('value')">Sabit Değer</button>
                                            <button type="button" :class="progressTargetMode() === 'column' && 'on'" @@click="switchProgressTargetMode('column')">Kolon</button>
                                        </div>
                                    </div>
                                    <template x-if="progressTargetMode() === 'value'">
                                        <div class="field">
                                            <label class="lab">Hedef Değer</label>
                                            <input type="number" class="inp"
                                                   :value="(selected.progress && selected.progress.targetValue != null) ? selected.progress.targetValue : ''"
                                                   @@input="setProgressField('targetValue', $event.target.value)"
                                                   placeholder="örn: 100" />
                                            <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">İlerleme yüzdesi (Değer / Hedef × 100) ile hesaplanır.</p>
                                        </div>
                                    </template>
                                    <template x-if="progressTargetMode() === 'column'">
                                        <div class="field">
                                            <label class="lab">Hedef Kolonu</label>
                                            <select class="inp"
                                                    :value="(selected.progress && selected.progress.targetColumn) || ''"
                                                    @@change="setProgressField('targetColumn', $event.target.value)">
                                                <option value="">— seç —</option>
                                                <template x-for="col in kpiNumberColumns()" :key="col">
                                                    <option :value="col" x-text="col"></option>
                                                </template>
                                            </select>
                                            <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">Hedef ilk satırın bu kolonu olarak alınır.</p>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>
                </div>

                @* M-11 chart binding: variant'a göre otomatik X/Y doldurur, manuel override edilebilir *@
                <template x-if="selected && selected.type === 'chart' && selected.result">
                    <div class="col-picker-block">
                        <div class="qb-header" style="margin-top:14px;">
                            <i class="fas fa-chart-column text-[10px]"></i> Eksen Bağlantıları
                        </div>

                        @* Capacity uyarısı — yetersiz kolon *@
                        <template x-if="chartCapacityWarning()">
                            <div style="background:#fef3c7; border:1px solid #fde68a; color:#92400e; padding:8px 10px; border-radius:6px; font-size:11px; margin-bottom:10px;">
                                <i class="fas fa-triangle-exclamation text-[10px]"></i>
                                <span x-text="chartCapacityWarning()"></span>
                            </div>
                        </template>

                        @* X ekseni — labelColumn (scatter dışındaki tipler) *@
                        <div class="field" x-show="chartFieldRequirements(selected.variant || 'bar').needsLabel">
                            <label class="lab">X Ekseni (Kategori)</label>
                            <select class="inp"
                                    :value="selected.labelColumn || ''"
                                    @@change="setChartLabelColumn($event.target.value)">
                                <option value="">— seç —</option>
                                <template x-for="col in chartLabelCandidates()" :key="col">
                                    <option :value="col"
                                            :selected="selected.labelColumn === col"
                                            x-text="col + ' · ' + columnKindFor(col)"></option>
                                </template>
                            </select>
                            <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">Tarih veya metin kolonu — kategorileri ayırır.</p>
                        </div>

                        @* Y serileri — datasets[] *@
                        <div class="field">
                            <label class="lab" style="display:flex; align-items:center; justify-content:space-between;">
                                <span>Y Ekseni (Seriler)</span>
                                <button type="button" class="btn ghost" style="height:24px; font-size:10px; padding:0 8px;"
                                        x-show="canAddChartDataset()"
                                        @@click="addChartDataset()" title="Yeni veri serisi ekle">
                                    <i class="fas fa-plus text-[9px]"></i> Seri Ekle
                                </button>
                            </label>
                            <template x-if="!selected.datasets || selected.datasets.length === 0">
                                <p style="font-size:11px; color:var(--ink-4); padding:6px 0;">Henüz seri yok — variant değiştirince otomatik dolar veya "Seri Ekle" ile manuel ekleyin.</p>
                            </template>
                            <template x-for="(ds, di) in (selected.datasets || [])" :key="di">
                                <div style="display:flex; gap:6px; align-items:center; margin-bottom:6px; padding:6px; background:var(--paper); border:1px solid var(--line); border-radius:6px;">
                                    <select class="inp" style="flex:2; font-size:11px; height:28px;"
                                            :value="ds.column || ''"
                                            @@change="setChartDatasetField(di, 'column', $event.target.value); setChartDatasetField(di, 'label', $event.target.value)">
                                        <option value="">— kolon —</option>
                                        <template x-for="col in chartColumnsByKind()['sayı']" :key="col">
                                            <option :value="col" :selected="ds.column === col" x-text="col"></option>
                                        </template>
                                    </select>
                                    <input type="text" class="inp" style="flex:2; font-size:11px; height:28px;"
                                           :value="ds.label || ''"
                                           @@input="setChartDatasetField(di, 'label', $event.target.value)"
                                           placeholder="Etiket" />
                                    <select class="inp" style="flex:1; font-size:11px; height:28px;"
                                            :value="ds.color || 'blue'"
                                            @@change="setChartDatasetField(di, 'color', $event.target.value)"
                                            title="Seri rengi">
                                        <template x-for="c in ['blue','green','amber','violet','rose','slate','red']" :key="c">
                                            <option :value="c" :selected="ds.color === c" x-text="c"></option>
                                        </template>
                                    </select>
                                    <button type="button"
                                            style="background:transparent; border:none; color:var(--ink-3); cursor:pointer; padding:4px; height:28px;"
                                            @@click="removeChartDataset(di)" title="Bu seriyi kaldır">
                                        <i class="fas fa-xmark text-[10px]"></i>
                                    </button>
                                </div>
                            </template>
                            <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">
                                <i class="fas fa-wand-magic-sparkles text-[9px]"></i>
                                Grafik tipini seçince varsayılan kolonlar otomatik atanır.
                            </p>
                        </div>
                    </div>
                </template>

                @* Plan 05.A: Tablo widget — kolon checkbox + drag-drop sıralama + hizalama *@
                <template x-if="selected && selected.type === 'table'">
                    <div class="col-picker-block">
                        <div class="qb-header" style="margin-top:14px;">
                            <i class="fas fa-table-cells text-[10px]"></i> Kolonlar
                        </div>
                        <template x-if="!selected.result">
                            <p style="font-size:11px; color:var(--ink-4); padding:8px 0;">Önce yukarıdan Veri Seti seçin.</p>
                        </template>
                        <template x-if="selected.result">
                            <div class="col-picker">
                                <template x-for="col in tableDisplayedColumns()" :key="col">
                                    <div class="col-row"
                                         :class="isTableColumnSelected(col) && 'selected'"
                                         :draggable="isTableColumnSelected(col) ? 'true' : 'false'"
                                         x-on:dragstart="onColDragStart(col, $event)"
                                         x-on:dragover="onColDragOver($event)"
                                         x-on:drop="onColDrop(col, $event)">
                                        <i class="fas fa-grip-vertical drag-handle" :style="!isTableColumnSelected(col) && 'visibility:hidden;'"></i>
                                        <input type="checkbox"
                                               :checked="isTableColumnSelected(col)"
                                               x-on:change="toggleTableColumn(col)" />
                                        <span class="col-name" x-text="col"></span>
                                        <span class="col-kind" x-text="columnKindFor(col)"></span>
                                        <button type="button" x-show="isComputedColumn(col)"
                                                style="background:transparent; border:none; color:var(--accent-ink); cursor:pointer; padding:2px 4px;" title="Formül düzenle"
                                                x-on:click="editCalcColumn(col)">
                                            <i class="fas fa-pen text-[10px]"></i>
                                        </button>
                                        <div class="align-toggle" x-show="isTableColumnSelected(col)">
                                            <button type="button" :class="getTableColumnAlign(col) === 'left' && 'on'"
                                                    x-on:click="setTableColumnAlign(col, 'left')" title="Sola hizala">
                                                <i class="fas fa-align-left text-[10px]"></i>
                                            </button>
                                            <button type="button" :class="getTableColumnAlign(col) === 'center' && 'on'"
                                                    x-on:click="setTableColumnAlign(col, 'center')" title="Ortaya hizala">
                                                <i class="fas fa-align-center text-[10px]"></i>
                                            </button>
                                            <button type="button" :class="getTableColumnAlign(col) === 'right' && 'on'"
                                                    x-on:click="setTableColumnAlign(col, 'right')" title="Sağa hizala">
                                                <i class="fas fa-align-right text-[10px]"></i>
                                            </button>
                                        </div>
                                    </div>
                                </template>
                                <p x-show="(tableDisplayedColumns() || []).length === 0" style="font-size:11px; color:var(--ink-4); padding:8px 0;">
                                    Bu veri setinde kolon bulunmuyor.
                                </p>
                            </div>
                        </template>

                        @* Plan 05.B: hesaplı kolon ekleme inline form *@
                        <template x-if="selected.result">
                            <div class="calc-col-section">
                                <button type="button" class="calc-col-add-btn"
                                        x-show="!calcColForm.open"
                                        x-on:click="openCalcColForm()">
                                    <i class="fas fa-plus text-[10px]"></i> Yeni Hesaplı Kolon
                                </button>
                                <div x-show="calcColForm.open" x-cloak class="calc-col-form">
                                    <div class="field">
                                        <label class="lab">Kolon Adı (alias)</label>
                                        <input type="text" class="inp"
                                               x-model="calcColForm.alias"
                                               :readonly="!!calcColForm.editingKey"
                                               :style="calcColForm.editingKey ? 'opacity:0.6; cursor:not-allowed;' : ''"
                                               placeholder="örn: marj, kategoriEtiket"
                                               maxlength="40" />
                                    </div>
                                    <div class="field">
                                        <label class="lab">Formül</label>
                                        <textarea class="inp" rows="3" style="font-family:'JetBrains Mono',monospace; font-size:11.5px; line-height:1.4;"
                                                  x-model="calcColForm.formula"
                                                  x-on:blur="validateFormulaLive()"
                                                  placeholder="örn: IIF(satis &gt; 100, 'Yüksek', 'Düşük')"></textarea>
                                        <div x-show="calcColForm.error" x-cloak class="form-error">
                                            <i class="fas fa-circle-exclamation text-[10px]"></i>
                                            <span x-text="calcColForm.error"></span>
                                            <span x-show="calcColForm.errorPos" x-text="' (poz ' + calcColForm.errorPos + ')'"></span>
                                        </div>
                                        <div x-show="availableColumnsForFormula.length > 0" x-cloak class="calc-col-suggest">
                                            <span class="calc-col-suggest-label">Mevcut kolonlar (tıkla → formüle ekle):</span>
                                            <div class="calc-col-suggest-pills">
                                                <template x-for="col in availableColumnsForFormula" :key="col">
                                                    <button type="button" class="calc-col-suggest-pill"
                                                            x-text="col"
                                                            x-on:click="insertColumnIntoFormula(col)"></button>
                                                </template>
                                            </div>
                                        </div>
                                        <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">
                                            Aritmetik (+ − × ÷), karşılaştırma (= != &lt; &gt; &lt;= &gt;=), AND/OR/NOT, IF/IIF, CASE WHEN/THEN/ELSE/END. Türkçe kolon adı: <code>[Şube]</code>.
                                        </p>
                                    </div>
                                    <div class="field">
                                        <label class="lab">Format</label>
                                        <select class="inp" x-model="calcColForm.format">
                                            <option value="auto">Otomatik</option>
                                            <option value="number">Sayı</option>
                                            <option value="currency">Para</option>
                                            <option value="percent">Yüzde</option>
                                            <option value="decimal2">2 Ondalık</option>
                                        </select>
                                    </div>
                                    <div class="calc-col-form-actions">
                                        <button type="button" class="btn btn-soft" x-on:click="cancelCalcColForm()">İptal</button>
                                        <button type="button" class="btn"
                                                :disabled="calcColForm.busy"
                                                x-on:click="addCalcColumn()">
                                            <span x-show="!calcColForm.busy" x-text="calcColForm.editingKey ? 'Güncelle' : 'Kaydet'"></span>
                                            <span x-show="calcColForm.busy" x-cloak><i class="fas fa-spinner fa-spin text-[10px]"></i> Doğrulanıyor</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </template>
                    </div>
                </template>

                @* İleri ayar — minimal: alt yazı + 2-kolon formül (KPI), genişlik (Stil tab'da) *@
                <template x-if="selected">
                    <div>
                        <button type="button" class="advanced-toggle" :class="showAdvanced && 'open'" @@click="showAdvanced = !showAdvanced">
                            <i class="fas fa-chevron-right text-[9px]"></i>
                            İleri ayar (formül, alt yazı)
                        </button>
                        <div x-show="showAdvanced" x-cloak style="border-top:1px solid var(--line-2); padding-top:10px; margin-top:8px;">
                            <template x-if="selected.type === 'kpi'">
                                <div>
                                    <div class="field">
                                        <label class="lab">Alt Yazı</label>
                                        <input type="text" class="inp" :value="selected.subtitle || ''" @@input="setField('subtitle', $event.target.value)" placeholder="Örn: bugün toplam" />
                                    </div>

                                    @* 2-kolon formül — A (op) B → KPI *@
                                    <div class="section-hd" style="margin-top:14px;">
                                        Formül (2-kolon)
                                        <span style="font-weight:400; text-transform:none; letter-spacing:0; font-size:10px; color:var(--ink-4); margin-left:6px;">opsiyonel — fark / yüzde / oran</span>
                                    </div>
                                    <div class="field">
                                        <label class="lab">Kolon A</label>
                                        <select class="inp" :value="selected.formulaA || ''" @@change="setField('formulaA', $event.target.value || null)">
                                            <option value="">— yok —</option>
                                            <template x-for="col in selectedRsColumns()" :key="col">
                                                <option :value="col" x-text="col"></option>
                                            </template>
                                        </select>
                                    </div>
                                    <template x-if="selected.formulaA">
                                        <div>
                                            <div class="field">
                                                <label class="lab">İşlem</label>
                                                <div class="seg-full">
                                                    <button type="button" :class="selected.formulaOp === '+' && 'on'" @@click="setField('formulaOp', '+')">A + B</button>
                                                    <button type="button" :class="selected.formulaOp === '-' && 'on'" @@click="setField('formulaOp', '-')">A − B</button>
                                                    <button type="button" :class="selected.formulaOp === '*' && 'on'" @@click="setField('formulaOp', '*')">A × B</button>
                                                    <button type="button" :class="selected.formulaOp === '/' && 'on'" @@click="setField('formulaOp', '/')">A ÷ B</button>
                                                    <button type="button" :class="selected.formulaOp === '%' && 'on'" @@click="setField('formulaOp', '%')" title="Yüzde: 100 × A / B">% (A/B)</button>
                                                </div>
                                            </div>
                                            <div class="field">
                                                <label class="lab">Kolon B</label>
                                                <select class="inp" :value="selected.formulaB || ''" @@change="setField('formulaB', $event.target.value || null)">
                                                    <option value="">— yok —</option>
                                                    <template x-for="col in selectedRsColumns()" :key="col">
                                                        <option :value="col" x-text="col"></option>
                                                    </template>
                                                </select>
                                            </div>
                                            <button type="button" x-show="selected.formulaA || selected.formulaB || selected.formulaOp"
                                                    @@click="setField('formulaA', null); setField('formulaB', null); setField('formulaOp', null)"
                                                    style="background:transparent; border:none; color:var(--ink-3); font-size:10px; cursor:pointer; text-transform:uppercase; letter-spacing:.04em;">
                                                <i class="fas fa-rotate-left text-[9px]"></i> Formülü temizle
                                            </button>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </div>
                </template>
            </div>

            @* ===== STİL tab — renk swatch + icon grid (eski "Görünüm" tab) ===== *@
            <div x-show="selected && drawerTab === 'style'" x-cloak>
                <template x-if="!selected">
                    <div style="text-align:center; padding:40px 20px; color:var(--ink-4);">
                        <i class="fas fa-arrow-pointer" style="font-size:24px; opacity:.4;"></i>
                        <p style="margin-top:10px; font-size:12px;">Bir widget seçin.</p>
                    </div>
                </template>
                <template x-if="selected">
                    <div>
                        <div class="selected-banner">
                            <span class="ico"><i class="fas fa-palette"></i></span>
                            <span class="name" x-text="selected.title || typeLabel(selected.type)"></span>
                        </div>

                        @* KPI variant picker — 4 kart *@
                        <template x-if="selected.type === 'kpi'">
                            <div class="field">
                                <label class="lab">KPI Tipi</label>
                                <div class="variant-grid variant-grid--kpi">
                                    <template x-for="v in [{k:'basic',label:'Temel',icon:'fa-hashtag',desc:'Tek değer'},
                                                           {k:'delta',label:'Değişim',icon:'fa-arrow-trend-up',desc:'Önceki ile fark'},
                                                           {k:'sparkline',label:'Mini Grafik',icon:'fa-chart-line',desc:'Satır grafik'},
                                                           {k:'progress',label:'İlerleme',icon:'fa-battery-half',desc:'Yüzde bar'}]" :key="v.k">
                                        <button type="button" class="variant-card"
                                                :class="(selected.variant || 'basic') === v.k && 'on'"
                                                @@click="setKpiVariant(v.k)">
                                            <i class="fas" :class="v.icon" style="font-size:16px; margin-bottom:4px;"></i>
                                            <span class="variant-label" x-text="v.label"></span>
                                            <span class="variant-desc" x-text="v.desc"></span>
                                        </button>
                                    </template>
                                </div>
                            </div>
                        </template>

                        @* Chart tipi picker — 10 tip *@
                        <template x-if="selected.type === 'chart'">
                            <div class="field">
                                <label class="lab">Grafik Tipi</label>
                                <div class="variant-grid variant-grid--chart">
                                    <template x-for="v in [{k:'bar',label:'Sütun',icon:'fa-chart-bar'},
                                                           {k:'hbar',label:'Yatay Sütun',icon:'fa-chart-bar fa-rotate-90'},
                                                           {k:'line',label:'Çizgi',icon:'fa-chart-line'},
                                                           {k:'area',label:'Alan',icon:'fa-chart-area'},
                                                           {k:'stacked',label:'Yığılmış',icon:'fa-layer-group'},
                                                           {k:'pie',label:'Pasta',icon:'fa-chart-pie'},
                                                           {k:'doughnut',label:'Halka',icon:'fa-circle-notch'},
                                                           {k:'radar',label:'Radar',icon:'fa-compass'},
                                                           {k:'polarArea',label:'Kutup Alan',icon:'fa-bullseye'},
                                                           {k:'scatter',label:'Dağılım',icon:'fa-braille'}]" :key="v.k">
                                        <button type="button" class="variant-card variant-card--sm"
                                                :class="(selected.variant || 'bar') === v.k && 'on'"
                                                @@click="setChartVariant(v.k)">
                                            <i class="fas" :class="v.icon" style="font-size:14px;"></i>
                                            <span class="variant-label" x-text="v.label"></span>
                                        </button>
                                    </template>
                                </div>
                            </div>
                        </template>

                        <div class="field">
                            <label class="lab">Genişlik</label>
                            <div class="span-grid">
                                <template x-for="s in [1,2,3,4]" :key="s">
                                    <button type="button" class="span-pick"
                                            :class="(selected.span || 3) === s && 'on'"
                                            @@click="setField('span', s)"
                                            x-text="s === 1 ? '¼' : s === 2 ? '½' : s === 3 ? '¾' : 'Tam'"></button>
                                </template>
                            </div>
                            <p style="font-size:10px; color:var(--ink-4); margin-top:6px;">1 = çeyrek satır · 4 = tam satır.</p>
                        </div>

                        <div class="field">
                            <label class="lab" style="display:flex; align-items:center; justify-content:space-between;">
                                <span>Renk Vurgusu</span>
                                <button type="button" x-show="selected.color"
                                        @@click="setField('color', null)"
                                        style="background:transparent; border:none; color:var(--ink-3); font-size:10px; cursor:pointer; text-transform:none; letter-spacing:0;">
                                    Kaldır
                                </button>
                            </label>
                            <div class="swatch-grid">
                                <template x-for="c in ['red','blue','green','amber','violet','rose','slate']" :key="c">
                                    <div class="swatch" :class="['s-' + c, selected.color === c && 'on']"
                                         @@click="setField('color', c)" :title="c"></div>
                                </template>
                            </div>
                        </div>

                        <div class="field">
                            <label class="lab" style="display:flex; align-items:center; justify-content:space-between;">
                                <span>İkon</span>
                                <button type="button" x-show="selected.icon"
                                        @@click="setField('icon', null)"
                                        style="background:transparent; border:none; color:var(--ink-3); font-size:10px; cursor:pointer; text-transform:none; letter-spacing:0;">
                                    Kaldır
                                </button>
                            </label>
                            <input type="search" class="col-search" placeholder="İkon ara (chart, user, calendar...)" x-model="iconSearchTerm" style="margin-bottom:8px;" />
                            <div class="icon-grid">
                                <template x-for="ic in filteredIcons()" :key="ic">
                                    <div class="icon-pick" :class="selected.icon === ic && 'on'"
                                         @@click="setField('icon', ic)" :title="ic">
                                        <i class="fas" :class="ic" style="font-size:13px;"></i>
                                    </div>
                                </template>
                            </div>
                            <div x-show="filteredIcons().length === 0" style="text-align:center; padding:12px; color:var(--ink-4); font-size:11px;">
                                <i class="fas fa-magnifying-glass" style="opacity:.4; margin-bottom:4px;"></i>
                                <p>"<span x-text="iconSearchTerm"></span>" için sonuç yok</p>
                                <p style="margin-top:6px; font-size:10px;">Manuel girmek için aşağıdaki kutuyu kullanın.</p>
                            </div>
                            <details style="margin-top:10px; font-size:11px;">
                                <summary style="cursor:pointer; color:var(--ink-3); padding:4px 0;">Manuel ikon adı gir</summary>
                                <div style="display:flex; gap:6px; margin-top:6px;">
                                    <input type="text" class="inp" placeholder="fa-rocket veya rocket" x-model="iconCustom" @@keydown.enter="applyCustomIcon()" style="flex:1;" />
                                    <button type="button" class="btn" @@click="applyCustomIcon()" style="height:30px;">Uygula</button>
                                </div>
                                <p style="font-size:10px; color:var(--ink-4); margin-top:4px;">Font Awesome 6 kütüphanesindeki herhangi bir <code>fa-*</code> sınıfı.</p>
                            </details>
                            <p style="font-size:10px; color:var(--ink-4); margin-top:6px;">İkon KPI başlığında görünür.</p>
                        </div>
                    </div>
                </template>
            </div>

            @* ===== NO-SELECTION STATE — Rapor Ayarları (selected null iken görünür) ===== *@
            <div x-show="!selected" x-cloak>
                <div class="selected-banner">
                    <span class="ico"><i class="fas fa-gear"></i></span>
                    <span class="name">Rapor Ayarları</span>
                </div>
                <p style="font-size:11px; color:var(--ink-3); margin-bottom:14px;">Tüm alanlar form POST'a dahil olur. Reaktif değişiklik dirty chip'i tetikler.</p>

                <div class="field">
                    <label class="lab">Rapor Adı</label>
                    <input type="text" class="inp" x-model="title" placeholder="Örn: Şube Performans Panosu" />
                </div>

                <div class="field">
                    <label class="lab">Veri Kaynağı</label>
                    <select class="inp" x-model="dataSourceKey" @@change="onDataSourceChange()">
                        <option value="">— seç —</option>
                        <template x-for="ds in availableDataSources" :key="ds.key">
                            <option :value="ds.key" :selected="ds.key === dataSourceKey" x-text="ds.title + ' (' + ds.key + ')'"></option>
                        </template>
                    </select>
                </div>

                <div class="field">
                    <label class="lab">Stored Procedure</label>
                    <input type="text" class="inp" x-model="procName" list="spListV2"
                           @@change="onProcNameChange()" @@blur="onProcNameChange()"
                           :disabled="!dataSourceKey"
                           placeholder="Örn: sp_PdksPano" />
                    <datalist id="spListV2">
                        <template x-for="sp in spList" :key="sp.name">
                            <option :value="sp.name"></option>
                        </template>
                    </datalist>
                </div>

                <div class="field">
                    <label class="lab" style="display:flex; align-items:center; justify-content:space-between;">
                        <span>Parametre Şeması (JSON)</span>
                        <button type="button" x-show="dataSourceKey && procName"
                                x-on:click="loadProcParams()"
                                style="background:transparent; border:none; color:var(--accent-ink); font-size:10px; font-weight:600; cursor:pointer; text-transform:uppercase; letter-spacing:.04em;">
                            <i class="fas fa-rotate text-[9px]"></i> SP'den yeniden çek
                        </button>
                    </label>
                    <textarea class="inp" rows="7" x-model="paramSchemaJson"
                              style="font-family:'JetBrains Mono',monospace; font-size:11px; line-height:1.45; white-space:pre;"
                              placeholder='{ "fields": [ { "name": "Tarih", "type": "date", "required": false, "default": "today" } ] }'></textarea>
                    <p style="font-size:10px; color:var(--ink-4); margin-top:4px; line-height:1.4;">
                        Sadece kullanıcının doldurması gereken parametreleri bırakın. Kaldırılan SP parametreleri için SP default değerleri kullanılır.
                    </p>
                    <details x-show="procParams.length > 0" x-cloak style="margin-top:6px;">
                        <summary style="cursor:pointer; font-size:10.5px; color:var(--ink-3); padding:4px 0;">SP'nin tüm parametreleri (referans)</summary>
                        <div class="inp" style="background:var(--canvas); font-family:'JetBrains Mono',monospace; font-size:11px; line-height:1.5; margin-top:4px;">
                            <template x-for="p in procParams" :key="p.name">
                                <div>· <span x-text="p.name"></span> <span style="color:var(--ink-3);" x-text="'(' + p.type + ')'"></span></div>
                            </template>
                        </div>
                    </details>
                </div>

                <div class="field">
                    <label class="lab">Açıklama</label>
                    <textarea class="inp" rows="3" x-model="description"
                              placeholder="Rapor hakkında kısa açıklama…"></textarea>
                </div>

                <div class="field">
                    <label class="lab" style="display:flex; align-items:center; gap:8px;">
                        Aktif
                        <label style="position:relative; display:inline-block; width:36px; height:20px; cursor:pointer; margin:0;">
                            <input type="checkbox" :checked="isActive" x-on:change="isActive = $el.checked"
                                   style="opacity:0; width:0; height:0;" />
                            <span :style="'position:absolute; inset:0; border-radius:10px; transition:.2s; background:' + (isActive ? 'var(--accent-ink)' : 'var(--line)')"></span>
                            <span :style="'position:absolute; top:2px; width:16px; height:16px; border-radius:50%; transition:.2s; background:#fff; left:' + (isActive ? '18px' : '2px')"></span>
                        </label>
                    </label>
                </div>

                <template x-if="availableRoles.length > 0">
                    <div class="field">
                        <label class="lab">İzinli Roller</label>
                        <div style="display:flex; flex-direction:column; gap:4px; max-height:140px; overflow-y:auto; padding:6px 8px; border:1px solid var(--line); border-radius:6px; background:var(--paper);">
                            <template x-for="role in availableRoles" :key="role.id">
                                <label style="display:flex; align-items:center; gap:6px; font-size:12px; cursor:pointer;">
                                    <input type="checkbox" :checked="selectedRoleIds.includes(role.id)"
                                           x-on:change="toggleRole(role.id)" />
                                    <span x-text="role.name"></span>
                                </label>
                            </template>
                        </div>
                    </div>
                </template>

                <template x-if="availableGroups.length > 0">
                    <div class="field">
                        <label class="lab">Gruplar</label>
                        <div style="display:flex; flex-direction:column; gap:4px; max-height:140px; overflow-y:auto; padding:6px 8px; border:1px solid var(--line); border-radius:6px; background:var(--paper);">
                            <template x-for="grp in availableGroups" :key="grp.id">
                                <label style="display:flex; align-items:center; gap:6px; font-size:12px; cursor:pointer;">
                                    <input type="checkbox" :checked="selectedGroupIds.includes(grp.id)"
                                           x-on:change="toggleGroup(grp.id)" />
                                    <span x-text="grp.name"></span>
                                </label>
                            </template>
                        </div>
                    </div>
                </template>
            </div>

        </div>
    </aside>

    @* ============ FULL PREVIEW MODAL — F-9 iframe ============ *@
    <div x-show="previewModal && previewModal.open" x-cloak
         class="builder-v2-preview-backdrop"
         @@click.self="closePreview()"
         @@keydown.escape.window="closePreview()">
        <div class="builder-v2-preview-shell">
            <div class="m-head">
                <span class="m-title">Tam Dashboard Önizleme</span>
                <span class="m-meta" x-text="reportMeta && reportMeta.title ? reportMeta.title : ''"></span>
                <button type="button" class="m-close" @@click="closePreview()" title="Kapat (Esc)">×</button>
            </div>
            <div class="m-body">
                <div x-show="previewModal.loading" style="padding:20px; text-align:center; color:var(--ink-3);">
                    <i class="fas fa-spinner fa-spin"></i> Önizleme oluşturuluyor…
                </div>
                <div x-show="previewModal.error" x-cloak
                     style="padding:20px; color:var(--accent-ink); white-space:pre-line;"
                     x-text="previewModal.error"></div>
                <template x-if="!previewModal.loading && !previewModal.error && previewModal.html">
                    <iframe :srcdoc="previewModal.html"
                            sandbox="allow-scripts allow-same-origin allow-downloads"
                            style="width:100%; height:100%; border:0;"></iframe>
                </template>
            </div>
        </div>
    </div>

    @* ============ DATA MODAL — Widget çift-tıkla veya palette RS click ============ *@
    <div x-show="dataModal && dataModal.open" x-cloak
         class="builder-v2-modal-backdrop"
         @@click.self="closeDataModal()"
         @@keydown.escape.window="closeDataModal()">
        <div class="builder-v2-modal">
            <div class="m-head">
                <span class="m-meta" x-text="'RS:' + (dataModal.rsIdx + 1)"></span>
                <span class="m-title" x-text="modalRsTitle()"></span>
                <span class="m-tags">
                    <template x-if="dataModal.comp && dataModal.comp.column">
                        <span class="m-meta" style="background:var(--accent-soft); color:var(--accent-ink);"
                              x-text="'Bağlı kolon: ' + dataModal.comp.column"></span>
                    </template>
                    <template x-if="modalRs()">
                        <span style="font-size:11px; color:var(--ink-3);" x-text="modalRs().rowCount + ' satır · ' + (modalRs().columns || []).length + ' kolon · ilk ' + (modalRs().rows || []).length + ' gösteriliyor'"></span>
                    </template>
                </span>
                <button type="button" class="m-close" @@click="closeDataModal()" title="Kapat (Esc)">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>
            <div class="m-body">
                <template x-if="modalRs() && (modalRs().rows || []).length > 0">
                    <table>
                        <thead>
                            <tr>
                                <template x-for="col in (modalRs().columns || [])" :key="col">
                                    <th :class="dataModal.comp && dataModal.comp.column === col && 'col-highlight'" x-text="col"></th>
                                </template>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="(row, ri) in (modalRs().rows || [])" :key="ri">
                                <tr>
                                    <template x-for="col in (modalRs().columns || [])" :key="col">
                                        <td :class="dataModal.comp && dataModal.comp.column === col && 'col-highlight'"
                                            x-text="row[col] == null ? '' : String(row[col])"></td>
                                    </template>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </template>
                <template x-if="!modalRs() || (modalRs().rows || []).length === 0">
                    <div style="text-align:center; padding:60px 20px; color:var(--ink-4);">
                        <i class="fas fa-table" style="font-size:32px; opacity:.4;"></i>
                        <p style="margin-top:12px;">Bu veri setinde satır yok.</p>
                    </div>
                </template>
            </div>
            <div class="m-foot">
                <span><span class="kbd">Esc</span> kapat</span>
                <template x-if="dataModal.comp">
                    <span>Widget: <strong x-text="dataModal.comp.title || dataModal.comp.type"></strong></span>
                </template>
                <span style="margin-left:auto;">
                    <i class="fas fa-circle-info text-[10px]" style="margin-right:4px;"></i>
                    Bağlı kolon kırmızı vurgulu
                </span>
            </div>
        </div>
    </div>
</div>

<div class="builder-v2-foot">
    <span><span class="kbd">⌘S</span> kaydet</span>
    <span><span class="kbd">⌘P</span> önizle</span>
    <span><span class="kbd">Çift-tık</span> widget verisi</span>
    <span><span class="kbd">Del</span> seçili sil</span>
    <span style="margin-left:auto;" x-data="{}" x-text="'12 sütun grid'"></span>
</div>

