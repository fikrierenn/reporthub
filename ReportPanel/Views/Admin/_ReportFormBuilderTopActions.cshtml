@*
    EditReport + CreateReport ortak topbar slot icerigi.
    Form id parametre olarak gecirilir (string model): "reportEditForm" veya "reportCreateForm".

    F-9'da builder-core.js bu butonlari bind edecek (dbDirtyChip/dbBtnPreview/dbBtnUndo/dbBtnJson).
*@
@model string

<span id="dbDirtyChip" class="dirty-chip" hidden>
    <i class="fas fa-circle-exclamation text-[9px]"></i>
    kaydedilmemiş
</span>
<button type="button" id="dbBtnPreview" class="btn" disabled title="F-9'da aktif olacak">
    <i class="fas fa-eye text-[10px]"></i>
    Önizle
</button>
<button type="button" id="dbBtnUndo" class="btn" disabled title="F-9'da aktif olacak">
    <i class="fas fa-rotate-left text-[10px]"></i>
    Geri Al
</button>
<button type="button" id="dbBtnJson" class="btn" title="DashboardConfigJson'a in/çık">
    <i class="fas fa-code text-[10px]"></i>
    JSON
</button>
<button type="submit" form="@Model" class="btn primary">
    <i class="fas fa-check text-[10px]"></i>
    Kaydet
</button>
