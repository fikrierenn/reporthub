@model ReportPanel.ViewModels.AdminReportFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Yeni Rapor - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Yeni Rapor";
    var dataSources = Model.DataSources ?? new List<ReportPanel.Models.DataSource>();
    var availableRoles = Model.AvailableRoles ?? new List<ReportPanel.Models.Role>();
    var selectedRoleIds = Model.SelectedRoleIds ?? new HashSet<int>();
    var availableCategories = Model.AvailableCategories ?? new List<ReportPanel.Models.ReportCategory>();
    var selectedCategoryIds = Model.SelectedCategoryIds ?? new HashSet<int>();
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@@10.3.1/dist/gridstack.min.css" crossorigin="anonymous" />
    <script defer src="https://cdn.jsdelivr.net/npm/gridstack@@10.3.1/dist/gridstack-all.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="~/assets/css/dashboard-builder.css" asp-append-version="true" />
}

@section Breadcrumb {
    <div class="crumbs">
        <a href="/Dashboard">BKM Kitap</a>
        <span class="sep">/</span>
        <a href="/Admin">Yönetim</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=reports">Raporlar</a>
        <span class="sep">/</span>
        <span class="current">Yeni Rapor</span>
    </div>
}

@section TopActions {
    @await Html.PartialAsync("_ReportFormBuilderTopActions", "reportCreateForm")
}

<div class="hero">
    <h1>Yeni Rapor</h1>
    <div class="sub">
        <span>Yeni rapor tanımı oluşturun</span>
        <span class="pill">
            <i class="fas fa-circle-info" style="font-size:9px; color:var(--ink-3);"></i>
            Tüm raporlar dashboard olarak kaydedilir (ADR-009)
        </span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var isError = Model.MessageType == "error";
    <div role="alert" style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                background: @(isError ? "rgba(220,38,38,0.10)" : "rgba(16,185,129,0.10)");
                border: 1px solid @(isError ? "rgba(220,38,38,0.25)" : "rgba(16,185,129,0.25)");
                color: @(isError ? "var(--accent-ink)" : "#065f46");">
        <i class="fas @(isError ? "fa-circle-exclamation" : "fa-circle-check")" style="margin-right:8px;"></i>
        @Model.Message
    </div>
}

<form method="post" id="reportCreateForm">
    @Html.AntiForgeryToken()

    @* ===== 1. Genel Bilgiler ===== *@
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; margin-bottom:14px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-file-lines" style="margin-right:6px; color:var(--ink-3);"></i>
                Genel Bilgiler
            </h2>
        </div>
        <div style="padding:20px;">
            <div class="field" style="margin-bottom:14px;">
                <label class="lab">Rapor Adı <span style="color:var(--accent);">*</span></label>
                <input type="text" name="Title" value="@Model.Report.Title" required class="inp" placeholder="örn: Satış Raporu" />
            </div>

            <div class="field" style="margin-bottom:14px;">
                <label class="lab">Veri Kaynağı <span style="color:var(--accent);">*</span></label>
                @if (dataSources.Any())
                {
                    <select name="DataSourceKey" required class="inp">
                        <option value="">Veri kaynağını seçiniz...</option>
                        @foreach (var ds in dataSources)
                        {
                            <option value="@ds.DataSourceKey" selected="@(ds.DataSourceKey == Model.Report.DataSourceKey)">
                                @ds.Title (@ds.DataSourceKey)
                            </option>
                        }
                    </select>
                }
                else
                {
                    <div style="padding:12px 14px; background:rgba(220,38,38,0.06); border:1px solid rgba(220,38,38,0.2); border-radius:8px; color:var(--accent-ink); font-size:12px;">
                        <i class="fas fa-circle-exclamation" style="margin-right:6px;"></i>
                        Aktif veri kaynağı bulunamadı.
                        <a href="/Admin/CreateDataSource" style="color:var(--accent-ink); text-decoration:underline;">Önce veri kaynağı ekleyin</a>
                    </div>
                    <input type="hidden" name="DataSourceKey" value="" />
                }
            </div>

            <div class="field" style="margin-bottom:14px;">
                <label class="lab">Açıklama</label>
                <textarea name="Description" rows="3" class="inp" style="height:auto; padding:10px 12px; resize:vertical;"
                          placeholder="Rapor hakkında açıklama yazın...">@Model.Report.Description</textarea>
            </div>

            <div class="field" style="margin-bottom:0;">
                <label class="lab">Kategoriler</label>
                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:6px; padding:8px 10px; background:var(--canvas); border:1px solid var(--line); border-radius:8px;">
                    @if (!availableCategories.Any())
                    {
                        <div style="font-size:12px; color:var(--accent-ink);">Kategori listesi tanımlı değil.</div>
                    }
                    else
                    {
                        foreach (var category in availableCategories)
                        {
                            var isChecked = selectedCategoryIds.Contains(category.CategoryId);
                            <label style="display:flex; align-items:center; gap:6px; font-size:12px; color:var(--ink-2); cursor:pointer;">
                                <input type="checkbox" name="SelectedCategories" value="@category.CategoryId" @(isChecked ? "checked" : "")
                                       style="width:14px; height:14px; accent-color:var(--accent);" />
                                <span>@category.Name</span>
                            </label>
                        }
                    }
                </div>
                <p style="margin:6px 0 0; font-size:11px; color:var(--ink-3);">Birden fazla kategori seçilebilir.</p>
            </div>
        </div>
    </div>

    @* ===== 2. Teknik Ayarlar ===== *@
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; margin-bottom:14px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-gear" style="margin-right:6px; color:var(--ink-3);"></i>
                Teknik Ayarlar
            </h2>
        </div>
        <div style="padding:20px;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Prosedür Adı <span style="color:var(--accent);">*</span></label>
                    <input type="text" name="ProcName" id="ProcName" value="@Model.Report.ProcName" required
                           class="inp" style="font-family:'JetBrains Mono', monospace;" placeholder="sp_SatisRaporu" />
                    <p style="margin:6px 0 0; font-size:11px; color:var(--ink-3);">Veritabanında çalıştırılacak SP adı.</p>
                </div>

                <div class="field" style="margin-bottom:0;">
                    <label class="lab">İzinli Roller</label>
                    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:6px; padding:8px 10px; background:var(--canvas); border:1px solid var(--line); border-radius:8px;">
                        @if (!availableRoles.Any())
                        {
                            <div style="font-size:12px; color:var(--accent-ink);">Rol listesi tanımlı değil.</div>
                        }
                        else
                        {
                            foreach (var role in availableRoles)
                            {
                                var isChecked = selectedRoleIds.Contains(role.RoleId);
                                <label style="display:flex; align-items:center; gap:6px; font-size:12px; color:var(--ink-2); cursor:pointer;">
                                    <input type="checkbox" name="SelectedRoles" value="@role.RoleId" @(isChecked ? "checked" : "")
                                           style="width:14px; height:14px; accent-color:var(--accent);" />
                                    <span>@role.Name</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="field" style="margin-bottom:0;">
                <label class="lab">ParamSchemaJson</label>
                @Html.TextArea("ParamSchemaJson", Model.Report.ParamSchemaJson, new
                {
                    id = "ParamSchemaJson",
                    rows = "3",
                    @class = "inp",
                    style = "height:auto; padding:10px 12px; font-family:'JetBrains Mono', monospace; font-size:12px; resize:vertical;",
                    placeholder = "{\"fields\":[{\"name\":\"StartDate\",\"label\":\"Başlangıç Tarihi\",\"type\":\"date\",\"required\":true}]}"
                })
                <p style="margin:6px 0 0; font-size:11px; color:var(--ink-3);">JSON formatında parametre tanımı.</p>
            </div>
        </div>
    </div>

    @* ===== 3. Parametre Oluşturucu ===== *@
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; margin-bottom:14px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-list-ul" style="margin-right:6px; color:var(--ink-3);"></i>
                Parametre Oluşturucu
            </h2>
        </div>
        <div style="padding:20px;">
            <div style="display:grid; grid-template-columns:repeat(7, 1fr) auto auto; gap:8px; align-items:end;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Ad</label>
                    <input type="text" id="paramName" class="inp" placeholder="StartDate" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Etiket</label>
                    <input type="text" id="paramLabel" class="inp" placeholder="Başlangıç Tarihi" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Placeholder</label>
                    <input type="text" id="paramPlaceholder" class="inp" placeholder="gg.aa.yyyy" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Tip</label>
                    <select id="paramType" class="inp">
                        <option value="text">text</option>
                        <option value="number">number</option>
                        <option value="decimal">decimal</option>
                        <option value="date">date</option>
                        <option value="checkbox">checkbox</option>
                    </select>
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Varsayılan</label>
                    <input type="text" id="paramDefault" class="inp" placeholder="today" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Yardım</label>
                    <input type="text" id="paramHelp" class="inp" placeholder="Zorunlu alan" />
                </div>
                <div style="display:flex; align-items:center; gap:6px; height:34px;">
                    <input type="checkbox" id="paramRequired" style="width:14px; height:14px; accent-color:var(--accent);" />
                    <label for="paramRequired" class="lab" style="margin:0;">Zorunlu</label>
                </div>
                <button type="button" id="addParamBtn" class="btn primary" style="height:34px;">
                    <i class="fas fa-plus text-[10px]"></i>
                    Ekle
                </button>
                <button type="button" id="loadParamsBtn" class="btn" style="height:34px;">
                    <i class="fas fa-download text-[10px]"></i>
                    SP'den Getir
                </button>
            </div>

            <div style="margin-top:14px;">
                <div style="font-size:12px; color:var(--ink-3); margin-bottom:8px;">Parametreler</div>
                <div id="paramList" style="display:flex; flex-direction:column; gap:6px;"></div>
            </div>
        </div>
    </div>

    @* ===== 4. Dashboard Oluşturucu (ADR-009: tüm raporlar dashboard) ===== *@
    <div id="dashboardConfigSection" style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; margin-bottom:14px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-table-cells-large" style="margin-right:6px; color:var(--ink-3);"></i>
                Dashboard Oluşturucu
            </h2>
            <div style="font-size:12px; color:var(--ink-3); margin-top:2px;">İlk kayıt sonrası widget eklenebilir</div>
        </div>
        <textarea name="DashboardConfigJson" id="DashboardConfigJson" class="hidden">@Model.Report.DashboardConfigJson</textarea>
        <div id="dashboardBuilder" style="padding:20px;"></div>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:14px 20px; margin-bottom:14px; display:flex; align-items:center; gap:10px;">
        <input type="checkbox" name="IsActive" value="true" id="reportActive" @(Model.Report.IsActive ? "checked" : "")
               style="width:16px; height:16px; accent-color:var(--accent);" />
        <label for="reportActive" class="lab" style="margin:0;">Raporu aktif olarak işaretle</label>
    </div>

    <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 20px; background:var(--paper); border:1px solid var(--line); border-radius:10px;">
        <a href="/Admin?tab=reports" class="btn ghost">
            <i class="fas fa-arrow-left text-[10px]"></i>
            Geri Dön
        </a>
        <span style="font-size:11px; color:var(--ink-3);">Kaydet işlemi üst topbar'dan da yapılabilir</span>
    </div>
</form>

<script src="~/assets/js/admin-report-form/param-builder.js"></script>
<script src="~/assets/js/admin-report-form/sp-helper.js"></script>
<script src="~/assets/js/dashboard-builder/builder-core.js"></script>
<script src="~/assets/js/dashboard-builder/builder-canvas.js"></script>
<script src="~/assets/js/dashboard-builder/builder-contract.js"></script>
<script src="~/assets/js/dashboard-builder/builder-list.js"></script>
<script src="~/assets/js/dashboard-builder/builder-drawer.js"></script>
<script src="~/assets/js/dashboard-builder/builder-preview.js"></script>
<script src="~/assets/js/dashboard-builder/builder-templates.js"></script>
