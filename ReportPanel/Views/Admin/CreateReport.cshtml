@model ReportPanel.ViewModels.AdminReportFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Yeni Rapor - BKM Rapor Paneli";
    var dataSources = Model.DataSources ?? new List<ReportPanel.Models.DataSource>();
    var availableRoles = Model.AvailableRoles ?? new List<ReportPanel.Models.Role>();
    var selectedRoleIds = Model.SelectedRoleIds ?? new HashSet<int>();
    var availableCategories = Model.AvailableCategories ?? new List<ReportPanel.Models.ReportCategory>();
    var selectedCategoryIds = Model.SelectedCategoryIds ?? new HashSet<int>();
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Yeni Rapor</h1>
        <p class="text-sm text-gray-500">Yeni rapor tanimi olusturun</p>
    </div>
    <a href="/Admin?tab=reports" class="btn-brand-outline flex items-center px-4 py-2 text-sm font-medium rounded-lg">
        <i class="fas fa-times mr-2"></i>İptal
    </a>
</div>

<div class="bg-white rounded-2xl shadow-brand border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 px-8 py-6 border-b border-gray-100">
        <div class="flex items-center space-x-4">
            <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center shadow-lg">
                <i class="fas fa-plus text-white text-2xl"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Rapor Bilgileri</h2>
                <p class="text-gray-600">Rapor detaylarini ve ayarlarini girin</p>
            </div>
        </div>
    </div>

    <div class="p-8">
        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            var isError = Model.MessageType == "error";
            var bannerClasses = isError
                ? "bg-red-50 border-red-200 text-red-800"
                : "bg-emerald-50 border-emerald-200 text-emerald-800";
            var bannerIcon = isError ? "fa-circle-exclamation" : "fa-circle-check";
            <div class="mb-6 border rounded-xl px-4 py-3 flex items-start @bannerClasses" role="alert">
                <i class="fas @bannerIcon mt-0.5 mr-3"></i>
                <div class="text-sm font-medium">@Model.Message</div>
            </div>
        }

        <form method="post" class="space-y-8">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-file-alt mr-2 text-blue-600"></i>Rapor Adi *
                    </label>
                    <input type="text" name="Title" value="@Model.Report.Title" required
                           class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg font-medium"
                           placeholder="Orn: Satis Raporu">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-database mr-2 text-blue-600"></i>Veri Kaynagi *
                    </label>
                    @if (dataSources.Any())
                    {
                        <select name="DataSourceKey" required
                                class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg">
                            <option value="">Veri kaynagini seciniz...</option>
                            @foreach (var ds in dataSources)
                            {
                                <option value="@ds.DataSourceKey" selected="@(ds.DataSourceKey == Model.Report.DataSourceKey)">
                                    @ds.Title (@ds.DataSourceKey)
                                </option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="w-full px-4 py-4 border border-red-300 rounded-xl bg-red-50 text-red-700 text-lg">
                            <i class="fas fa-exclamation-triangle mr-2"></i>
                            Aktif veri kaynagi bulunamadi.
                            <a href="/Admin/CreateDataSource" class="text-red-800 underline hover:text-red-900">
                                Once veri kaynagi ekleyin
                            </a>
                        </div>
                        <input type="hidden" name="DataSourceKey" value="">
                    }
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-3">
                    <i class="fas fa-align-left mr-2 text-blue-600"></i>Aciklama
                </label>
                <textarea name="Description" rows="4"
                          class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg"
                          placeholder="Rapor hakkinda aciklama yazin...">@Model.Report.Description</textarea>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-3">
                    <i class="fas fa-folder-open mr-2 text-blue-600"></i>Kategoriler
                </label>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    @if (!availableCategories.Any())
                    {
                        <div class="text-sm text-red-600">Kategori listesi tanimli degil.</div>
                    }
                    else
                    {
                        foreach (var category in availableCategories)
                        {
                            var isChecked = selectedCategoryIds.Contains(category.CategoryId);
                            <label class="flex items-center gap-2 text-sm text-gray-700">
                                <input type="checkbox" name="SelectedCategories" value="@category.CategoryId" @(isChecked ? "checked" : "")
                                       class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                                <span>@category.Name</span>
                            </label>
                        }
                    }
                </div>
                <p class="text-xs text-gray-500 mt-2">Birden fazla kategori secilebilir.</p>
            </div>

            @* ADR-009: "Rapor Tipi" radio kartı kaldırıldı. Yeni raporlar otomatik dashboard olarak oluşturulur; admin sonradan builder'da düzenler. *@

            <div class="bg-gray-50 rounded-2xl border border-gray-200 p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-cogs mr-3 text-blue-600"></i> Teknik Ayarlar
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-code mr-2 text-blue-600"></i>Prosedur Adi *
                        </label>
                        <input type="text" name="ProcName" value="@Model.Report.ProcName" required
                               class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg font-mono"
                               placeholder="sp_SatisRaporu">
                        <p class="text-xs text-gray-500 mt-2">Veritabanında çalıştırılacak stored procedure adı</p>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-users mr-2 text-blue-600"></i>Izinli Roller
                        </label>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            @if (!availableRoles.Any())
                            {
                                <div class="text-sm text-red-600">Rol listesi tanimli degil.</div>
                            }
                            else
                            {
                                foreach (var role in availableRoles)
                                {
                                    var isChecked = selectedRoleIds.Contains(role.RoleId);
                                    <label class="flex items-center gap-2 text-sm text-gray-700">
                                        <input type="checkbox" name="SelectedRoles" value="@role.RoleId" @(isChecked ? "checked" : "")
                                               class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                                        <span>@role.Name</span>
                                    </label>
                                }
                            }
                        </div>
                        <p class="text-xs text-gray-500 mt-2">Birden fazla rol secilebilir.</p>
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-sliders-h mr-2 text-blue-600"></i>ParamSchemaJson
                    </label>
                    @Html.TextArea("ParamSchemaJson", Model.Report.ParamSchemaJson, new
                    {
                        id = "ParamSchemaJson",
                        rows = "4",
                        @class = "w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-sm font-mono",
                        placeholder = "{\"fields\":[{\"name\":\"StartDate\",\"label\":\"Başlangıç Tarihi\",\"type\":\"date\",\"required\":true}]}"
                    })
                    <p class="text-xs text-gray-500 mt-2">JSON formatinda parametre tanimi.</p>
                </div>
            </div>

            <div class="bg-white rounded-2xl border border-gray-200 p-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                    <i class="fas fa-list mr-3 text-blue-600"></i> Parametre Olusturucu
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-7 gap-4 items-end">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Ad</label>
                        <input type="text" id="paramName" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="StartDate">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Etiket</label>
                        <input type="text" id="paramLabel" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="Başlangıç Tarihi">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Placeholder</label>
                        <input type="text" id="paramPlaceholder" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="gg.aa.yyyy">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Tip</label>
                        <select id="paramType" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
                            <option value="text">text</option>
                            <option value="number">number</option>
                            <option value="decimal">decimal</option>
                            <option value="date">date</option>
                            <option value="checkbox">checkbox</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Varsayilan</label>
                        <input type="text" id="paramDefault" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="today">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Yardim</label>
                        <input type="text" id="paramHelp" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="Zorunlu alan">
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="flex items-center gap-2 text-sm font-semibold text-gray-700">
                            <input type="checkbox" id="paramRequired" class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                            Zorunlu
                        </label>
                        <button type="button" id="addParamBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold">
                            Ekle
                        </button>
                    </div>
                    <div class="flex items-center">
                        <button type="button" id="loadParamsBtn" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-semibold">
                            SP Parametrelerini Getir
                        </button>
                    </div>
                </div>

                <div class="mt-6">
                    <div class="text-sm text-gray-600 mb-2">Parametreler</div>
                    <div id="paramList" class="space-y-2"></div>
                </div>
            </div>

            <div id="dashboardConfigSection" style="display:none;">
                <div class="bg-white rounded-2xl border border-gray-200 p-6">
                    <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-th-large mr-3 text-purple-600"></i> Dashboard Olusturucu
                    </h3>
                    <textarea name="DashboardConfigJson" id="DashboardConfigJson" class="hidden">@Model.Report.DashboardConfigJson</textarea>
                    <div id="dashboardBuilder"></div>
                </div>
            </div>

            <div class="flex items-center space-x-3">
                <input type="checkbox" name="IsActive" value="true" @(Model.Report.IsActive ? "checked" : "")
                       class="w-5 h-5 text-blue-600 focus:ring-blue-600 border-gray-300 rounded">
                <label class="text-lg font-medium text-gray-700">Raporu aktif olarak isaretle</label>
            </div>

            <div class="flex items-center justify-between pt-6 border-t border-gray-200">
                <a href="/Admin?tab=reports" class="btn-brand-outline flex items-center px-6 py-3 text-lg font-medium rounded-xl">
                    <i class="fas fa-arrow-left mr-2"></i>Geri Don
                </a>

                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white flex items-center px-8 py-3 text-lg font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 transform hover:scale-105">
                    <i class="fas fa-save mr-3"></i>Raporu Kaydet
                </button>
            </div>
        </form>
    </div>
</div>
<script src="~/assets/js/admin-report-form.js"></script>
<script src="~/assets/js/dashboard-builder.js"></script>
<script>
function toggleReportType(type) {
    var dashSection = document.getElementById('dashboardConfigSection');
    var labelTable = document.getElementById('radioLabelTable');
    var labelDash = document.getElementById('radioLabelDashboard');
    if (type === 'dashboard') {
        dashSection.style.display = 'block';
        labelDash.style.borderColor = '#a855f7';
        labelDash.style.background = '#faf5ff';
        labelTable.style.borderColor = '#e5e7eb';
        labelTable.style.background = '';
    } else {
        dashSection.style.display = 'none';
        labelTable.style.borderColor = '#3b82f6';
        labelTable.style.background = '#eff6ff';
        labelDash.style.borderColor = '#e5e7eb';
        labelDash.style.background = '';
    }
}
</script>
