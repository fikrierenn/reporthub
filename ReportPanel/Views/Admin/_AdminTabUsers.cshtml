@model ReportPanel.ViewModels.AdminIndexViewModel

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
    <div style="font-size:12px; color:var(--ink-3);">Kullanıcıları ekleyin, güncelleyin ve pasif edin</div>
    <a href="/Admin/CreateUser" class="btn primary">
        <i class="fas fa-user-plus text-[10px]"></i>
        Yeni Kullanıcı
    </a>
</div>

<div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
    <table class="dt">
        <thead>
            <tr>
                <th>Kullanıcı</th>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Roller</th>
                <th>Durum</th>
                <th>Son Giriş</th>
                <th style="text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td><span class="mono">@user.Username</span></td>
                    <td>@user.FullName</td>
                    <td style="font-size:12px; color:var(--ink-3);">@user.Email</td>
                    <td style="font-size:12px;">@(Model.UserRoleNames.TryGetValue(user.UserId, out var _roleNames) ? string.Join(", ", _roleNames) : "-")</td>
                    <td>
                        <span class="status @(user.IsActive ? "ok" : "err")">@(user.IsActive ? "Aktif" : "Pasif")</span>
                    </td>
                    <td><span class="ago">@(user.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</span></td>
                    <td style="text-align:right;">
                        <div style="display:inline-flex; gap:6px;">
                            <a href="/Admin/EditUser/@user.UserId" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                <i class="fas fa-pen text-[9px]"></i>
                                Düzenle
                            </a>
                            <form method="post" style="display:inline;" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="action" value="delete_user" />
                                <input type="hidden" name="id" value="@user.UserId" />
                                <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                    <i class="fas fa-trash text-[9px]"></i>
                                    Sil
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
