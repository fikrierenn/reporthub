@model ReportPanel.ViewModels.AdminDataSourceFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Yeni Veri Kaynagi - BKM Rapor Paneli";
    var templateConnString = Model.TemplateConnString ?? "";
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Yeni Veri Kaynagi</h1>
        <p class="text-sm text-gray-500">Yeni veritabani baglantisi olusturun</p>
    </div>
    <a href="/Admin" class="btn-brand-outline flex items-center px-4 py-2 text-sm font-medium rounded-lg">
        <i class="fas fa-times mr-2"></i>İptal
    </a>
</div>

<div class="bg-white rounded-2xl shadow-brand border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-red-50 to-orange-50 px-8 py-6 border-b border-gray-100">
        <div class="flex items-center space-x-4">
            <div class="w-16 h-16 bg-brand rounded-2xl flex items-center justify-center shadow-brand">
                <i class="fas fa-plus text-white text-2xl"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Veri Kaynagi Bilgileri</h2>
                <p class="text-gray-600">Veritabani baglanti detaylarini girin</p>
            </div>
        </div>
    </div>

    <div class="p-8">
        <form method="post" class="space-y-8" onsubmit="return validateForm()">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-key mr-2 text-brand"></i>Anahtar *
                    </label>
                    <input type="text" name="DataSourceKey" value="@Model.DataSource.DataSourceKey" required
                           class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand text-lg font-medium"
                           placeholder="Orn: MAIN, IK, MALI">
                    <p class="text-xs text-gray-500 mt-2">Benzersiz anahtar (buyuk harf onerilir)</p>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-tag mr-2 text-brand"></i>Baslik *
                    </label>
                    <input type="text" name="Title" value="@Model.DataSource.Title" required
                           class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand text-lg"
                           placeholder="Orn: Ana Veritabani">
                </div>
            </div>

            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl border border-blue-200 p-6">
                <h3 class="text-lg font-bold text-blue-900 mb-4 flex items-center">
                    <i class="fas fa-server mr-3"></i> Veritabani Baglanti Ayarlari
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-server mr-2 text-blue-600"></i>Sunucu Adi *
                        </label>
                        <input type="text" id="serverName" placeholder="Orn: BT-FIKRI\\SQLEXPRESS"
                               class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg"
                               value="BT-FIKRI\\SQLEXPRESS">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-database mr-2 text-blue-600"></i>Veritabani Adi *
                        </label>
                        <input type="text" id="databaseName" placeholder="Orn: PortalHUB"
                               class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg"
                               value="PortalHUB">
                        <div class="mt-2 flex flex-wrap gap-2">
                            <button type="button" onclick="setDatabase('PortalHUB')" class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg text-sm hover:bg-blue-200 transition-colors">PortalHUB</button>
                            <button type="button" onclick="setDatabase('BKM_GENEL')" class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg text-sm hover:bg-blue-200 transition-colors">BKM_GENEL</button>
                            <button type="button" onclick="setDatabase('MainDB')" class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg text-sm hover:bg-blue-200 transition-colors">MainDB</button>
                            <button type="button" onclick="setDatabase('MaliDB')" class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg text-sm hover:bg-blue-200 transition-colors">MaliDB</button>
                        </div>
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-shield-alt mr-2 text-blue-600"></i>Kimlik Dogrulama Turu
                    </label>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-white rounded-xl border-2 border-gray-200 p-4 cursor-pointer transition-all duration-200 hover:border-blue-600 hover:shadow-md" onclick="selectAuth('windows')">
                            <div class="flex items-center space-x-3">
                                <input type="radio" name="authType" value="windows" id="authWindows" class="w-5 h-5 text-blue-600">
                                <div>
                                    <h4 class="font-semibold text-gray-900">Windows Authentication</h4>
                                    <p class="text-sm text-gray-500">Güvenli, şifre gerektirmez</p>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white rounded-xl border-2 border-blue-500 p-4 cursor-pointer transition-all duration-200 hover:border-blue-600 hover:shadow-md" onclick="selectAuth('sql')">
                            <div class="flex items-center space-x-3">
                                <input type="radio" name="authType" value="sql" id="authSql" class="w-5 h-5 text-blue-600" checked>
                                <div>
                                    <h4 class="font-semibold text-gray-900">SQL Server Authentication</h4>
                                    <p class="text-sm text-gray-500">Kullanıcı adı ve şifre ile</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="sqlAuthFields" class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-user mr-2 text-blue-600"></i>Kullanıcı Adı
                        </label>
                        <input type="text" id="username" value="sa"
                               class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-3">
                            <i class="fas fa-lock mr-2 text-blue-600"></i>Şifre
                        </label>
                        <input type="password" id="password" value="fe9610578+*"
                               class="w-full px-4 py-4 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-600 focus:border-blue-600 text-lg">
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-3">
                        <i class="fas fa-link mr-2 text-blue-600"></i>Olusturulan Baglanti String
                    </label>
                    <textarea name="ConnString" id="connString" required rows="4" readonly
                              class="w-full px-4 py-4 border border-gray-300 rounded-xl bg-gray-50 font-mono text-sm text-gray-700"></textarea>
                    <p class="text-xs text-gray-500 mt-2">Bu alan otomatik olarak olusturulur</p>
                </div>
            </div>

            <div class="flex items-center space-x-3">
                <input type="hidden" name="IsActive" value="false">
                <input type="checkbox" name="IsActive" value="true" @(Model.DataSource.IsActive ? "checked" : "")
                       class="w-5 h-5 text-brand focus:ring-brand border-gray-300 rounded">
                <label class="text-lg font-medium text-gray-700">Veri kaynagini aktif olarak isaretle</label>
            </div>

            <div class="flex items-center justify-between pt-6 border-t border-gray-200">
                <a href="/Admin" class="btn-brand-outline flex items-center px-6 py-3 text-lg font-medium rounded-xl">
                    <i class="fas fa-arrow-left mr-2"></i>Geri Don
                </a>

                <div class="flex space-x-4">
                    <button type="button" class="bg-gray-100 text-gray-700 hover:bg-gray-200 px-6 py-3 rounded-xl font-medium transition-brand">
                        <i class="fas fa-plug mr-2"></i>Baglantiyi Test Et
                    </button>
                    <button type="submit" class="btn-brand flex items-center px-8 py-3 text-lg font-semibold rounded-xl shadow-brand-lg">
                        <i class="fas fa-save mr-3"></i>Veri Kaynagini Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
<script src="~/assets/js/admin-datasource-form.js"></script>
