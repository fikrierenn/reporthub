@*
    V2 builder SP çıktı önizleme modalı.
    Builder root x-data="builderV2" component'i içinde render edilir; rsViewerMixin'den
    rsModal / openRsModal / selectRsTab / closeRsModal kullanılır.
    Topbar "Veri Setleri" butonu veya footer rozet $dispatch('builder-rs-open') ile açar.
*@

<div @@builder-rs-open.window="openRsModal($event.detail && typeof $event.detail.idx === 'number' ? $event.detail.idx : 0)"
     style="display:none;"></div>

<div x-show="rsModal && rsModal.open" x-cloak
     class="fixed inset-0 z-40 flex items-center justify-center"
     style="background:rgba(15, 23, 42, 0.5);"
     @@click.self="closeRsModal()">
    <div class="rounded-xl shadow-xl bg-white border border-slate-200"
         style="width: min(1100px, 95vw); max-height: 88vh; display:flex; flex-direction:column;">

        <div class="flex items-center justify-between px-5 py-3 border-b border-slate-200">
            <h2 class="text-sm font-semibold text-slate-800">
                <i class="fas fa-database text-[12px]"></i> SP Çıktıları
                <span class="text-slate-400 font-normal text-xs ml-2"
                      x-text="(spPreview && spPreview.resultSets ? spPreview.resultSets.length : 0) + ' veri seti'"></span>
            </h2>
            <button type="button" @@click="closeRsModal()"
                    class="text-slate-500 hover:text-slate-800" title="Kapat (Esc)">
                <i class="fas fa-xmark"></i>
            </button>
        </div>

        @* RS sekme bar *@
        <div style="display:flex; gap:4px; padding:8px 14px 0; border-bottom:1px solid var(--line); overflow-x:auto;">
            <template x-for="(rs, i) in (spPreview && spPreview.resultSets ? spPreview.resultSets : [])" :key="i">
                <button type="button"
                        @@click="selectRsTab(i)"
                        style="padding:6px 12px; font-size:12px; border:1px solid transparent; border-bottom:none; border-radius:6px 6px 0 0; cursor:pointer; white-space:nowrap;"
                        :style="rsModal.activeIdx === i
                                ? 'background:white; border-color:var(--line); border-bottom:1px solid white; color:var(--ink-1); font-weight:600;'
                                : 'background:transparent; color:var(--ink-3);'">
                    <span x-text="rsTabLabel(rs, i)"></span>
                    <span class="text-[10px] opacity-60 ml-1"
                          x-text="'(' + (rs.rows || []).length + ')'"></span>
                </button>
            </template>
        </div>

        @* Aktif RS tablosu *@
        <div style="flex:1; overflow:auto; padding:12px 14px;">
            <template x-if="rsActiveColumns().length === 0">
                <p class="text-sm text-slate-500" style="padding:20px; text-align:center;">
                    <i class="fas fa-circle-info text-[11px]"></i>
                    Bu veri setinde kolon bulunmuyor — SP boş RS döndürmüş olabilir.
                </p>
            </template>
            <template x-if="rsActiveColumns().length > 0">
                <div>
                    <div class="text-[10px] text-slate-500 mb-2">
                        <span x-text="rsActiveColumns().length + ' kolon'"></span>
                        ·
                        <span x-text="rsActiveTotalRows() + ' toplam satır'"></span>
                        <span x-show="rsActiveTotalRows() > 50" class="text-amber-600">
                            (ilk 50 gösteriliyor)
                        </span>
                    </div>
                    <table class="dt" style="font-size:11px; width:100%;">
                        <thead>
                            <tr>
                                <template x-for="col in rsActiveColumns()" :key="col">
                                    <th style="white-space:nowrap; padding:4px 8px; background:#f8fafc; border-bottom:1px solid var(--line); position:sticky; top:0;">
                                        <div class="text-[11px]" x-text="col"></div>
                                        <div class="text-[9px] text-slate-400 font-normal mt-0.5"
                                             x-text="rsActiveRows()[0] ? columnKindFor(col) : ''"></div>
                                    </th>
                                </template>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="(row, ri) in rsActiveRows()" :key="ri">
                                <tr>
                                    <template x-for="col in rsActiveColumns()" :key="col">
                                        <td style="padding:3px 8px; border-bottom:1px solid var(--line-2); white-space:nowrap;"
                                            :style="rsCellAlign(row, col) === 'right' ? 'text-align:right; font-variant-numeric:tabular-nums;' : ''"
                                            x-text="rsCellValue(row, col)"></td>
                                    </template>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </template>
        </div>

        <div class="flex items-center justify-between gap-2 px-5 py-3 border-t border-slate-200" style="background:#f8fafc; font-size:11px; color:var(--ink-3);">
            <span>
                <i class="fas fa-circle-info text-[10px]"></i>
                Bu önizleme draft config'den bağımsız ham SP çıktısıdır. Tam render için "Tam Önizle".
            </span>
            <button type="button" class="btn ghost" @@click="closeRsModal()">Kapat</button>
        </div>
    </div>
</div>
