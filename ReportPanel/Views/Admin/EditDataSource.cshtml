@model ReportPanel.ViewModels.AdminDataSourceFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = $"Düzenle: {Model.DataSource.DataSourceKey} - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Veri Kaynağı Düzenle";
    var ds = Model.DataSource;
}

@section Breadcrumb {
    <div class="crumbs">
        <a href="/Dashboard">BKM Kitap</a>
        <span class="sep">/</span>
        <a href="/Admin">Yönetim</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=datasources">Veri Kaynakları</a>
        <span class="sep">/</span>
        <span class="current">@ds.DataSourceKey</span>
    </div>
}

@section TopActions {
    <a href="/Admin?tab=datasources" class="btn">
        <i class="fas fa-xmark text-[10px]"></i>
        İptal
    </a>
}

<div class="hero">
    <h1>Veri Kaynağı Düzenle</h1>
    <div class="sub">
        <span class="pill"><span class="mono">@ds.DataSourceKey</span></span>
        <span>@ds.Title</span>
        <span class="pill" style="@(ds.IsActive ? "" : "background:rgba(220,38,38,0.06); border-color:rgba(220,38,38,0.2);")">
            <span class="dot" style="background:@(ds.IsActive ? "var(--ok)" : "var(--danger)");"></span>
            @(ds.IsActive ? "Aktif" : "Pasif")
        </span>
    </div>
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" id="initialConnString" value="@ds.ConnString" />

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; max-width:880px; margin-bottom:18px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-tag" style="margin-right:6px; color:var(--ink-3);"></i>
                Genel Bilgiler
            </h2>
        </div>
        <div style="padding:20px;">
            <div style="display:grid; grid-template-columns:1fr 2fr; gap:14px;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Anahtar</label>
                    <input type="text" value="@ds.DataSourceKey" disabled class="inp" style="background:var(--canvas); color:var(--ink-3); cursor:not-allowed; font-family:'JetBrains Mono', monospace;" />
                    <input type="hidden" name="DataSourceKey" value="@ds.DataSourceKey" />
                    <p style="margin:6px 0 0; font-size:11px; color:var(--ink-3);">Anahtar değiştirilemez</p>
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Başlık <span style="color:var(--accent);">*</span></label>
                    <input type="text" name="Title" value="@ds.Title" required class="inp" placeholder="örn: Ana Veritabanı" />
                </div>
            </div>
        </div>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; max-width:880px; margin-bottom:18px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-server" style="margin-right:6px; color:var(--ink-3);"></i>
                Veritabanı Bağlantı Ayarları
            </h2>
        </div>
        <div style="padding:20px;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Sunucu Adı <span style="color:var(--accent);">*</span></label>
                    <input type="text" id="serverName" class="inp" placeholder="örn: BT-FIKRI\SQLEXPRESS" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Veritabanı Adı <span style="color:var(--accent);">*</span></label>
                    <input type="text" id="databaseName" class="inp" placeholder="örn: PortalHUB" />
                    <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:8px;">
                        <button type="button" onclick="setDatabase('PortalHUB')" class="btn ghost" style="font-size:11px; padding:0 10px; height:26px;">PortalHUB</button>
                        <button type="button" onclick="setDatabase('BKM_GENEL')" class="btn ghost" style="font-size:11px; padding:0 10px; height:26px;">BKM_GENEL</button>
                        <button type="button" onclick="setDatabase('MainDB')" class="btn ghost" style="font-size:11px; padding:0 10px; height:26px;">MainDB</button>
                        <button type="button" onclick="setDatabase('MaliDB')" class="btn ghost" style="font-size:11px; padding:0 10px; height:26px;">MaliDB</button>
                    </div>
                </div>
            </div>

            <div class="field" style="margin-bottom:14px;">
                <label class="lab">Kimlik Doğrulama</label>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                    <label class="opt-card" onclick="selectAuth('windows')">
                        <input type="radio" name="authType" value="windows" id="authWindows" />
                        <div>
                            <div class="t">Windows Authentication</div>
                            <div class="s">Güvenli, şifre gerektirmez</div>
                        </div>
                    </label>
                    <label class="opt-card" onclick="selectAuth('sql')">
                        <input type="radio" name="authType" value="sql" id="authSql" />
                        <div>
                            <div class="t">SQL Server Authentication</div>
                            <div class="s">Kullanıcı adı + şifre ile</div>
                        </div>
                    </label>
                </div>
            </div>

            <div id="sqlAuthFields" style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Kullanıcı Adı</label>
                    <input type="text" id="username" value="sa" class="inp" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Şifre</label>
                    <input type="password" id="password" class="inp" autocomplete="off" />
                </div>
            </div>

            <div class="field" style="margin-bottom:0;">
                <label class="lab">Oluşturulan Bağlantı String <i class="fas fa-circle-info" style="font-size:10px; color:var(--ink-4); margin-left:4px;" title="Bu alan otomatik oluşturulur"></i></label>
                <textarea name="ConnString" id="connString" required rows="3" readonly class="inp" style="height:auto; padding:10px 12px; font-family:'JetBrains Mono', monospace; font-size:12px; background:var(--canvas); color:var(--ink-2); resize:vertical;">@ds.ConnString</textarea>
            </div>
        </div>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:14px 20px; max-width:880px; margin-bottom:18px; display:flex; align-items:center; gap:10px;">
        <input type="hidden" name="IsActive" value="false" />
        <input type="checkbox" name="IsActive" value="true" id="dsActive" @(ds.IsActive ? "checked" : "")
               style="width:16px; height:16px; accent-color:var(--accent);" />
        <label for="dsActive" class="lab" style="margin:0;">Veri kaynağını aktif yap</label>
    </div>

    <div style="display:flex; align-items:center; justify-content:space-between; max-width:880px; padding:14px 20px; background:var(--paper); border:1px solid var(--line); border-radius:10px;">
        <a href="/Admin?tab=datasources" class="btn ghost">
            <i class="fas fa-arrow-left text-[10px]"></i>
            Geri Dön
        </a>
        <button type="submit" class="btn primary">
            <i class="fas fa-check text-[10px]"></i>
            Değişiklikleri Kaydet
        </button>
    </div>
</form>

<form method="post" action="/Admin" style="margin-top:14px; max-width:880px;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="action" value="test_datasource" />
    <input type="hidden" name="key" value="@ds.DataSourceKey" />
    <button type="submit" class="btn">
        <i class="fas fa-plug text-[10px]"></i>
        Bağlantıyı Test Et
    </button>
</form>

<script src="~/assets/js/admin-datasource-form.js"></script>
