@model ReportPanel.ViewModels.AdminUserFormViewModel
@using System.Linq
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Kullanıcı Düzenle - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Kullanıcı Düzenle";
    var message = Model.Message ?? "";
    var messageType = Model.MessageType ?? "";
    var availableRoles = Model.AvailableRoles ?? new List<ReportPanel.Models.Role>();
    var selectedRoleIds = Model.SelectedRoleIds ?? new HashSet<int>();
    var user = Model.User ?? new ReportPanel.Models.User();
    var dataSources = Model.DataSources ?? new List<ReportPanel.Models.DataSource>();
}

@section Breadcrumb {
    <div class="crumbs">
        <a href="/Dashboard">BKM Kitap</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=users">Yönetim</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=users">Kullanıcılar</a>
        <span class="sep">/</span>
        <span class="current">@(string.IsNullOrWhiteSpace(user.Username) ? "Düzenle" : user.Username)</span>
    </div>
}

@section TopActions {
    <a href="/Admin?tab=users" class="btn">
        <i class="fas fa-xmark text-[10px]"></i>
        İptal
    </a>
}

<div class="hero">
    <h1>Kullanıcı Düzenle</h1>
    <div class="sub">
        <span>Kullanıcı bilgilerini güncelleyin</span>
        <span class="pill"><span class="mono">@user.Username</span></span>
        @if (user.IsAdUser)
        {
            <span class="pill"><i class="fas fa-windows" style="font-size:9px; color:var(--ink-3);"></i> AD</span>
        }
        <span class="pill" style="@(user.IsActive ? "" : "background:rgba(220,38,38,0.06); border-color:rgba(220,38,38,0.2);")">
            <span class="dot" style="background:@(user.IsActive ? "var(--ok)" : "var(--danger)");"></span>
            @(user.IsActive ? "Aktif" : "Pasif")
        </span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div role="alert" style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                background: @(messageType == "success" ? "rgba(16,185,129,0.10)" : "rgba(220,38,38,0.10)");
                border: 1px solid @(messageType == "success" ? "rgba(16,185,129,0.25)" : "rgba(220,38,38,0.25)");
                color: @(messageType == "success" ? "#065f46" : "var(--accent-ink)");">
        <i class="fas @(messageType == "success" ? "fa-check-circle" : "fa-exclamation-circle")" style="margin-right:8px;"></i>
        @message
    </div>
}

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="UserId" value="@user.UserId" />

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; max-width:880px; margin-bottom:18px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-user-pen" style="margin-right:6px; color:var(--ink-3);"></i>
                Kullanıcı Bilgileri
            </h2>
            <div style="font-size:12px; color:var(--ink-3); margin-top:2px;">Hesap detayları + roller + şifre</div>
        </div>

        <div style="padding:20px;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Kullanıcı Adı <span style="color:var(--accent);">*</span></label>
                    <input type="text" name="Username" value="@user.Username" required class="inp" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Ad Soyad <span style="color:var(--accent);">*</span></label>
                    <input type="text" name="FullName" value="@user.FullName" required class="inp" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">E-posta</label>
                    <input type="email" name="Email" value="@user.Email" class="inp" placeholder="ornek@bkmkitap.com" />
                </div>
                <div class="field" style="margin-bottom:0;">
                    <label class="lab">Roller <span style="color:var(--accent);">*</span></label>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; padding:8px 10px; background:var(--canvas); border:1px solid var(--line); border-radius:8px;">
                        @if (!availableRoles.Any())
                        {
                            <div style="font-size:12px; color:var(--accent-ink);">Rol listesi tanımlı değil.</div>
                        }
                        else
                        {
                            foreach (var role in availableRoles)
                            {
                                var isChecked = selectedRoleIds.Contains(role.RoleId);
                                <label style="display:flex; align-items:center; gap:6px; font-size:12px; color:var(--ink-2); cursor:pointer;">
                                    <input type="checkbox" name="SelectedRoles" value="@role.RoleId" @(isChecked ? "checked" : "")
                                           style="width:14px; height:14px; accent-color:var(--accent);" />
                                    <span>@role.Name</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="field" style="margin-bottom:14px;">
                <label class="lab">Yeni Şifre</label>
                <input type="password" id="Password" name="Password" class="inp" placeholder="Boş bırakırsanız şifre değişmez" autocomplete="new-password" />
            </div>

            <div style="display:flex; flex-wrap:wrap; gap:18px; padding-top:8px;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="hidden" name="IsAdUser" value="false" />
                    <input type="checkbox" id="IsAdUser" name="IsAdUser" value="true" @(user.IsAdUser ? "checked" : "")
                           style="width:16px; height:16px; accent-color:var(--accent);" />
                    <label for="IsAdUser" class="lab" style="margin:0;">Windows AD kullanıcısı</label>
                    <span style="font-size:11px; color:var(--ink-3);" title="AD kullanıcıları DOMAIN\\kullanici ile giriş yapar">
                        <i class="fas fa-circle-info"></i>
                    </span>
                </div>
                <div style="display:flex; align-items:center; gap:8px;">
                    <input type="hidden" name="IsActive" value="false" />
                    <input type="checkbox" id="userActive" name="IsActive" value="true" @(user.IsActive ? "checked" : "")
                           style="width:16px; height:16px; accent-color:var(--accent);" />
                    <label for="userActive" class="lab" style="margin:0;">Kullanıcıyı aktif yap</label>
                </div>
            </div>
        </div>
    </div>

    @* ===== Veri Filtreleri ===== *@
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; max-width:880px; margin-bottom:18px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
                <i class="fas fa-filter" style="margin-right:6px; color:var(--ink-3);"></i>
                Veri Filtreleri
            </h2>
            <div style="font-size:12px; color:var(--ink-3); margin-top:2px;">
                Kullanıcının görebileceği veriler. Boş = tüm veriler. Aynı tip = VEYA, farklı tip = VE.
            </div>
        </div>
        <div style="padding:18px 20px;">
            <div id="filterList" style="display:flex; flex-direction:column; gap:8px; margin-bottom:12px;"></div>
            <button type="button" id="addFilterBtn" class="btn ghost" style="font-size:12px;">
                <i class="fas fa-circle-plus text-[10px]"></i>
                Filtre Ekle
            </button>
        </div>
    </div>

    <div style="display:flex; align-items:center; justify-content:space-between; max-width:880px; padding:14px 20px; background:var(--paper); border:1px solid var(--line); border-radius:10px;">
        <a href="/Admin?tab=users" class="btn ghost">
            <i class="fas fa-arrow-left text-[10px]"></i>
            Geri Dön
        </a>
        <button type="submit" class="btn primary">
            <i class="fas fa-check text-[10px]"></i>
            Kullanıcıyı Güncelle
        </button>
    </div>
</form>

<script>
    (function () {
        const adToggle = document.getElementById('IsAdUser');
        const passwordInput = document.getElementById('Password');
        if (!adToggle || !passwordInput) return;

        const syncPasswordState = () => {
            if (adToggle.checked) {
                passwordInput.value = '';
                passwordInput.disabled = true;
                passwordInput.removeAttribute('required');
            } else {
                passwordInput.disabled = false;
            }
        };

        adToggle.addEventListener('change', syncPasswordState);
        syncPasswordState();
    })();

    var dsOptions = '<option value="">Tüm kaynaklar</option>' +
        @Html.Raw("'" + string.Join("' + '", dataSources.Select(ds => $"<option value=\"{ds.DataSourceKey}\">{ds.Title}</option>")) + "'");

    function createFilterRow(selectedKey, selectedValue, selectedDs) {
        var row = document.createElement('div');
        row.style.cssText = 'display:flex; align-items:center; gap:8px;';

        var keySelect = document.createElement('select');
        keySelect.name = 'FilterKeys';
        keySelect.className = 'inp';
        keySelect.style.cssText = 'width:140px; flex-shrink:0;';
        keySelect.innerHTML = '<option value="sube">Şube</option><option value="bolum">Bölüm</option><option value="bolge">Bölge</option>' +
            '<option value="kategori">Kategori</option><option value="maliyet_merkezi">Maliyet Merkezi</option>';
        if (selectedKey) keySelect.value = selectedKey;

        var valueSelect = document.createElement('select');
        valueSelect.name = 'FilterValues';
        valueSelect.className = 'inp';
        valueSelect.style.cssText = 'flex:1;';
        valueSelect.innerHTML = '<option value="">Yükleniyor...</option>';

        var dsSelect = document.createElement('select');
        dsSelect.name = 'FilterDataSources';
        dsSelect.className = 'inp';
        dsSelect.style.cssText = 'width:160px; flex-shrink:0;';
        dsSelect.innerHTML = dsOptions;
        if (selectedDs) dsSelect.value = selectedDs;

        var delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.className = 'btn ghost';
        delBtn.style.cssText = 'color:var(--accent-ink); flex-shrink:0;';
        delBtn.innerHTML = '<i class="fas fa-trash text-[10px]"></i>';
        delBtn.title = 'Filtreyi sil';
        delBtn.onclick = function() { row.remove(); };

        row.appendChild(keySelect);
        row.appendChild(valueSelect);
        row.appendChild(dsSelect);
        row.appendChild(delBtn);

        function loadOptions() {
            var key = keySelect.value;
            var ds = dsSelect.value;
            var url = '/Admin/FilterOptions?filterKey=' + encodeURIComponent(key);
            if (ds) url += '&dataSourceKey=' + encodeURIComponent(ds);

            fetch(url)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    var opts = '<option value="">Seçiniz...</option>';
                    if (data.options && data.options.length > 0) {
                        data.options.forEach(function(o) {
                            var sel = (selectedValue && o.value === selectedValue) ? ' selected' : '';
                            opts += '<option value="' + o.value + '"' + sel + '>' + o.label + '</option>';
                        });
                    } else {
                        opts = '<option value="">Liste boş</option>';
                    }
                    valueSelect.innerHTML = opts;
                    selectedValue = null;
                })
                .catch(function() {
                    valueSelect.innerHTML = '<option value="">Hata</option>';
                });
        }

        keySelect.addEventListener('change', loadOptions);
        dsSelect.addEventListener('change', loadOptions);
        loadOptions();

        return row;
    }

    var existingFilters = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.DataFilters.Select(f => new { key = f.FilterKey, value = f.FilterValue, ds = f.DataSourceKey ?? "" })));
    var filterListEl = document.getElementById('filterList');
    existingFilters.forEach(function(f) {
        filterListEl.appendChild(createFilterRow(f.key, f.value, f.ds));
    });

    document.getElementById('addFilterBtn').addEventListener('click', function() {
        filterListEl.appendChild(createFilterRow(null, null, null));
    });
</script>
