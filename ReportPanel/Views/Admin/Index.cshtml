@model ReportPanel.ViewModels.AdminIndexViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Yönetim Paneli - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Yönetim Paneli";
    var tab = Model.ActiveTab ?? "datasources";

    string TabClass(string name) => tab == name ? "active" : "";
}

<div class="hero">
    <h1>Yönetim Paneli</h1>
    <div class="sub">
        <span>Veri kaynakları, raporlar, kullanıcılar, roller ve kategoriler</span>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div role="alert" style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                background: @(Model.MessageType == "success" ? "rgba(16,185,129,0.10)" : "rgba(220,38,38,0.10)");
                border: 1px solid @(Model.MessageType == "success" ? "rgba(16,185,129,0.25)" : "rgba(220,38,38,0.25)");
                color: @(Model.MessageType == "success" ? "#065f46" : "var(--accent-ink)");">
        <i class="fas @(Model.MessageType == "success" ? "fa-check-circle" : "fa-exclamation-circle")" style="margin-right:8px;"></i>
        @Model.Message
    </div>
}

<nav class="subnav" aria-label="Yönetim alt-navigasyonu">
    <a href="/Admin?tab=datasources" class="@TabClass("datasources")">
        <i class="fas fa-database"></i>
        <span>Veri Kaynakları</span>
        <span class="count">@Model.DataSources.Count</span>
    </a>
    <a href="/Admin?tab=reports" class="@TabClass("reports")">
        <i class="fas fa-file-lines"></i>
        <span>Rapor Kataloğu</span>
        <span class="count">@Model.Reports.Count</span>
    </a>
    <a href="/Admin?tab=users" class="@TabClass("users")">
        <i class="fas fa-users"></i>
        <span>Kullanıcılar</span>
        <span class="count">@Model.Users.Count</span>
    </a>
    <a href="/Admin?tab=roles" class="@TabClass("roles")">
        <i class="fas fa-shield-halved"></i>
        <span>Roller</span>
        <span class="count">@Model.Roles.Count</span>
    </a>
    <a href="/Admin?tab=groups" class="@TabClass("groups")">
        <i class="fas fa-folder-tree"></i>
        <span>Gruplar</span>
        <span class="count">@Model.Groups.Count</span>
    </a>
    <a href="/Admin?tab=filters" class="@TabClass("filters")">
        <i class="fas fa-filter"></i>
        <span>Filtreler</span>
        <span class="count">@Model.FilterDefinitions.Count</span>
    </a>
</nav>

@switch (tab)
{
    case "reports":     @await Html.PartialAsync("_AdminTabReports", Model);     break;
    case "users":       @await Html.PartialAsync("_AdminTabUsers", Model);       break;
    case "roles":       @await Html.PartialAsync("_AdminTabRoles", Model);       break;
    case "groups":      @await Html.PartialAsync("_AdminTabGroups", Model);      break;
    case "filters":     @await Html.PartialAsync("_AdminTabFilters", Model);     break;
    default:            @await Html.PartialAsync("_AdminTabDataSources", Model); break;
}
