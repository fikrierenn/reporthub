@model ReportPanel.ViewModels.AdminIndexViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Yönetim Paneli - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Yönetim Paneli";
    var tab = Model.ActiveTab ?? "datasources";

    string TabClass(string name) => tab == name ? "active" : "";
}

@functions {
    private static string MaskConnString(string? connString)
    {
        if (string.IsNullOrWhiteSpace(connString)) return string.Empty;
        const int keepStart = 8;
        const int keepEnd = 6;
        if (connString.Length <= keepStart + keepEnd + 3)
        {
            return new string('*', connString.Length);
        }
        return connString.Substring(0, keepStart) + "..." + connString.Substring(connString.Length - keepEnd);
    }
}

<div class="hero">
    <h1>Yönetim Paneli</h1>
    <div class="sub">
        <span>Veri kaynakları, raporlar, kullanıcılar, roller ve kategoriler</span>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div role="alert" style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                background: @(Model.MessageType == "success" ? "rgba(16,185,129,0.10)" : "rgba(220,38,38,0.10)");
                border: 1px solid @(Model.MessageType == "success" ? "rgba(16,185,129,0.25)" : "rgba(220,38,38,0.25)");
                color: @(Model.MessageType == "success" ? "#065f46" : "var(--accent-ink)");">
        <i class="fas @(Model.MessageType == "success" ? "fa-check-circle" : "fa-exclamation-circle")" style="margin-right:8px;"></i>
        @Model.Message
    </div>
}

<nav class="subnav" aria-label="Yönetim alt-navigasyonu">
    <a href="/Admin?tab=datasources" class="@TabClass("datasources")">
        <i class="fas fa-database"></i>
        <span>Veri Kaynakları</span>
        <span class="count">@Model.DataSources.Count</span>
    </a>
    <a href="/Admin?tab=reports" class="@TabClass("reports")">
        <i class="fas fa-file-lines"></i>
        <span>Rapor Kataloğu</span>
        <span class="count">@Model.Reports.Count</span>
    </a>
    <a href="/Admin?tab=users" class="@TabClass("users")">
        <i class="fas fa-users"></i>
        <span>Kullanıcılar</span>
        <span class="count">@Model.Users.Count</span>
    </a>
    <a href="/Admin?tab=roles" class="@TabClass("roles")">
        <i class="fas fa-shield-halved"></i>
        <span>Roller</span>
        <span class="count">@Model.Roles.Count</span>
    </a>
    <a href="/Admin?tab=categories" class="@TabClass("categories")">
        <i class="fas fa-folder-tree"></i>
        <span>Kategoriler</span>
        <span class="count">@Model.Categories.Count</span>
    </a>
</nav>

@if (tab == "datasources")
{
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
        <div style="font-size:12px; color:var(--ink-3);">Veritabanı bağlantılarını yönetin</div>
        <a href="/Admin/CreateDataSource" class="btn primary">
            <i class="fas fa-plus text-[10px]"></i>
            Yeni Veri Kaynağı
        </a>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
        <table class="dt">
            <thead>
                <tr>
                    <th>Anahtar</th>
                    <th>Başlık</th>
                    <th>Bağlantı</th>
                    <th>Durum</th>
                    <th style="text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ds in Model.DataSources)
                {
                    <tr>
                        <td><span class="mono">@ds.DataSourceKey</span></td>
                        <td>@ds.Title</td>
                        <td><span class="mono" style="font-size:11.5px; color:var(--ink-3);">@MaskConnString(ds.ConnString)</span></td>
                        <td>
                            <span class="status @(ds.IsActive ? "ok" : "err")">@(ds.IsActive ? "Aktif" : "Pasif")</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:inline-flex; gap:6px;">
                                <a href="/Admin/EditDataSource/@ds.DataSourceKey" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                    <i class="fas fa-pen text-[9px]"></i>
                                    Düzenle
                                </a>
                                <form method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="test_datasource" />
                                    <input type="hidden" name="key" value="@ds.DataSourceKey" />
                                    <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                        <i class="fas fa-plug text-[9px]"></i>
                                        Test
                                    </button>
                                </form>
                                <form method="post" style="display:inline;" onsubmit="return confirm('Bu veri kaynağını silmek istediğinizden emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="delete_datasource" />
                                    <input type="hidden" name="key" value="@ds.DataSourceKey" />
                                    <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                        <i class="fas fa-trash text-[9px]"></i>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (tab == "reports")
{
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
        <div style="font-size:12px; color:var(--ink-3);">Sistem raporlarını yönetin</div>
        <a href="/Admin/CreateReport" class="btn primary">
            <i class="fas fa-plus text-[10px]"></i>
            Yeni Rapor
        </a>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
        <table class="dt">
            <thead>
                <tr>
                    <th style="width:60px;">ID</th>
                    <th>Rapor</th>
                    <th>Veri Kaynağı</th>
                    <th>Prosedür</th>
                    <th>Kategori</th>
                    <th>Durum</th>
                    <th style="text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var report in Model.Reports)
                {
                    var reportCategories = report.ReportCategories
                        .Select(rc => rc.Category?.Name ?? "")
                        .Where(name => !string.IsNullOrWhiteSpace(name))
                        .ToList();
                    <tr>
                        <td><span class="mono">#@report.ReportId</span></td>
                        <td>
                            <div style="font-weight:500; color:var(--ink-1);">@report.Title</div>
                            @if (!string.IsNullOrWhiteSpace(report.Description))
                            {
                                <div style="font-size:11px; color:var(--ink-3); margin-top:2px;">@report.Description</div>
                            }
                        </td>
                        <td><span class="mono">@report.DataSourceKey</span></td>
                        <td><span class="mono" style="font-size:11.5px; color:var(--ink-3);">@report.ProcName</span></td>
                        <td style="font-size:12px; color:var(--ink-3);">@string.Join(", ", reportCategories)</td>
                        <td>
                            <span class="status @(report.IsActive ? "ok" : "err")">@(report.IsActive ? "Aktif" : "Pasif")</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:inline-flex; gap:6px;">
                                <a href="/Admin/EditReport/@report.ReportId" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                    <i class="fas fa-pen text-[9px]"></i>
                                    Düzenle
                                </a>
                                <form method="post" style="display:inline;" onsubmit="return confirm('Bu raporu silmek istediğinizden emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="delete_report" />
                                    <input type="hidden" name="id" value="@report.ReportId" />
                                    <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                        <i class="fas fa-trash text-[9px]"></i>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (tab == "users")
{
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
        <div style="font-size:12px; color:var(--ink-3);">Kullanıcıları ekleyin, güncelleyin ve pasif edin</div>
        <a href="/Admin/CreateUser" class="btn primary">
            <i class="fas fa-user-plus text-[10px]"></i>
            Yeni Kullanıcı
        </a>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
        <table class="dt">
            <thead>
                <tr>
                    <th>Kullanıcı</th>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Roller</th>
                    <th>Durum</th>
                    <th>Son Giriş</th>
                    <th style="text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td><span class="mono">@user.Username</span></td>
                        <td>@user.FullName</td>
                        <td style="font-size:12px; color:var(--ink-3);">@user.Email</td>
                        <td style="font-size:12px;">@(Model.UserRoleNames.TryGetValue(user.UserId, out var _roleNames) ? string.Join(", ", _roleNames) : "-")</td>
                        <td>
                            <span class="status @(user.IsActive ? "ok" : "err")">@(user.IsActive ? "Aktif" : "Pasif")</span>
                        </td>
                        <td><span class="ago">@(user.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</span></td>
                        <td style="text-align:right;">
                            <div style="display:inline-flex; gap:6px;">
                                <a href="/Admin/EditUser/@user.UserId" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                    <i class="fas fa-pen text-[9px]"></i>
                                    Düzenle
                                </a>
                                <form method="post" style="display:inline;" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinizden emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="delete_user" />
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                        <i class="fas fa-trash text-[9px]"></i>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (tab == "roles")
{
    @* Inline ekleme formu *@
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:16px 20px; margin-bottom:14px;">
        <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0 0 12px;">
            <i class="fas fa-circle-plus" style="margin-right:6px; color:var(--ink-3);"></i>
            Yeni Rol Ekle
        </h2>
        <form method="post" style="display:grid; grid-template-columns:1.5fr 2fr auto auto; gap:10px; align-items:end;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="action" value="create_role" />
            <div class="field" style="margin-bottom:0;">
                <label class="lab">Rol Adı <span style="color:var(--accent);">*</span></label>
                <input type="text" name="Name" class="inp" required />
            </div>
            <div class="field" style="margin-bottom:0;">
                <label class="lab">Açıklama</label>
                <input type="text" name="Description" class="inp" />
            </div>
            <div style="display:flex; align-items:center; gap:6px; height:34px;">
                <input type="hidden" name="IsActive" value="false" />
                <input type="checkbox" name="IsActive" value="true" id="newRoleActive" checked
                       style="width:16px; height:16px; accent-color:var(--accent);" />
                <label for="newRoleActive" class="lab" style="margin:0;">Aktif</label>
            </div>
            <button type="submit" class="btn primary">
                <i class="fas fa-plus text-[10px]"></i>
                Ekle
            </button>
        </form>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
        <table class="dt">
            <thead>
                <tr>
                    <th>Rol</th>
                    <th>Açıklama</th>
                    <th>Durum</th>
                    <th style="text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model.Roles)
                {
                    <tr>
                        <td style="font-weight:500; color:var(--ink-1);">@role.Name</td>
                        <td style="font-size:12px; color:var(--ink-3);">@role.Description</td>
                        <td>
                            <span class="status @(role.IsActive ? "ok" : "err")">@(role.IsActive ? "Aktif" : "Pasif")</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:inline-flex; gap:6px;">
                                <a href="/Admin/EditRole/@role.RoleId" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                    <i class="fas fa-pen text-[9px]"></i>
                                    Düzenle
                                </a>
                                <form method="post" style="display:inline;" onsubmit="return confirm('Rol silinsin mi?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="delete_role" />
                                    <input type="hidden" name="id" value="@role.RoleId" />
                                    <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                        <i class="fas fa-trash text-[9px]"></i>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (tab == "categories")
{
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:16px 20px; margin-bottom:14px;">
        <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0 0 12px;">
            <i class="fas fa-circle-plus" style="margin-right:6px; color:var(--ink-3);"></i>
            Yeni Kategori Ekle
        </h2>
        <form method="post" style="display:grid; grid-template-columns:1.5fr 2fr auto auto; gap:10px; align-items:end;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="action" value="create_category" />
            <div class="field" style="margin-bottom:0;">
                <label class="lab">Kategori Adı <span style="color:var(--accent);">*</span></label>
                <input type="text" name="Name" class="inp" required />
            </div>
            <div class="field" style="margin-bottom:0;">
                <label class="lab">Açıklama</label>
                <input type="text" name="Description" class="inp" />
            </div>
            <div style="display:flex; align-items:center; gap:6px; height:34px;">
                <input type="hidden" name="IsActive" value="false" />
                <input type="checkbox" name="IsActive" value="true" id="newCatActive" checked
                       style="width:16px; height:16px; accent-color:var(--accent);" />
                <label for="newCatActive" class="lab" style="margin:0;">Aktif</label>
            </div>
            <button type="submit" class="btn primary">
                <i class="fas fa-plus text-[10px]"></i>
                Ekle
            </button>
        </form>
    </div>

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
        <table class="dt">
            <thead>
                <tr>
                    <th>Kategori</th>
                    <th>Açıklama</th>
                    <th>Durum</th>
                    <th style="text-align:right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.Categories)
                {
                    <tr>
                        <td style="font-weight:500; color:var(--ink-1);">@category.Name</td>
                        <td style="font-size:12px; color:var(--ink-3);">@category.Description</td>
                        <td>
                            <span class="status @(category.IsActive ? "ok" : "err")">@(category.IsActive ? "Aktif" : "Pasif")</span>
                        </td>
                        <td style="text-align:right;">
                            <div style="display:inline-flex; gap:6px;">
                                <a href="/Admin/EditCategory/@category.CategoryId" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                    <i class="fas fa-pen text-[9px]"></i>
                                    Düzenle
                                </a>
                                <form method="post" style="display:inline;" onsubmit="return confirm('Kategori silinsin mi?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="delete_category" />
                                    <input type="hidden" name="id" value="@category.CategoryId" />
                                    <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                        <i class="fas fa-trash text-[9px]"></i>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
