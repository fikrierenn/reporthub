            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Kategori</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Aciklama</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Durum</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Islemler</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var category in Model.Categories)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">@category.Name</td>
                                <td class="px-6 py-4 text-sm text-gray-500">@category.Description</td>
                                <td class="px-6 py-4">
                                    @if (category.IsActive)
                                    {
                                        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            <div class="w-2 h-2 bg-green-500 rounded-full mr-2"></div>
                                            Aktif
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            <div class="w-2 h-2 bg-red-500 rounded-full mr-2"></div>
                                            Pasif
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-2">
                                        <a href="/Admin/EditCategory/@category.CategoryId"
                                           class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-700 hover:bg-blue-100 rounded-lg text-sm font-medium transition-colors duration-200">
                                            <i class="fas fa-edit mr-1.5"></i>
                                            Duzenle
                                        </a>
                                        <form method="post" class="inline" onsubmit="return confirm('Kategori silinsin mi?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="action" value="delete_category">
                                            <input type="hidden" name="id" value="@category.CategoryId">
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 bg-red-50 text-red-700 hover:bg-red-100 rounded-lg text-sm font-medium transition-colors duration-200">
                                                <i class="fas fa-trash mr-1.5"></i>
                                                Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (Model.ActiveTab == "users")
{
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-8 overflow-hidden">
        <div class="bg-gradient-to-r from-emerald-50 to-green-50 px-8 py-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-green-600 rounded-xl flex items-center justify-center shadow-lg">
                        <i class="fas fa-users text-white text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-gray-900">Kullanici Yonetimi</h3>
                        <p class="text-gray-600 text-sm">Kullanicilari ekleyin, guncelleyin ve pasif edin</p>
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-2xl font-bold text-gray-900">@Model.Users.Count</div>
                    <div class="text-sm text-gray-500">Toplam kullanici</div>
                </div>
            </div>
        </div>
        <div class="p-8">
            <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
                <div class="text-sm text-gray-500">Yeni kullanici ve rol tanimlayin</div>
                <a href="/Admin/CreateUser" class="btn-brand inline-flex items-center px-6 py-3 rounded-xl text-sm font-bold shadow-brand-lg hover:shadow-brand-xl transition-brand transform hover:scale-105">
                    <i class="fas fa-user-plus mr-2 text-base"></i>
                    Yeni Kullanici Ekle
                </a>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Kullanici</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Ad Soyad</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">E-posta</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Roller</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Durum</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Son Giris</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Islemler</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @foreach (var user in Model.Users)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">@user.Username</td>
                                <td class="px-6 py-4 text-sm text-gray-900">@user.FullName</td>
                                <td class="px-6 py-4 text-sm text-gray-500">@user.Email</td>
                                <td class="px-6 py-4 text-sm text-gray-500">@(Model.UserRoleNames.TryGetValue(user.UserId, out var _roleNames) ? string.Join(", ", _roleNames) : "-")</td>
                                <td class="px-6 py-4">
                                    @if (user.IsActive)
                                    {
                                        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            <div class="w-2 h-2 bg-green-500 rounded-full mr-2"></div>
                                            Aktif
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            <div class="w-2 h-2 bg-red-500 rounded-full mr-2"></div>
                                            Pasif
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">@(user.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-2">
                                        <a href="/Admin/EditUser/@user.UserId"
                                           class="inline-flex items-center px-3 py-1.5 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 rounded-lg text-sm font-medium transition-colors duration-200">
                                            <i class="fas fa-edit mr-1.5"></i>
                                            Duzenle
                                        </a>
                                        <form method="post" class="inline" onsubmit="return confirm('Bu kullaniciyi silmek istediginizden emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="action" value="delete_user">
                                            <input type="hidden" name="id" value="@user.UserId">
                                            <button type="submit"
                                                    class="inline-flex items-center px-3 py-1.5 bg-red-50 text-red-700 hover:bg-red-100 rounded-lg text-sm font-medium transition-colors duration-200">
                                                <i class="fas fa-trash mr-1.5"></i>
                                                Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
