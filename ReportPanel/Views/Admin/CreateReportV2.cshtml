<script src="~/assets/js/builder-v2/builder-drawer.js" asp-append-version="true"></script>
<script src="~/assets/js/builder-v2/builder-settings.js" asp-append-version="true"></script>
<script src="~/assets/js/builder-v2/builder-tabs.js" asp-append-version="true"></script>
<script src="~/assets/js/builder-v2/builder-preview.js" asp-append-version="true"></script>
<script src="~/assets/js/builder-v2/builder.js" asp-append-version="true"></script>
