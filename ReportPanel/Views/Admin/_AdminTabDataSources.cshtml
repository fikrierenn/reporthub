@model ReportPanel.ViewModels.AdminIndexViewModel
@functions {
    private static string MaskConnString(string? connString)
    {
        if (string.IsNullOrWhiteSpace(connString)) return string.Empty;
        const int keepStart = 8;
        const int keepEnd = 6;
        if (connString.Length <= keepStart + keepEnd + 3)
        {
            return new string('*', connString.Length);
        }
        return connString.Substring(0, keepStart) + "..." + connString.Substring(connString.Length - keepEnd);
    }
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
    <div style="font-size:12px; color:var(--ink-3);">Veritabanı bağlantılarını yönetin</div>
    <a href="/Admin/CreateDataSource" class="btn primary">
        <i class="fas fa-plus text-[10px]"></i>
        Yeni Veri Kaynağı
    </a>
</div>

<div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
    <table class="dt">
        <thead>
            <tr>
                <th>Anahtar</th>
                <th>Başlık</th>
                <th>Bağlantı</th>
                <th>Durum</th>
                <th style="text-align:right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ds in Model.DataSources)
            {
                <tr>
                    <td><span class="mono">@ds.DataSourceKey</span></td>
                    <td>@ds.Title</td>
                    <td><span class="mono" style="font-size:11.5px; color:var(--ink-3);">@MaskConnString(ds.ConnString)</span></td>
                    <td>
                        <span class="status @(ds.IsActive ? "ok" : "err")">@(ds.IsActive ? "Aktif" : "Pasif")</span>
                    </td>
                    <td style="text-align:right;">
                        <div style="display:inline-flex; gap:6px;">
                            <a href="/Admin/EditDataSource/@ds.DataSourceKey" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                <i class="fas fa-pen text-[9px]"></i>
                                Düzenle
                            </a>
                            <form method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="action" value="test_datasource" />
                                <input type="hidden" name="key" value="@ds.DataSourceKey" />
                                <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                    <i class="fas fa-plug text-[9px]"></i>
                                    Test
                                </button>
                            </form>
                            <form method="post" style="display:inline;" onsubmit="return confirm('Bu veri kaynağını silmek istediğinizden emin misiniz?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="action" value="delete_datasource" />
                                <input type="hidden" name="key" value="@ds.DataSourceKey" />
                                <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                    <i class="fas fa-trash text-[9px]"></i>
                                    Sil
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
