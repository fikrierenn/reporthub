@model ReportPanel.ViewModels.AdminCategoryFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Kategori Duzenle - BKM Rapor Paneli";
    var message = Model.Message ?? "";
    var messageType = Model.MessageType ?? "";
    var category = Model.Category ?? new ReportPanel.Models.ReportCategory();
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Kategori Duzenle</h1>
        <p class="text-sm text-gray-500">Kategori bilgilerini guncelleyin</p>
    </div>
    <a href="/Admin?tab=categories" class="btn-brand-outline flex items-center px-4 py-2 text-sm font-medium rounded-lg">
        <i class="fas fa-times mr-2"></i>Iptal
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="mb-6">
        <div class="@(messageType == "success" ? "bg-green-100 border-green-400 text-green-700" : "bg-red-100 border-red-400 text-red-700") px-4 py-3 rounded border">
            @message
        </div>
    </div>
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-amber-50 to-yellow-50 px-8 py-6 border-b border-gray-100">
        <div class="flex items-center space-x-4">
            <div class="w-12 h-12 bg-amber-600 rounded-xl flex items-center justify-center shadow-lg">
                <i class="fas fa-folder-open text-white text-xl"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Kategori Bilgileri</h2>
                <p class="text-gray-600">Degisiklikleri kaydedin</p>
            </div>
        </div>
    </div>

    <div class="p-8">
        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CategoryId" value="@category.CategoryId" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Kategori Adi *</label>
                    <input type="text" name="Name" value="@category.Name" required
                           class="form-input-brand w-full px-4 py-3 rounded-lg">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Aciklama</label>
                    <input type="text" name="Description" value="@category.Description"
                           class="form-input-brand w-full px-4 py-3 rounded-lg">
                </div>
            </div>

            <div class="flex items-center space-x-3">
                <input type="hidden" name="IsActive" value="false">
                <input type="checkbox" name="IsActive" value="true" @(category.IsActive ? "checked" : "")
                       class="w-5 h-5 text-brand focus:ring-brand border-gray-300 rounded">
                <label class="text-sm font-medium text-gray-700">Kategoriyi aktif yap</label>
            </div>

            <div class="flex items-center justify-between pt-6 border-t border-gray-200">
                <a href="/Admin?tab=categories" class="btn-brand-outline flex items-center px-6 py-3 text-sm font-medium rounded-lg">
                    <i class="fas fa-arrow-left mr-2"></i>Geri Don
                </a>
                <button type="submit" class="btn-brand flex items-center px-6 py-3 text-sm font-semibold rounded-lg">
                    <i class="fas fa-save mr-2"></i>Kategori Guncelle
                </button>
            </div>
        </form>
    </div>
</div>
