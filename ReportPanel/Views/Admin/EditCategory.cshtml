@model ReportPanel.ViewModels.AdminCategoryFormViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Kategori Düzenle - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Kategori Düzenle";
    var message = Model.Message ?? "";
    var messageType = Model.MessageType ?? "";
    var category = Model.Category ?? new ReportPanel.Models.ReportCategory();
}

@section Breadcrumb {
    <div class="crumbs">
        <a href="/Dashboard">BKM Kitap</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=categories">Yönetim</a>
        <span class="sep">/</span>
        <a href="/Admin?tab=categories">Kategoriler</a>
        <span class="sep">/</span>
        <span class="current">@(string.IsNullOrWhiteSpace(category.Name) ? "Düzenle" : category.Name)</span>
    </div>
}

@section TopActions {
    <a href="/Admin?tab=categories" class="btn">
        <i class="fas fa-xmark text-[10px]"></i>
        İptal
    </a>
}

<div class="hero">
    <h1>Kategori Düzenle</h1>
    <div class="sub">
        <span>Kategori bilgilerini güncelleyin</span>
        <span class="pill"><span class="mono">#@category.CategoryId</span></span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div role="alert" style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                background: @(messageType == "success" ? "rgba(16,185,129,0.10)" : "rgba(220,38,38,0.10)");
                border: 1px solid @(messageType == "success" ? "rgba(16,185,129,0.25)" : "rgba(220,38,38,0.25)");
                color: @(messageType == "success" ? "#065f46" : "var(--accent-ink)");">
        <i class="fas @(messageType == "success" ? "fa-check-circle" : "fa-exclamation-circle")" style="margin-right:8px;"></i>
        @message
    </div>
}

<div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; max-width:720px;">
    <div style="padding:14px 18px; border-bottom:1px solid var(--line);">
        <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">
            <i class="fas fa-folder-tree" style="margin-right:6px; color:var(--ink-3);"></i>
            Kategori Bilgileri
        </h2>
        <div style="font-size:12px; color:var(--ink-3); margin-top:2px;">Değişiklikleri kaydedin</div>
    </div>

    <form method="post" style="padding:20px;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="CategoryId" value="@category.CategoryId" />

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
            <div class="field" style="margin-bottom:0;">
                <label class="lab">Kategori Adı <span style="color:var(--accent);">*</span></label>
                <input type="text" name="Name" value="@category.Name" required class="inp" />
            </div>
            <div class="field" style="margin-bottom:0;">
                <label class="lab">Açıklama</label>
                <input type="text" name="Description" value="@category.Description" class="inp" />
            </div>
        </div>

        <div style="display:flex; align-items:center; gap:8px; margin-bottom:18px;">
            <input type="hidden" name="IsActive" value="false" />
            <input type="checkbox" name="IsActive" value="true" id="catActive"
                   @(category.IsActive ? "checked" : "")
                   style="width:16px; height:16px; accent-color:var(--accent);" />
            <label for="catActive" class="lab" style="margin:0;">Kategoriyi aktif yap</label>
        </div>

        <div style="display:flex; align-items:center; justify-content:space-between; padding-top:18px; border-top:1px solid var(--line);">
            <a href="/Admin?tab=categories" class="btn ghost">
                <i class="fas fa-arrow-left text-[10px]"></i>
                Geri Dön
            </a>
            <button type="submit" class="btn primary">
                <i class="fas fa-check text-[10px]"></i>
                Kategoriyi Güncelle
            </button>
        </div>
    </form>
</div>
