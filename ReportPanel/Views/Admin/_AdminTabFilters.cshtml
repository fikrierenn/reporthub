@model ReportPanel.ViewModels.AdminIndexViewModel
@*
    Plan 07 Faz 6 — Admin Filtreler tab.
    FilterDefinition listesi (DataSource bazli gruplandirilmis); CRUD detay sayfasi
    /Admin/CreateFilter ve /Admin/EditFilter/{id}.
*@
@{
    var dataSourceTitleByKey = (Model.DataSources ?? new List<ReportPanel.Models.DataSource>())
        .ToDictionary(ds => ds.DataSourceKey, ds => ds.Title ?? ds.DataSourceKey, StringComparer.OrdinalIgnoreCase);

    var groups = Model.FilterDefinitions
        .GroupBy(f => f.DataSourceKey)
        .OrderBy(g => g.Key == null ? 1 : 0).ThenBy(g => g.Key)
        .ToList();
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
    <div style="font-size:12px; color:var(--ink-3);">
        Veri filtreleri — kullanıcılara atanan FilterDefinition tanımları. Her DataSource kendi
        sube/bolum/kategori vb. filter'larını burada yönetir; cross-cutting (DataSource bağımsız)
        filter'lar "Sistem" başlığı altındadır.
    </div>
    <a href="/Admin/CreateFilter" class="btn primary">
        <i class="fas fa-plus text-[10px]"></i>
        Yeni Filtre
    </a>
</div>

@if (Model.FilterDefinitions.Count == 0)
{
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:24px; text-align:center; font-size:12px; color:var(--ink-3);">
        Henüz filtre tanımı yok. "Yeni Filtre" ile ekleyin.
    </div>
}
else
{
    @foreach (var group in groups)
    {
        var dsKey = group.Key;
        var dsTitle = dsKey == null
            ? "Sistem (cross-cutting)"
            : (dataSourceTitleByKey.TryGetValue(dsKey, out var t) ? $"{t} ({dsKey})" : dsKey);

        <div style="margin-bottom:18px;">
            <div style="display:flex; align-items:center; gap:8px; padding:8px 10px; background:rgba(0,0,0,0.03); border-radius:6px; margin-bottom:8px;">
                <i class="fas fa-database" style="font-size:11px; color:var(--ink-3);"></i>
                <span style="font-size:12px; font-weight:600; color:var(--ink-2); text-transform:uppercase; letter-spacing:0.4px;">@dsTitle</span>
            </div>

            <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;">
                <table class="dt">
                    <thead>
                        <tr>
                            <th>Anahtar</th>
                            <th>Etiket</th>
                            <th>Scope</th>
                            <th>OptionsQuery</th>
                            <th>Sıra</th>
                            <th>Durum</th>
                            <th style="text-align:right;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fd in group.OrderBy(d => d.DisplayOrder).ThenBy(d => d.Label))
                        {
                            <tr>
                                <td><span class="mono">@fd.FilterKey</span></td>
                                <td style="font-weight:500; color:var(--ink-1);">@fd.Label</td>
                                <td>
                                    @if (fd.Scope == "spInjection")
                                    {
                                        <span class="pill" style="font-size:10px;">SP enjeksiyon</span>
                                    }
                                    else
                                    {
                                        <span class="pill" style="font-size:10px; background:rgba(99,102,241,0.10); border-color:rgba(99,102,241,0.25);">Rapor erişim</span>
                                    }
                                </td>
                                <td style="font-size:11px; color:var(--ink-3); max-width:340px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@fd.OptionsQuery">
                                    @(string.IsNullOrEmpty(fd.OptionsQuery) ? "—" : fd.OptionsQuery)
                                </td>
                                <td>@fd.DisplayOrder</td>
                                <td>
                                    <span class="status @(fd.IsActive ? "ok" : "err")">@(fd.IsActive ? "Aktif" : "Pasif")</span>
                                </td>
                                <td style="text-align:right;">
                                    <div style="display:inline-flex; gap:6px;">
                                        <a href="/Admin/EditFilter/@fd.FilterDefinitionId" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px;">
                                            <i class="fas fa-pen text-[9px]"></i>
                                            Düzenle
                                        </a>
                                        <form method="post" style="display:inline;" onsubmit="return confirm('Bu filtre tanimi silinsin mi? Kullanicilara atanan kayitlar kalir.')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="action" value="delete_filter" />
                                            <input type="hidden" name="id" value="@fd.FilterDefinitionId" />
                                            <button type="submit" class="btn ghost" style="font-size:11px; height:28px; padding:0 10px; color:var(--accent-ink);">
                                                <i class="fas fa-trash text-[9px]"></i>
                                                Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
