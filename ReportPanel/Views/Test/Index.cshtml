@model ReportPanel.ViewModels.TestViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Veritabanı Test - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Veritabanı Bağlantı Testi";
}

<div class="hero">
    <h1>Veritabanı Bağlantı Testi</h1>
    <div class="sub">
        <span>Bağlantı ve örnek verileri kontrol edin</span>
        <span class="pill">
            <span class="dot" style="background:@(Model.CanConnect ? "var(--ok)" : "var(--danger)");"></span>
            @(Model.CanConnect ? "Bağlantı Başarılı" : "Bağlantı Başarısız")
        </span>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                background:rgba(220,38,38,0.10); border:1px solid rgba(220,38,38,0.25); color:var(--accent-ink);">
        <i class="fas fa-exclamation-circle" style="margin-right:8px;"></i>
        <strong>Hata:</strong> @Model.Error
    </div>
}

<div class="kpi-grid" style="grid-template-columns:repeat(3,1fr); margin-bottom:18px;">
    <div class="kpi-card k-ink">
        <div class="head">
            <span class="label">Veri Kaynakları</span>
        </div>
        <div class="value">@Model.DataSourceCount</div>
    </div>
    <div class="kpi-card k-ink">
        <div class="head">
            <span class="label">Raporlar</span>
        </div>
        <div class="value">@Model.ReportCount</div>
    </div>
    <div class="kpi-card k-ink">
        <div class="head">
            <span class="label">Loglar</span>
        </div>
        <div class="value">@Model.LogCount</div>
    </div>
</div>

@if (Model.DataSources != null && Model.DataSources.Count > 0)
{
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden; margin-bottom:18px;">
        <div style="padding:14px 18px; border-bottom:1px solid var(--line); display:flex; align-items:center; justify-content:space-between;">
            <h2 style="font-size:13px; font-weight:600; color:var(--ink-1); margin:0;">Mevcut Veri Kaynakları</h2>
            <span style="font-size:11px; color:var(--ink-3);">@Model.DataSources.Count kayıt</span>
        </div>
        <table class="dt">
            <thead>
                <tr>
                    <th>Anahtar</th>
                    <th>Başlık</th>
                    <th>Durum</th>
                    <th>Oluşturulma</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ds in Model.DataSources)
                {
                    <tr>
                        <td><span class="mono">@ds.DataSourceKey</span></td>
                        <td>@ds.Title</td>
                        <td>
                            <span class="status @(ds.IsActive ? "ok" : "err")">@(ds.IsActive ? "Aktif" : "Pasif")</span>
                        </td>
                        <td><span class="ago">@ds.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (Model.DataSources != null)
{
    <div style="background:var(--paper); border:1px dashed var(--line-2); border-radius:10px; padding:32px; text-align:center; color:var(--ink-3); margin-bottom:18px;">
        <i class="fas fa-database" style="font-size:24px; margin-bottom:8px; opacity:0.5;"></i>
        <p style="margin:0;">Henüz veri kaynağı bulunmuyor.</p>
    </div>
}

<div style="display:flex; gap:10px;">
    <button onclick="addSampleData()" class="btn primary">
        <i class="fas fa-plus text-[10px]"></i>
        Örnek Veri Ekle
    </button>
    <button onclick="location.reload()" class="btn">
        <i class="fas fa-rotate text-[10px]"></i>
        Yenile
    </button>
</div>

<script src="~/assets/js/test-page.js"></script>
