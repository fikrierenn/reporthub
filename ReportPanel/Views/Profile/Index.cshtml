@model ReportPanel.ViewModels.ProfileViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Profil - BKM Rapor Paneli";
    var message = Model.Message ?? string.Empty;
    var messageType = Model.MessageType ?? string.Empty;
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Profil</h1>
        <p class="text-sm text-gray-500">Kisisel bilgilerinizi guncelleyin</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="mb-6">
        <div class="@(messageType == "success" ? "bg-green-100 border-green-400 text-green-700" : "bg-red-100 border-red-400 text-red-700") px-4 py-3 rounded border">
            @message
        </div>
    </div>
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="bg-gradient-to-r from-slate-50 to-gray-50 px-8 py-6 border-b border-gray-100">
        <div class="flex items-center space-x-4">
            <div class="w-12 h-12 bg-brand rounded-xl flex items-center justify-center shadow-brand">
                <i class="fas fa-user text-white text-xl"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Hesap Bilgileri</h2>
                <p class="text-gray-600">Roller: @Model.Roles</p>
            </div>
        </div>
    </div>

    <div class="p-8">
        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Kullanici Adi</label>
                    <input type="text" value="@Model.Username" readonly
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg bg-gray-100 text-gray-700">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Durum</label>
                    <input type="text" value="@(Model.IsActive ? "Aktif" : "Pasif")" readonly
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg bg-gray-100 text-gray-700">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Ad Soyad *</label>
                    <input type="text" name="FullName" value="@Model.FullName" required
                           class="form-input-brand w-full px-4 py-3 rounded-lg">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">E-posta</label>
                    <input type="email" name="Email" value="@Model.Email"
                           class="form-input-brand w-full px-4 py-3 rounded-lg">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Yeni Sifre</label>
                    <input type="password" name="NewPassword"
                           class="form-input-brand w-full px-4 py-3 rounded-lg"
                           placeholder="Yeni sifre">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Yeni Sifre (Tekrar)</label>
                    <input type="password" name="ConfirmPassword"
                           class="form-input-brand w-full px-4 py-3 rounded-lg"
                           placeholder="Yeni sifreyi tekrar girin">
                </div>
            </div>

            <div class="flex items-center justify-between pt-6 border-t border-gray-200">
                <a href="/Dashboard" class="btn-brand-outline flex items-center px-6 py-3 text-sm font-medium rounded-lg">
                    <i class="fas fa-arrow-left mr-2"></i>Geri Don
                </a>
                <button type="submit" class="btn-brand flex items-center px-6 py-3 text-sm font-semibold rounded-lg">
                    <i class="fas fa-save mr-2"></i>Profili Guncelle
                </button>
            </div>
        </form>
    </div>
</div>
