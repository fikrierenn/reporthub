@model ReportPanel.ViewModels.ReportRunViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Rapor Calistir - BKM Rapor Paneli";
    ViewData["BodyClass"] = Model.BodyClass;
}

@* ADR-009: Tüm raporlar dashboard — IsDashboard if/else kaldırıldı, tek başlık + tek Tam Ekran butonu. *@
<div class="mb-6 flex items-center gap-3">
    <a href="/Reports" class="text-gray-500 hover:text-brand transition-brand">
        <i class="fas fa-arrow-left text-xl"></i>
    </a>
    <h1 class="text-3xl font-bold text-gray-900">
        <i class="fas fa-chart-pie text-brand mr-2"></i>Dashboard
    </h1>
    @if (Model.RunSuccess)
    {
        <div class="ml-auto">
            <button type="button" onclick="toggleDashboardFullscreen()"
                    class="btn-brand-outline inline-flex items-center px-4 py-2 text-sm font-medium rounded-lg">
                <i class="fas fa-expand mr-2" id="fsIcon"></i>
                Tam Ekran
            </button>
        </div>
    }
</div>

@if (Model.SelectedReport == null)
{
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center">
        Rapor bulunamadı.
    </div>
}
else
{
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 mb-6" id="reportFormCard">
        <div class="flex items-start justify-between">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">@Model.SelectedReport.Title</h2>
                <p class="text-gray-600 mt-2">
                    @(string.IsNullOrWhiteSpace(Model.SelectedReport.Description)
                        ? "Bu rapor için açıklama bulunmuyor."
                        : Model.SelectedReport.Description)
                </p>
                <div class="mt-3 text-sm text-gray-500">
                    <span class="mr-4">
                        <i class="fas fa-database mr-1"></i>
                        @(Model.SelectedReport.DataSource?.Title ?? Model.SelectedReport.DataSourceKey)
                    </span>
                    <span>
                        <i class="fas fa-cog mr-1"></i>
                        @Model.SelectedReport.ProcName
                    </span>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.RunError))
        {
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mt-6">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-circle text-red-500 mr-3 mt-1"></i>
                    <div>
                        <h3 class="text-red-800 font-semibold mb-1">Hata</h3>
                        <p class="text-red-700 text-sm">@Model.RunError</p>
                    </div>
                </div>
            </div>
        }

        <form method="post" action="/Reports/Run" class="mt-8 space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reportId" value="@Model.SelectedReport.ReportId" />
            <input type="hidden" name="viewMode" value="@Model.ViewMode" />

            <div class="flex items-center justify-between pb-4 border-b border-gray-200">
                <div class="text-sm text-gray-500">
                    <i class="fas fa-shield-alt mr-1"></i>
                    Güvenli stored procedure çalıştırma
                </div>
                <button type="submit" class="btn-brand inline-flex items-center px-6 py-3 font-medium rounded-lg transition-brand">
                    <i class="fas fa-play mr-2"></i>
                    Raporu Çalıştır
                </button>
            </div>

            @if (!Model.ParamFields.Any())
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <i class="fas fa-sliders-h text-brand mr-3"></i>
                        <span class="text-brand-dark">
                            Bu rapor parametre gerektirmiyor.
                        </span>
                    </div>
                </div>
            }
            else
            {
                <div class="flex items-center justify-between text-sm text-gray-500 mb-3">
                    <span>* Zorunlu alan</span>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @foreach (var field in Model.ParamFields)
                    {
                        var normalizedType = (field.Type ?? "text").Trim().ToLowerInvariant();
                        normalizedType = normalizedType switch
                        {
                            "int" => "number",
                            "integer" => "number",
                            "decimal" => "decimal",
                            "float" => "decimal",
                            "double" => "decimal",
                            "bit" => "checkbox",
                            "bool" => "checkbox",
                            "boolean" => "checkbox",
                            "datetime" => "date",
                            _ => normalizedType
                        };
                        var requiredAttr = field.Required ? "required" : "";
                        var fieldValue = Model.ParamValues.TryGetValue(field.Name, out var currentValue)
                            ? currentValue
                            : (string.Equals(normalizedType, "date", StringComparison.OrdinalIgnoreCase) &&
                               string.Equals(field.DefaultValue, "today", StringComparison.OrdinalIgnoreCase)
                                ? DateTime.Today.ToString("yyyy-MM-dd")
                                : field.DefaultValue);
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2" for="@field.Name">
                                @field.Label
                                @if (field.Required)
                                {
                                    <span class="text-red-500 ml-1">*</span>
                                }
                            </label>
                            @switch (normalizedType)
                            {
                                case "number":
                                    <input type="number" name="@field.Name" id="@field.Name" @requiredAttr
                                           value="@fieldValue"
                                           placeholder="@field.Placeholder"
                                           class="form-input-brand w-full px-3 py-2 rounded-lg" />
                                    break;
                                case "decimal":
                                    <input type="text" name="@field.Name" id="@field.Name" @requiredAttr
                                           value="@fieldValue"
                                           placeholder="@field.Placeholder"
                                           class="form-input-brand w-full px-3 py-2 rounded-lg" />
                                    break;
                                case "date":
                                    <input type="date" name="@field.Name" id="@field.Name" @requiredAttr
                                           value="@fieldValue"
                                           placeholder="@field.Placeholder"
                                           class="form-input-brand w-full px-3 py-2 rounded-lg" />
                                    break;
                                case "checkbox":
                                    <div class="flex items-center">
                                        @{
                                            var checkedValue = Model.ParamValues.TryGetValue(field.Name, out var cv) && (cv == "true" || cv == "1" || cv == "on");
                                        }
                                        <input type="checkbox" name="@field.Name" id="@field.Name" value="true"
                                               @(checkedValue ? "checked" : "")
                                               class="h-4 w-4 text-brand border-gray-300 rounded" />
                                        <label for="@field.Name" class="ml-2 text-sm text-gray-700">@field.Label</label>
                                    </div>
                                    break;
                                default:
                                    <input type="text" name="@field.Name" id="@field.Name" @requiredAttr
                                           value="@fieldValue"
                                           placeholder="@field.Placeholder"
                                           class="form-input-brand w-full px-3 py-2 rounded-lg" />
                                    break;
                            }
                            @if (!string.IsNullOrWhiteSpace(field.HelpText))
                            {
                                <p class="mt-2 text-xs text-gray-500">@field.HelpText</p>
                            }
                        </div>
                    }
                </div>
            }

        </form>
    </div>

    @if (Model.RunSuccess)
    {
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
            <div class="flex flex-wrap items-center gap-4">
                <div class="flex items-center gap-3">
                    <i class="fas fa-check-circle text-green-500"></i>
                    <div>
                        <p class="text-green-700 font-medium">@Model.RunMessage</p>
                        <p class="text-green-600 text-sm mt-1">
                            Kayıt Sayısı: @Model.RunRowCount, Süre: @Model.RunDurationMs ms
                        </p>
                    </div>
                </div>
                @* ADR-009: Excel dışa aktar butonu tablo raporlarına özeldi — dashboard-only path'te kaldırıldı.
                   Re-introduce edilirse dashboard widget-bazlı export olarak yeniden tasarlanır (M-12). *@
            </div>
        </div>
    }

    @if (Model.RunSuccess && !string.IsNullOrWhiteSpace(Model.DashboardRenderedHtml))
    {
        <div class="rounded-2xl shadow-sm border border-gray-200 overflow-hidden" id="dashboardContainer">
            <iframe id="dashboardFrame"
                    class="w-full border-0"
                    style="min-height: 700px;"
                    sandbox="allow-scripts"
                    srcdoc="@Model.DashboardRenderedHtml">
            </iframe>
        </div>
        <script>
        (function() {
            var frame = document.getElementById('dashboardFrame');
            function resizeFrame() {
                try {
                    var h = frame.contentDocument.documentElement.scrollHeight;
                    if (h > 100) frame.style.height = (h + 40) + 'px';
                } catch(e) {}
            }
            frame.addEventListener('load', function() {
                resizeFrame();
                setTimeout(resizeFrame, 500);
                setTimeout(resizeFrame, 1500);
            });
        })();
        function toggleDashboardFullscreen() {
            var container = document.getElementById('dashboardContainer');
            var icon = document.getElementById('fsIcon');
            if (container.style.position === 'fixed') {
                container.style.position = '';
                container.style.inset = '';
                container.style.zIndex = '';
                container.style.borderRadius = '';
                icon.className = 'fas fa-expand mr-2';
            } else {
                container.style.position = 'fixed';
                container.style.inset = '0';
                container.style.zIndex = '9999';
                container.style.borderRadius = '0';
                icon.className = 'fas fa-compress mr-2';
            }
        }
        </script>
    }

    @* ADR-009: Eski tablo render bloğu (Model.RunData + server-side arama/filtrele/Excel) DROP edildi.
       Tüm rapor çıktısı DashboardRenderer.Render → iframe srcdoc tek path'i üzerinden. *@
}
