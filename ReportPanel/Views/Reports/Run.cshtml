@model ReportPanel.ViewModels.ReportRunViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = $"{Model.SelectedReport?.Title ?? "Rapor Çalıştır"} - BKM Rapor Paneli";
    ViewData["BodyClass"] = Model.BodyClass;

    var report = Model.SelectedReport;
    var dsTitle = report?.DataSource?.Title ?? report?.DataSourceKey ?? "";
}

@section Breadcrumb {
    <div class="crumbs">
        <a href="/Dashboard">BKM Kitap</a>
        <span class="sep">/</span>
        <a href="/Reports">Raporlar</a>
        <span class="sep">/</span>
        <span class="current">@(report?.Title ?? "Rapor")</span>
    </div>
}

@if (Model.RunSuccess)
{
    @section TopActions {
        <button type="button" onclick="toggleDashboardFullscreen()" class="btn">
            <i class="fas fa-expand text-[10px]" id="fsIcon"></i>
            Tam Ekran
        </button>
    }
}

@if (report == null)
{
    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:32px; text-align:center; color:var(--ink-3);">
        Rapor bulunamadı.
    </div>
}
else
{
    <div class="hero">
        <h1>@report.Title</h1>
        <div class="sub">
            @if (!string.IsNullOrWhiteSpace(report.Description))
            {
                <span>@report.Description</span>
            }
            <span class="pill">
                <i class="fas fa-database" style="font-size:9px; color:var(--ink-3);"></i>
                @dsTitle
            </span>
            <span class="pill">
                <span class="mono">@report.ProcName</span>
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.RunError))
    {
        <div style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                    background:rgba(220,38,38,0.10); border:1px solid rgba(220,38,38,0.25); color:var(--accent-ink);">
            <i class="fas fa-exclamation-circle" style="margin-right:8px;"></i>
            <strong>Hata:</strong> @Model.RunError
        </div>
    }

    <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:20px; margin-bottom:18px;" id="reportFormCard">
        <form method="post" action="/Reports/Run">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reportId" value="@report.ReportId" />
            <input type="hidden" name="viewMode" value="@Model.ViewMode" />

            <div style="display:flex; align-items:center; justify-content:space-between; padding-bottom:14px; border-bottom:1px solid var(--line); margin-bottom:18px;">
                <div style="font-size:12px; color:var(--ink-3);">
                    <i class="fas fa-shield-halved" style="margin-right:6px;"></i>
                    Güvenli stored procedure çalıştırma
                </div>
                <button type="submit" class="btn primary">
                    <i class="fas fa-play text-[10px]"></i>
                    Raporu Çalıştır
                </button>
            </div>

            @if (!Model.ParamFields.Any())
            {
                <div style="padding:14px 16px; border-radius:8px; background:var(--canvas); border:1px dashed var(--line-2); color:var(--ink-3); font-size:13px;">
                    <i class="fas fa-sliders" style="margin-right:8px;"></i>
                    Bu rapor parametre gerektirmiyor.
                </div>
            }
            else
            {
                <div style="font-size:11px; color:var(--ink-3); margin-bottom:10px;">
                    <span style="color:var(--accent);">*</span> Zorunlu alan
                </div>
                <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:14px;">
                    @foreach (var field in Model.ParamFields)
                    {
                        var normalizedType = (field.Type ?? "text").Trim().ToLowerInvariant();
                        normalizedType = normalizedType switch
                        {
                            "int" => "number",
                            "integer" => "number",
                            "decimal" => "decimal",
                            "float" => "decimal",
                            "double" => "decimal",
                            "bit" => "checkbox",
                            "bool" => "checkbox",
                            "boolean" => "checkbox",
                            "datetime" => "date",
                            _ => normalizedType
                        };
                        var requiredAttr = field.Required ? "required" : "";
                        var fieldValue = Model.ParamValues.TryGetValue(field.Name, out var currentValue)
                            ? currentValue
                            : (string.Equals(normalizedType, "date", StringComparison.OrdinalIgnoreCase) &&
                               string.Equals(field.DefaultValue, "today", StringComparison.OrdinalIgnoreCase)
                                ? DateTime.Today.ToString("yyyy-MM-dd")
                                : field.DefaultValue);

                        if (normalizedType == "checkbox")
                        {
                            var checkedValue = Model.ParamValues.TryGetValue(field.Name, out var cv) && (cv == "true" || cv == "1" || cv == "on");
                            <div class="field" style="margin-bottom:0; display:flex; align-items:center; gap:8px;">
                                <input type="checkbox" name="@field.Name" id="@field.Name" value="true"
                                       @(checkedValue ? "checked" : "")
                                       style="width:16px; height:16px; accent-color:var(--accent);" />
                                <label class="lab" for="@field.Name" style="margin:0;">
                                    @field.Label
                                    @if (field.Required)
                                    {
                                        <span style="color:var(--accent);">*</span>
                                    }
                                </label>
                            </div>
                        }
                        else
                        {
                            <div class="field" style="margin-bottom:0;">
                                <label class="lab" for="@field.Name">
                                    @field.Label
                                    @if (field.Required)
                                    {
                                        <span style="color:var(--accent);">*</span>
                                    }
                                </label>
                                @switch (normalizedType)
                                {
                                    case "number":
                                        <input type="number" name="@field.Name" id="@field.Name" @requiredAttr
                                               value="@fieldValue" placeholder="@field.Placeholder" class="inp" />
                                        break;
                                    case "decimal":
                                        <input type="text" name="@field.Name" id="@field.Name" @requiredAttr
                                               value="@fieldValue" placeholder="@field.Placeholder" class="inp" />
                                        break;
                                    case "date":
                                        <input type="date" name="@field.Name" id="@field.Name" @requiredAttr
                                               value="@fieldValue" placeholder="@field.Placeholder" class="inp" />
                                        break;
                                    default:
                                        <input type="text" name="@field.Name" id="@field.Name" @requiredAttr
                                               value="@fieldValue" placeholder="@field.Placeholder" class="inp" />
                                        break;
                                }
                                @if (!string.IsNullOrWhiteSpace(field.HelpText))
                                {
                                    <p style="margin-top:6px; font-size:11px; color:var(--ink-3);">@field.HelpText</p>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </form>
    </div>

    @if (Model.RunSuccess)
    {
        <div style="margin-bottom:18px; padding:12px 16px; border-radius:10px; font-size:13px;
                    background:rgba(16,185,129,0.10); border:1px solid rgba(16,185,129,0.25); color:#065f46;
                    display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
            <i class="fas fa-circle-check"></i>
            <div>
                <div style="font-weight:600;">@Model.RunMessage</div>
                <div style="font-size:11px; opacity:0.85; margin-top:2px;">
                    Kayıt: <span class="mono">@Model.RunRowCount</span> · Süre: <span class="mono">@Model.RunDurationMs ms</span>
                </div>
            </div>
        </div>
    }

    @if (Model.RunSuccess && !string.IsNullOrWhiteSpace(Model.DashboardRenderedHtml))
    {
        <div style="background:var(--paper); border:1px solid var(--line); border-radius:10px; overflow:hidden;" id="dashboardContainer">
            <iframe id="dashboardFrame"
                    style="width:100%; min-height:700px; border:0; display:block;"
                    sandbox="allow-scripts allow-downloads"
                    srcdoc="@Model.DashboardRenderedHtml">
            </iframe>
        </div>
        <script>
        (function() {
            var frame = document.getElementById('dashboardFrame');
            function resizeFrame() {
                try {
                    var h = frame.contentDocument.documentElement.scrollHeight;
                    if (h > 100) frame.style.height = (h + 40) + 'px';
                } catch(e) {}
            }
            frame.addEventListener('load', function() {
                resizeFrame();
                setTimeout(resizeFrame, 500);
                setTimeout(resizeFrame, 1500);
            });
        })();
        function toggleDashboardFullscreen() {
            var container = document.getElementById('dashboardContainer');
            var icon = document.getElementById('fsIcon');
            if (container.style.position === 'fixed') {
                container.style.position = '';
                container.style.inset = '';
                container.style.zIndex = '';
                container.style.borderRadius = '';
                icon.className = 'fas fa-expand text-[10px]';
            } else {
                container.style.position = 'fixed';
                container.style.inset = '0';
                container.style.zIndex = '9999';
                container.style.borderRadius = '0';
                icon.className = 'fas fa-compress text-[10px]';
            }
        }
        </script>
    }
}
