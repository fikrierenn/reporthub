@model ReportPanel.ViewModels.ReportsIndexViewModel
@using System.Security.Claims
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Raporlar - BKM Rapor Paneli";
    ViewData["PageTitle"] = "Raporlar";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isAdmin = User.IsInRole("admin");
    var totalCount = Model.Reports.Count;
    var favCount = Model.FavoriteReportIds.Count;
}

@* Breadcrumb default: _AppLayout ViewData["PageTitle"] = "Raporlar"'dan otomatik üretir *@

@section TopActions {
    @if (isAdmin)
    {
        <a href="/Admin/CreateReport" class="btn primary">
            <i class="fas fa-plus text-[10px]"></i>
            Yeni Rapor
        </a>
    }
    <a href="#" class="icon-btn" title="Yardım">
        <i class="fas fa-circle-question"></i>
    </a>
}

@* ============ HERO ============ *@
<div class="hero">
    <h1>Raporlar</h1>
    <div class="sub">
        <span class="mono">@totalCount erişilebilir rapor</span>
        @if (favCount > 0)
        {
            <span class="pill"><i class="fas fa-star" style="color:var(--accent); font-size:10px;"></i> @favCount favori</span>
        }
        @if (Model.UserRoles.Any())
        {
            <span class="pill mono">@string.Join(" · ", Model.UserRoles)</span>
        }
    </div>
</div>

@* ============ FİLTRE BAR ============ *@
<form method="get" class="report-filter-bar" style="background:var(--paper); border:1px solid var(--line); border-radius:10px; padding:14px 16px; margin-bottom:18px; display:flex; gap:12px; flex-wrap:wrap; align-items:end;">
    <div style="flex:1; min-width:240px;">
        <label class="lab" for="reportSearch">Arama</label>
        <div style="position:relative;">
            <span style="position:absolute; left:10px; top:50%; transform:translateY(-50%); color:var(--ink-4); pointer-events:none;">
                <i class="fas fa-magnifying-glass" style="font-size:12px;"></i>
            </span>
            <input type="text" id="reportSearch" name="q" value="@Model.SearchTerm"
                   class="inp" style="padding-left:32px;"
                   placeholder="Rapor adı, açıklama veya kategori..." />
        </div>
    </div>

    <div style="min-width:180px;">
        <label class="lab" for="reportCategory">Kategori</label>
        <select id="reportCategory" name="category" class="inp">
            <option value="">Tüm kategoriler</option>
            @foreach (var category in Model.Categories)
            {
                <option value="@category" selected="@(string.Equals(category, Model.SelectedCategory, StringComparison.OrdinalIgnoreCase))">
                    @category
                </option>
            }
        </select>
    </div>

    <div style="display:flex; gap:6px;">
        <button type="submit" class="btn primary">
            <i class="fas fa-filter text-[10px]"></i>
            Filtrele
        </button>
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || !string.IsNullOrWhiteSpace(Model.SelectedCategory))
        {
            <a href="/Reports" class="btn ghost">
                <i class="fas fa-xmark text-[10px]"></i>
                Temizle
            </a>
        }
    </div>
</form>

@* ============ RAPORLAR — qcard grid ============ *@
@if (!Model.Reports.Any())
{
    <div style="background:var(--paper); border:1px dashed var(--line); border-radius:10px; padding:48px 24px; text-align:center; color:var(--ink-3);">
        <i class="fas fa-folder-open" style="font-size:48px; opacity:.4; margin-bottom:12px;"></i>
        <h3 style="font-size:14px; font-weight:600; color:var(--ink-1); margin:0 0 4px;">Erişilebilir rapor bulunamadı</h3>
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || !string.IsNullOrWhiteSpace(Model.SelectedCategory))
        {
            <p style="margin:0; font-size:12.5px;">Filtre kriterlerini değiştirin veya <a href="/Reports" style="color:var(--accent); font-weight:500;">filtreyi temizle</a>.</p>
        }
        else
        {
            <p style="margin:0; font-size:12.5px;">Yöneticinizden rol veya rapor erişimi isteyin.</p>
        }
    </div>
}
else
{
    <div class="quick-grid">
        @foreach (var report in Model.Reports)
        {
            var isFavorite = Model.FavoriteReportIds.Contains(report.ReportId);
            var categoryNames = report.ReportCategories
                .Select(rc => rc.Category?.Name ?? "")
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .ToList();
            var displaySub = string.IsNullOrWhiteSpace(report.Description)
                ? (categoryNames.Count > 0 ? string.Join(", ", categoryNames) : (report.DataSource?.Title ?? report.DataSourceKey))
                : report.Description;
            <div class="qcard" style="position:relative;">
                <div class="row1">
                    <span class="type-chip type-dash">Dashboard</span>
                    <span class="mono" style="font-size:10.5px; color:var(--ink-4); margin-left:auto;">#@report.ReportId</span>
                    <form method="post" action="@(isFavorite ? "/Reports/Unfavorite" : "/Reports/Favorite")" style="display:inline; margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reportId" value="@report.ReportId" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit"
                                class="fav @(isFavorite ? "on" : "")"
                                title="@(isFavorite ? "Favoriden kaldır" : "Favorilere ekle")"
                                style="position:relative; z-index:2;">
                            @if (isFavorite)
                            {
                                <i class="fas fa-star" style="font-size:12px;"></i>
                            }
                            else
                            {
                                <i class="far fa-star" style="font-size:12px;"></i>
                            }
                        </button>
                    </form>
                </div>
                <a href="/Reports/Run?reportId=@report.ReportId" style="text-decoration:none; color:inherit;">
                    <h3>@report.Title</h3>
                    <div class="sub">@displaySub</div>
                    <div class="meta">
                        <span class="ago" style="font-family:'JetBrains Mono',monospace;">
                            <i class="fas fa-database" style="font-size:9px; color:var(--ink-4); margin-right:3px;"></i>
                            @(report.DataSource?.Title ?? report.DataSourceKey)
                        </span>
                        <span class="run">Çalıştır <i class="fas fa-arrow-right text-[10px]"></i></span>
                    </div>
                </a>
            </div>
        }
    </div>
}

<div class="footer-hint">
    <span class="kbd">⌘K</span> hızlı arama
    <span style="margin:0 8px;">·</span>
    <span class="mono">@totalCount rapor</span>
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <span style="margin:0 8px;">·</span>
        <span>arama: <span class="mono">"@Model.SearchTerm"</span></span>
    }
    @if (!string.IsNullOrWhiteSpace(Model.SelectedCategory))
    {
        <span style="margin:0 8px;">·</span>
        <span>kategori: <span class="mono">@Model.SelectedCategory</span></span>
    }
</div>
