@model ReportPanel.ViewModels.ReportsIndexViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Raporlar - BKM Rapor Paneli";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Raporlar</h1>
    <p class="text-gray-600">Rolleriniz: @string.Join(", ", Model.UserRoles)</p>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 overflow-hidden">
    <form method="get" class="px-6 py-4 flex flex-col gap-4 md:flex-row md:items-end">
        <div class="flex-1">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Arama</label>
            <input type="text" name="q" value="@Model.SearchTerm"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg"
                   placeholder="Rapor adi, aciklama, kategori...">
        </div>
        <div class="w-full md:w-64">
            <label class="block text-sm font-semibold text-gray-700 mb-2">Kategori</label>
            <select name="category" class="w-full px-4 py-3 border border-gray-300 rounded-lg">
                <option value="">Tum kategoriler</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category" selected="@(string.Equals(category, Model.SelectedCategory, StringComparison.OrdinalIgnoreCase))">
                        @category
                    </option>
                }
            </select>
        </div>
        <div class="flex items-center gap-3">
            <button type="submit" class="btn-brand inline-flex items-center px-5 py-3 text-sm font-semibold rounded-lg">
                Filtrele
            </button>
            <a href="/Reports" class="btn-brand-outline inline-flex items-center px-5 py-3 text-sm font-semibold rounded-lg">
                Temizle
            </a>
        </div>
    </form>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">Raporlar (@Model.Reports.Count)</h2>
    </div>
    <div class="divide-y divide-gray-100">
        @if (!Model.Reports.Any())
        {
            <div class="p-8 text-center text-gray-500">
                Erisiminiz olan rapor bulunmamaktadir.
            </div>
        }
        else
        {
            @foreach (var report in Model.Reports)
            {
                var isFavorite = Model.FavoriteReportIds.Contains(report.ReportId);
                <div class="flex items-center justify-between px-6 py-5 hover:bg-gray-50 transition-brand">
                    <a href="/Reports/Run?reportId=@report.ReportId" class="min-w-0 flex-1">
                        <div class="text-base font-semibold text-gray-900 truncate">
                            @report.Title
                            @if (report.ReportType == "dashboard")
                            {
                                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
                                    <i class="fas fa-chart-pie mr-1 text-xs"></i>Dashboard
                                </span>
                            }
                        </div>
                        <div class="text-sm text-gray-600 truncate">
                            @(string.IsNullOrWhiteSpace(report.Description) ? "Aciklama bulunmuyor" : report.Description)
                        </div>
                        <div class="mt-2 text-xs text-gray-500">
                            <i class="fas fa-database mr-1"></i>
                            @(report.DataSource?.Title ?? report.DataSourceKey)
                        </div>
                        @{
                            var categoryNames = report.ReportCategories
                                .Select(rc => rc.Category?.Name ?? "")
                                .Where(name => !string.IsNullOrWhiteSpace(name))
                                .ToList();
                            if (categoryNames.Count > 0)
                            {
                                <div class="mt-2 text-xs text-gray-500">
                                    <i class="fas fa-folder-open mr-1"></i>
                                    @string.Join(", ", categoryNames)
                                </div>
                            }
                        }
                    </a>
                    <div class="flex items-center gap-3">
                        <form method="post" action="@(isFavorite ? "/Reports/Unfavorite" : "/Reports/Favorite")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="reportId" value="@report.ReportId" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit"
                                    class="text-sm @(isFavorite ? "text-yellow-500" : "text-gray-400 hover:text-gray-600")"
                                    title="@(isFavorite ? "Favoriden kaldir" : "Favorilere ekle")">
                                <i class="@(isFavorite ? "fas fa-star" : "far fa-star")"></i>
                            </button>
                        </form>
                        <div class="text-sm text-gray-400">
                            <i class="fas fa-chevron-right"></i>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
