@using System.Security.Claims
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var userName = isAuthenticated ? User?.Identity?.Name ?? "" : "";
    var fullName = isAuthenticated
        ? User?.Claims?.FirstOrDefault(claim => claim.Type == "full_name")?.Value ?? ""
        : "";
    var userRoles = isAuthenticated
        ? User?.Claims?
            .Where(claim => claim.Type == ClaimTypes.Role)
            .Select(claim => claim.Value)
            .Distinct()
            .ToArray() ?? Array.Empty<string>()
        : Array.Empty<string>();
    var isAdminUser = userRoles.Any(role => role.Equals("admin", StringComparison.OrdinalIgnoreCase));
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool IsActive(params string[] controllers) => controllers.Any(c => controller.Equals(c, StringComparison.OrdinalIgnoreCase));
    string AvatarInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(new[] { ' ', '.', '_' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        return name.Substring(0, Math.Min(2, name.Length)).ToUpperInvariant();
    }
    var avatar = AvatarInitials(string.IsNullOrWhiteSpace(fullName) ? userName : fullName);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light">
    <title>@ViewData["Title"]</title>

    @* M-13 Plan 03 Faz A: Inter+JetBrains Mono proje-wide font + Tailwind CDN + Font Awesome + style.css + app-shell.css *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/assets/css/style.css" rel="stylesheet" asp-append-version="true">
    <link href="~/assets/css/app-shell.css" rel="stylesheet" asp-append-version="true">

    @* M-13 Plan 04 (28 Nisan 2026): Alpine.js + htmx CDN-only entegrasyon. Build step yok.
       Alpine = client state (toggle/modal/form), htmx = server-driven swap (SP preview, list refresh).
       Skill: .claude/skills/alpine-js/ + .claude/skills/htmx-expert/. *@
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@@2.0.4/dist/htmx.min.js"></script>

    @RenderSection("Head", required: false)
</head>
<body class="@(ViewData["BodyClass"] as string ?? "")">

<div class="app-shell" id="appShell">

    @* ============ SIDEBAR ============ *@
    <aside class="sidebar">

        <div class="side-head">
            <a href="/Dashboard" class="brand-mark" title="ReportHub">R</a>
            <div class="brand-name">
                <div class="t">ReportHub</div>
                <span class="s">bkm-kitap</span>
            </div>
            <button class="side-collapse" id="btnSidebarCollapse" type="button" title="Daralt/Aç (Ctrl+B)">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>

        <div class="side-body">

            @if (isAuthenticated)
            {
                <div class="side-section">Ana</div>
                <ul class="nav-list">
                    <li>
                        <a href="/Dashboard" class="@(IsActive("Dashboard") ? "active" : "")">
                            <span class="icon"><i class="fas fa-house"></i></span>
                            <span class="label">Genel Bakış</span>
                        </a>
                    </li>
                    <li>
                        <a href="/Reports" class="@(IsActive("Reports") ? "active" : "")">
                            <span class="icon"><i class="fas fa-chart-column"></i></span>
                            <span class="label">Raporlar</span>
                        </a>
                    </li>
                </ul>

                @if (isAdminUser)
                {
                    <div class="side-section">Sistem</div>
                    <ul class="nav-list">
                        <li>
                            <a href="/Logs" class="@(IsActive("Logs") ? "active" : "")">
                                <span class="icon"><i class="fas fa-clock-rotate-left"></i></span>
                                <span class="label">Geçmiş / Loglar</span>
                            </a>
                        </li>
                    </ul>

                    @* M-13 Plan 03 Faz D: Yönetim section sadeleştirildi.
                       Eski: 6 link (Yönetim Paneli + Rapor/Kullanıcı/Rol/Kategori/Veri Kaynağı yönetimleri).
                       Sorun: 5 alt-link sidebar + Admin/Index subnav'da duplicate; üstelik /Admin/Reports vb.
                       AdminController'da action olmadığından 404 dönüyordu.
                       Yeni: Tek "Yönetim Paneli" linki, alt-section'lar Admin/Index içindeki subnav'da. *@
                    <div class="side-section">Yönetim</div>
                    <ul class="nav-list">
                        <li>
                            <a href="/Admin" class="@(IsActive("Admin") ? "active" : "")">
                                <span class="icon"><i class="fas fa-gauge-high"></i></span>
                                <span class="label">Yönetim Paneli</span>
                            </a>
                        </li>
                    </ul>
                }
            }
        </div>

        @if (isAuthenticated)
        {
            <div class="side-foot">
                <div class="avatar">@avatar</div>
                <div class="user-info">
                    <div class="n">@(string.IsNullOrWhiteSpace(fullName) ? userName : fullName)</div>
                    <div class="r">@(userRoles.Length > 0 ? string.Join(", ", userRoles) : "user")</div>
                </div>
                <div class="user-actions">
                    <a href="/Profile" title="Profil"><i class="fas fa-user-gear"></i></a>
                    <a href="/Login?logout=1" class="danger" title="Çıkış"><i class="fas fa-right-from-bracket"></i></a>
                </div>
            </div>
        }
    </aside>

    @* ============ MAIN ============ *@
    <main class="main">

        <div class="topbar">
            <button class="mobile-menu" id="btnMobileMenu" type="button" title="Menü">
                <i class="fas fa-bars"></i>
            </button>

            @* Breadcrumb slot — view'lar override edebilir *@
            @if (IsSectionDefined("Breadcrumb"))
            {
                @RenderSection("Breadcrumb", required: false)
            }
            else
            {
                <div class="crumbs">
                    <a href="/Dashboard">BKM Kitap</a>
                    <span class="sep">/</span>
                    <span class="current">@(ViewData["PageTitle"] as string ?? ViewData["Title"]?.ToString()?.Split(" - ")[0] ?? "")</span>
                </div>
            }

            @* Search slot — view'lar disable edebilir *@
            @if (!(ViewData["HideSearch"] is bool hideSearch && hideSearch))
            {
                <div class="search">
                    <span class="ico"><i class="fas fa-magnifying-glass"></i></span>
                    <input type="text" placeholder="Rapor, dashboard, kullanıcı ara..." />
                    <span class="kbd">⌘K</span>
                </div>
            }

            <div class="top-actions">
                @* TopActions slot — builder gibi sayfalar mode/dirty/Kaydet butonlarını buraya enjekte eder *@
                @if (IsSectionDefined("TopActions"))
                {
                    @RenderSection("TopActions", required: false)
                }
                else if (isAuthenticated)
                {
                    <a href="#" class="icon-btn" title="Bildirimler">
                        <i class="fas fa-bell"></i>
                    </a>
                    <a href="#" class="icon-btn" title="Yardım">
                        <i class="fas fa-circle-question"></i>
                    </a>
                }
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </main>

</div>

<script src="~/assets/js/app-shell.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
