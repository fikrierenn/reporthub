@*
    Yeniden kullanılabilir parola input + show/hide toggle (Alpine.js).
    Plan 04 F2.3 (28 Nisan 2026): Login.cshtml + Profile/Index.cshtml DRY — 3 yerde tekrar yerine
    tek partial. Razor `:` attribute desteklemediği için x-init + $watch pattern, asp-for yerine
    manuel name (tag helper static type="password" eklemesi Alpine override'ı kırıyor).

    Kullanım:
      @await Html.PartialAsync("_PasswordInput", new PasswordInputViewModel {
          Id = "Password", Name = "Password", Label = "Şifre",
          Placeholder = "Şifrenizi girin",
          Autocomplete = "current-password", Required = true
      })
*@
@model ReportPanel.ViewModels.PasswordInputViewModel

<div class="field" x-data="{ shown: false }">
    @if (!string.IsNullOrWhiteSpace(Model.Label))
    {
        <label class="lab" for="@Model.Id">@Model.Label</label>
    }
    <div style="position:relative;">
        <input id="@Model.Id" name="@Model.Name" type="password"
               @(Model.Required ? "required" : "")
               autocomplete="@Model.Autocomplete"
               class="inp" style="padding-right:38px;"
               placeholder="@Model.Placeholder"
               x-init="$watch('shown', v => $el.type = v ? 'text' : 'password')" />
        <button type="button" @@click="shown = !shown"
                style="position:absolute; right:8px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--ink-3); padding:4px;"
                :title="shown ? 'Şifreyi gizle' : 'Şifreyi göster'"
                :aria-label="shown ? 'Şifreyi gizle' : 'Şifreyi göster'">
            <i class="fas" :class="shown ? 'fa-eye-slash' : 'fa-eye'"></i>
        </button>
    </div>
</div>
